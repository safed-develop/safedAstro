---
import BaseLayout from './BaseLayout.astro';
import SubHeroSection from '../components/common/SubHeroSection.astro';
import HorizontalNav from '../components/common/HorizontalNav.astro';

interface Props {
  title: string;
  pageTitle: string;
  pageTitleEn?: string;
  description?: string;
  keywords?: string;
  breadcrumbs?: { label: string; href?: string }[];
  navLinks?: { name: string; url: string }[];
}

const {
  title,
  pageTitle,
  pageTitleEn,
  description,
  keywords,
  breadcrumbs,
  navLinks,
} = Astro.props;
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <SubHeroSection title={pageTitle} titleEn={pageTitleEn} breadcrumbs={breadcrumbs} />
  {navLinks && <HorizontalNav links={navLinks} />}
  <slot />
</BaseLayout>
