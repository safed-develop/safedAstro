---
import '../styles/global.css';
import '../styles/mobile-custom.css';
import Navigation from '../components/common/Navigation.astro';
import Footer from '../components/common/Footer.astro';
import FixedButtons from '../components/common/FixedButtons.astro';
import PdfFloatingButton from '../components/common/PdfFloatingButton.astro';
import MobileBottomBar from '../components/common/MobileBottomBar.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
  hideFixedButtons?: boolean;
  hidePdfButton?: boolean;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description = '세이프디(SafeD)는 건설·산업 현장 스마트 안전관리 플랫폼입니다. 위험성평가·GPS·비콘·AI 번역으로 중대재해처벌법 대응을 자동화합니다.',
  keywords,
  ogImage = '/images/oglogo.jpg',
  canonicalUrl,
  hideFixedButtons = false,
  hidePdfButton = true,
  jsonLd,
  noindex = false,
} = Astro.props;

// ── 사이트 엔티티 상수 ─────────────────────────
const SITE_URL = 'https://www.safed.kr';
const SITE_NAME = '세이프디';
const LEGAL_NAME = '주식회사 세이프디';
// ─────────────────────────────────────────────

const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : Astro.url.pathname + '/';
const canonical = canonicalUrl || `${SITE_URL}${pathname}`;
const isHome = pathname === '/';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    <!-- Verification -->
    <meta name="naver-site-verification" content="1651e4200fe4313c8cf0f5fd4a870677fccdf5be" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ko_KR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}${ogImage}`} />

    <!-- Favicon / App Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="shortcut icon" href="/favicon.ico?v=2" />
    <link rel="apple-touch-icon" href="/favicon.ico?v=2" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0060B7" />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap"
      rel="stylesheet"
    />

    <!-- Organization JSON-LD (모든 페이지 공통) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      "name": SITE_NAME,
      "alternateName": ["SafeD", "세이프디", "주식회사 세이프디"],
      "legalName": LEGAL_NAME,
      "url": SITE_URL,
      "logo": {
        "@type": "ImageObject",
        "url": `${SITE_URL}/images/oglogo.jpg`,
        "width": 1200,
        "height": 630
      },
      "image": `${SITE_URL}/images/oglogo.jpg`,
      "description": "세이프디(SafeD)는 건설·산업 현장 스마트 안전관리 플랫폼입니다. 위험성평가, GPS 모니터링, 비콘, AI 번역, 중대재해처벌법 대응을 하나로 통합합니다.",
      "taxID": "724-81-03168",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "테헤란로 534, 21층 글라스타워",
        "addressLocality": "강남구",
        "addressRegion": "서울특별시",
        "postalCode": "06178",
        "addressCountry": "KR"
      },
      "contactPoint": [{
        "@type": "ContactPoint",
        "telephone": "+82-2-6748-0836",
        "contactType": "sales",
        "email": "sales@safed.co.kr",
        "areaServed": "KR",
        "availableLanguage": ["ko", "en"]
      }],
      "sameAs": [
        "https://play.google.com/store/apps/details?id=kr.co.yido.safeD",
        "https://apps.apple.com/kr/app/id1542123112",
        "https://safed.co.kr"
      ]
    })} />

    <!-- WebSite JSON-LD (홈에서만 1회) -->
    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": `${SITE_URL}/#website`,
        "url": SITE_URL,
        "name": SITE_NAME,
        "alternateName": "SafeD",
        "inLanguage": "ko-KR",
        "publisher": { "@id": `${SITE_URL}/#organization` }
      })} />
    )}

    <!-- 페이지별 JSON-LD -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <slot name="head" />

    <!-- Custom scrollbar: no native bar, custom overlay with hover track -->
    <script is:inline>
      (function(){
        // Hide native scrollbar
        var hide = document.createElement('style');
        var ff = navigator.userAgent.indexOf('Firefox') > -1;
        hide.textContent = ff
          ? 'html{scrollbar-width:none}'
          : '::-webkit-scrollbar{width:0;height:0;display:none}';
        document.head.appendChild(hide);

        // Create track + thumb
        var track = document.createElement('div');
        var thumb = document.createElement('div');
        track.id = 'cbar-track';
        thumb.id = 'cbar-thumb';

        track.style.cssText = 'position:fixed;top:0;right:0;width:8px;height:100vh;z-index:9999;'
          + 'opacity:0;transition:opacity .3s;cursor:pointer;';
        thumb.style.cssText = 'position:absolute;right:0;width:3px;border-radius:0;'
          + 'transition:width .2s,opacity .3s,background .3s;pointer-events:none;';

        track.appendChild(thumb);
        document.body.appendChild(track);

        // Brightness probe
        function probeDark(y) {
          var el = document.elementFromPoint(window.innerWidth - 20, y);
          if (!el) return false;
          var node = el;
          while (node && node !== document.documentElement) {
            var bg = getComputedStyle(node).backgroundColor;
            if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
              var m = bg.match(/\d+/g);
              if (m) return ((parseInt(m[0])*299+parseInt(m[1])*587+parseInt(m[2])*114)/1000) < 80;
              break;
            }
            node = node.parentElement;
          }
          return false;
        }

        function update() {
          var doc = document.documentElement;
          var scrollH = doc.scrollHeight - doc.clientHeight;
          if (scrollH <= 0) return;
          var ratio = doc.clientHeight / doc.scrollHeight;
          var thumbH = Math.max(ratio * doc.clientHeight, 30);
          var top = (window.scrollY / scrollH) * (doc.clientHeight - thumbH);
          var dark = probeDark(top + thumbH / 2);

          thumb.style.height = thumbH + 'px';
          thumb.style.top = top + 'px';
          thumb.style.background = dark ? 'rgba(255,255,255,0.45)' : 'rgba(0,0,0,0.25)';

          // Track bg matches section = invisible
          track.style.background = 'transparent';
        }

        // Show on scroll
        var fadeTimer;
        function showBar() {
          update();
          track.style.opacity = '1';
          clearTimeout(fadeTimer);
          fadeTimer = setTimeout(function(){ track.style.opacity = '0'; }, 1200);
        }

        // Hover: show track bg matching section color + widen thumb
        track.addEventListener('mouseenter', function() {
          clearTimeout(fadeTimer);
          track.style.opacity = '1';
          thumb.style.width = '5px';
          // Sample section bg for track
          var doc = document.documentElement;
          var scrollH = doc.scrollHeight - doc.clientHeight;
          if (scrollH <= 0) return;
          var ratio = doc.clientHeight / doc.scrollHeight;
          var thumbH = Math.max(ratio * doc.clientHeight, 30);
          var top = (window.scrollY / scrollH) * (doc.clientHeight - thumbH);
          var dark = probeDark(top + thumbH / 2);
          track.style.background = dark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)';
        });
        track.addEventListener('mouseleave', function() {
          thumb.style.width = '3px';
          track.style.background = 'transparent';
          fadeTimer = setTimeout(function(){ track.style.opacity = '0'; }, 800);
        });

        // Click track to jump
        track.addEventListener('click', function(e) {
          var doc = document.documentElement;
          var scrollH = doc.scrollHeight - doc.clientHeight;
          var clickRatio = e.clientY / window.innerHeight;
          window.scrollTo({ top: clickRatio * scrollH, behavior: 'smooth' });
        });

        window.addEventListener('scroll', showBar, { passive: true });
        window.addEventListener('resize', update, { passive: true });
      })();
    </script>
  </head>
  <body>
    <Navigation />

    <main>
      <slot />
    </main>

    <Footer />

    {!hideFixedButtons && <FixedButtons />}
    {!hidePdfButton && <PdfFloatingButton />}
    <MobileBottomBar />

    <!-- Naver Analytics -->
    <script is:inline src="https://wcs.naver.net/wcslog.js"></script>
    <script is:inline>
      if (!window.wcs_add) window.wcs_add = {};
      wcs_add["wa"] = "s_f9ed5407f8b";
      if (window.wcs) {
        wcs.inflow();
        wcs_do();
      }
    </script>

    <!-- Scroll Reveal Observer -->
    <script is:inline>
      (function() {
        var SEL = '.reveal, .reveal-left, .reveal-right, .reveal-scale';
        var observed = new WeakSet();

        var observer = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        function scan() {
          document.querySelectorAll(SEL).forEach(function(el) {
            if (!observed.has(el)) {
              observed.add(el);
              observer.observe(el);
            }
          });
        }

        // Initial scan
        scan();

        // Re-scan after React hydration completes
        setTimeout(scan, 500);
        setTimeout(scan, 1500);

        // Watch for dynamically added elements
        var mo = new MutationObserver(function() { scan(); });
        mo.observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>
