---
import '../styles/global.css';
import Navigation from '../components/common/Navigation.astro';
import Footer from '../components/common/Footer.astro';
import FixedButtons from '../components/common/FixedButtons.astro';
import PdfFloatingButton from '../components/common/PdfFloatingButton.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalUrl?: string;
  hideFixedButtons?: boolean;
  hidePdfButton?: boolean;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description = 'SafeD - 스마트 안전관리 시스템. 건설현장 안전관리의 새로운 기준을 제시합니다.',
  keywords = 'SafeD, 안전관리, 스마트안전, 건설안전, 안전관리시스템',
  ogImage = '/images/oglogo.jpg',
  canonicalUrl,
  hideFixedButtons = false,
  hidePdfButton = false,
  jsonLd,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://www.safed.co.kr';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Naver Search Advisor -->
    <meta name="naver-site-verification" content="1651e4200fe4313c8cf0f5fd4a870677fccdf5be" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="SafeD" />
    <meta property="og:locale" content="ko_KR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "세이프디 주식회사",
      "alternateName": "SafeD",
      "url": siteUrl,
      "logo": `${siteUrl}/images/oglogo.jpg`,
      "description": "SafeD - 스마트 안전관리 시스템. 건설현장 안전관리의 새로운 기준을 제시합니다.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "디지털로31길 53 이앤씨드림타워 7차 901호",
        "addressLocality": "구로구",
        "addressRegion": "서울특별시",
        "postalCode": "08379",
        "addressCountry": "KR"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+82-2-6949-0706",
        "contactType": "customer service",
        "email": "safed@solset.co.kr",
        "availableLanguage": "Korean"
      },
      "sameAs": []
    })} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <slot name="head" />
  </head>
  <body>
    <Navigation />

    <main>
      <slot />
    </main>

    <Footer />

    {!hideFixedButtons && <FixedButtons />}
    {!hidePdfButton && <PdfFloatingButton />}

    <!-- Naver Analytics -->
    <script is:inline src="https://wcs.naver.net/wcslog.js"></script>
    <script is:inline>
      if (!window.wcs_add) window.wcs_add = {};
      wcs_add["wa"] = "s_f9ed5407f8b";
      if (window.wcs) {
        wcs.inflow();
        wcs_do();
      }
    </script>

    <!-- Scroll Reveal Observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
