---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '채용안내', url: '/recruitment-guide' },
  { name: '채용정보', url: '/recruitment-info' },
];

const jobs = [
  {
    title: '2024 SafeD 채용공고',
    description: '2024 SafeD 채용공고 관련 안내드립니다.',
    date: '2024.12.01',
    status: '진행중',
  },
];
---

<SubPageLayout
  title="채용정보 - SafeD | 스마트안전관리시스템"
  pageTitle="채용정보"
  pageTitleEn="Job Openings"
  description="SafeD 채용정보 - 스마트안전관리시스템 채용 공고"
  navLinks={navLinks}
>
  <section class="py-20">
    <div class="w-container max-w-4xl">
      <div class="mb-12 pb-6 border-b border-[#E0E0E0] reveal">
        <p class="text-[#2563EB] eng font-semibold text-sm tracking-widest uppercase mb-4">Career Opportunities</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold tracking-tight leading-tight mb-3 text-[#111]">
          기술로 <span class="text-[#2563EB]">생명을 지키는</span> 일,<br />지금 시작하세요.
        </h2>
        <p class="text-[#6B6B6B] leading-relaxed">SafeD와 함께할 인재를 찾고 있습니다.</p>
      </div>

      <div class="reveal delay-100">
        {jobs.length > 0 ? (
          <div class="divide-y divide-[#E0E0E0]">
            {jobs.map((item, i) => (
              <div class="flex items-center gap-6 py-6">
                <span class="eng text-[#2563EB] font-bold text-lg flex-shrink-0 w-12 text-center">{String(i + 1).padStart(2, '0')}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    {item.status && (
                      <span class="text-xs text-white bg-[#2563EB] px-2 py-0.5">{item.status}</span>
                    )}
                    <h3 class="font-semibold text-[#111] truncate">{item.title}</h3>
                  </div>
                  <p class="text-sm text-[#6B6B6B] truncate">{item.description}</p>
                </div>
                <span class="text-sm text-[#6B6B6B] eng flex-shrink-0 hidden sm:block">{item.date}</span>
              </div>
            ))}
          </div>
        ) : (
          <div class="py-20 text-center text-[#6B6B6B]">
            <p>현재 진행 중인 채용 공고가 없습니다.</p>
          </div>
        )}
      </div>

      <div class="mt-16 border border-[#E0E0E0] p-8 text-center reveal delay-200">
        <p class="text-[#3A3A3A] mb-2">채용에 관한 문의사항이 있으시면</p>
        <p class="text-[#6B6B6B] text-sm mb-4">이메일: <a href="mailto:sales@safed.co.kr" class="text-[#2563EB] hover:underline">sales@safed.co.kr</a></p>
        <a href="/recruitment-guide" class="text-[#2563EB] text-sm font-semibold hover:underline">채용안내 보기 →</a>
      </div>
    </div>
  </section>
</SubPageLayout>
