<script>
  (function() {
    const section = document.getElementById('cinematic-journey');
    if (!section) return;
    const navWrap = document.querySelector('.nav-wrap');
    const hNav = document.querySelector('.h-nav');

    // DOM refs
    const panels = section.querySelectorAll<HTMLElement>('.hj-panel');
    const dots = section.querySelectorAll<HTMLElement>('.hj-timeline-dot');
    const timelineFill = section.querySelector<HTMLElement>('.hj-timeline-fill');
    const bgWarm = section.querySelector<HTMLElement>('.hj-bg-warm');
    const bgCool = section.querySelector<HTMLElement>('.hj-bg-cool');
    const heroWrap = section.querySelector<HTMLElement>('.wc-hero-wrap');

    // SVG elements
    const outlines = section.querySelectorAll<SVGElement>('.hj-helmet-outline');
    const solidDome = section.querySelector<SVGElement>('.hj-helmet-solid-dome');
    const solidBrim = section.querySelector<SVGElement>('.hj-helmet-solid-brim');
    const helmetText = section.querySelector<SVGElement>('.hj-helmet-text');
    const particles = section.querySelectorAll<SVGElement>('.hj-particle');
    const spotlight = section.querySelector<SVGElement>('.hj-spotlight-beam');
    const certShield = section.querySelector<SVGElement>('.hj-cert-shield');
    const stamps = section.querySelectorAll<SVGElement>('.hj-stamp');
    const sparkles = section.querySelectorAll<SVGElement>('.hj-sparkle');
    const rings = section.querySelectorAll<SVGElement>('.hj-ring');
    const minisGroup = section.querySelector<SVGGElement>('.hj-minis');
    const counter = section.querySelector<SVGElement>('.hj-counter');
    const globe = section.querySelector<SVGElement>('.hj-globe');
    const pins = section.querySelectorAll<SVGElement>('.hj-pin');
    const langWrap = section.querySelector<SVGElement>('.hj-lang-wrap');
    const langText = section.querySelector<SVGElement>('.hj-lang-text');

    const total = 4;

    // Reduced motion: show final state
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      panels.forEach(p => p.classList.add('active'));
      dots.forEach(d => d.classList.add('passed'));
      if (timelineFill) timelineFill.style.height = '100%';
      return;
    }

    // Generate mini helmets
    const MINI_COUNT = 36;
    const MINI_COLS = 6;
    const miniEls: SVGElement[] = [];
    if (minisGroup) {
      for (let i = 0; i < MINI_COUNT; i++) {
        const row = Math.floor(i / MINI_COLS);
        const col = i % MINI_COLS;
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.classList.add('hj-mini');
        g.setAttribute('data-row', String(row));
        g.setAttribute('data-col', String(col));
        g.setAttribute('opacity', '0');
        // Mini helmet path (scaled down)
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', 'M-8 4 Q-8 -6,0 -8 Q8 -6,8 4 L9 5 Q9 7,8 7 L-8 7 Q-9 7,-9 5 Z');
        path.setAttribute('fill', '#3b82f6');
        g.appendChild(path);
        minisGroup.appendChild(g);
        miniEls.push(g);
      }
    }

    // Helpers
    function clamp(v: number, lo: number, hi: number) { return Math.max(lo, Math.min(hi, v)); }
    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
    function subProgress(t: number, start: number, end: number) {
      return clamp((t - start) / (end - start), 0, 1);
    }
    function lerpColor(c1: number[], c2: number[], t: number): string {
      return `rgb(${Math.round(lerp(c1[0], c2[0], t))},${Math.round(lerp(c1[1], c2[1], t))},${Math.round(lerp(c1[2], c2[2], t))})`;
    }

    const BLUE = [59, 130, 246];
    const GOLD = [232, 166, 58];

    // Particle config: start positions & target positions (around helmet)
    const particleData = Array.from(particles).map((p, i) => {
      const startX = parseFloat(p.getAttribute('x') || '250');
      const startY = parseFloat(p.getAttribute('y') || '-30');
      const angle = (i / 12) * Math.PI * 2;
      const targetX = 250 + Math.cos(angle) * 80;
      const targetY = 200 + Math.sin(angle) * 60;
      return { el: p, startX, startY, targetX, targetY };
    });

    // ============ Phase Renderers ============

    function renderPhase0(t: number) {
      // Wireframe stroke-dashoffset
      const strokeT = subProgress(t, 0, 0.6);
      outlines.forEach(el => {
        const total = parseFloat(el.getAttribute('stroke-dasharray') || '900');
        el.setAttribute('stroke-dashoffset', String(total * (1 - strokeT)));
        el.setAttribute('opacity', t > 0 ? '1' : '0');
      });

      // Data particles: fall & absorb
      particleData.forEach((pd, i) => {
        const delay = i * 0.06;
        const pt = subProgress(t, 0.1 + delay, 0.7 + delay);
        if (pt <= 0) {
          pd.el.setAttribute('opacity', '0');
          return;
        }
        const fallT = Math.min(pt * 1.5, 1);
        const absorbT = subProgress(pt, 0.5, 1);
        const x = lerp(pd.startX, pd.targetX, fallT);
        const y = lerp(pd.startY, pd.targetY, fallT);
        pd.el.setAttribute('x', String(x));
        pd.el.setAttribute('y', String(y));
        pd.el.setAttribute('opacity', String(absorbT < 1 ? Math.min(fallT * 2, 1 - absorbT) : 0));
      });

      // Solid fill transition
      const fillT = subProgress(t, 0.6, 1);
      if (solidDome) {
        solidDome.setAttribute('fill-opacity', String(fillT));
        solidDome.setAttribute('fill', '#3b82f6');
      }
      if (solidBrim) {
        solidBrim.setAttribute('fill-opacity', String(fillT));
        solidBrim.setAttribute('fill', '#3b82f6');
      }

      // SAFED text
      const textT = subProgress(t, 0.8, 1);
      if (helmetText) helmetText.setAttribute('fill-opacity', String(textT));
    }

    function renderPhase1(t: number) {
      // Hide particles from Phase 0
      if (t > 0) {
        particleData.forEach(pd => pd.el.setAttribute('opacity', '0'));
      }

      // Spotlight beam
      if (spotlight) {
        const beamT = subProgress(t, 0, 0.3);
        spotlight.setAttribute('opacity', String(beamT * 0.7));
      }

      // Color transition: blue → gold
      const colorT = subProgress(t, 0.2, 0.8);
      const col = lerpColor(BLUE, GOLD, colorT);
      if (solidDome) solidDome.setAttribute('fill', col);
      if (solidBrim) solidBrim.setAttribute('fill', col);

      // Cert shield
      if (certShield) {
        const shieldT = subProgress(t, 0.4, 0.6);
        certShield.setAttribute('opacity', String(shieldT));
        certShield.setAttribute('transform', `translate(250, 200) scale(${shieldT})`);
      }

      // Stamps
      stamps.forEach((s, i) => {
        const sT = subProgress(t, 0.55 + i * 0.1, 0.75 + i * 0.1);
        s.setAttribute('opacity', String(sT));
        const rot = lerp(15, 0, sT);
        const baseX = i === 0 ? 160 : 340;
        s.setAttribute('transform', `translate(${baseX}, 340) rotate(${rot}) scale(${sT})`);
      });

      // Sparkles: toggle animating class
      const sparkleT = subProgress(t, 0.5, 1);
      sparkles.forEach((s, i) => {
        if (sparkleT > 0 && t < 1) {
          s.setAttribute('opacity', '0.6');
          s.classList.add('animating');
          (s as SVGElement).style.animationDelay = `${i * 0.2}s`;
        } else {
          s.setAttribute('opacity', '0');
          s.classList.remove('animating');
        }
      });
    }

    function renderPhase2(t: number) {
      // Hide particles & Phase 1 elements only when this phase is active
      if (t > 0) {
        particleData.forEach(pd => pd.el.setAttribute('opacity', '0'));
        sparkles.forEach(s => { s.setAttribute('opacity', '0'); s.classList.remove('animating'); });
      }

      // Fade out Phase 1 elements
      const fadeOut1 = 1 - subProgress(t, 0, 0.3);
      if (t > 0 && spotlight) spotlight.setAttribute('opacity', String(fadeOut1 * 0.7));
      if (t > 0 && certShield) certShield.setAttribute('opacity', String(fadeOut1));
      if (t > 0) stamps.forEach(s => s.setAttribute('opacity', String(fadeOut1)));

      // Fade out solid helmet
      if (t > 0) {
        const hideSolidT = subProgress(t, 0, 0.3);
        if (solidDome) { solidDome.setAttribute('fill', '#3b82f6'); solidDome.setAttribute('fill-opacity', String(1 - hideSolidT)); }
        if (solidBrim) { solidBrim.setAttribute('fill', '#3b82f6'); solidBrim.setAttribute('fill-opacity', String(1 - hideSolidT)); }
        if (helmetText) helmetText.setAttribute('fill-opacity', String(1 - hideSolidT));
        // Also hide wireframe outline from Phase 0
        outlines.forEach(el => el.setAttribute('opacity', String(1 - hideSolidT)));
      }

      // Pulse rings
      rings.forEach((r, i) => {
        const ringT = subProgress(t, 0, 0.3);
        if (ringT > 0 && t < 0.8) {
          r.classList.add('animating');
          r.setAttribute('opacity', '0.6');
        } else {
          r.classList.remove('animating');
          r.setAttribute('opacity', '0');
        }
      });

      // Mini helmets: center → grid
      const miniT = subProgress(t, 0.2, 0.8);
      const gridSpacing = 45;
      const gridStartX = 250 - (MINI_COLS - 1) * gridSpacing / 2;
      const gridStartY = 120;
      miniEls.forEach((m, i) => {
        const row = Math.floor(i / MINI_COLS);
        const col = i % MINI_COLS;
        const targetX = gridStartX + col * gridSpacing;
        const targetY = gridStartY + row * gridSpacing;
        const distFromCenter = Math.sqrt(Math.pow(col - 2.5, 2) + Math.pow(row - 2.5, 2));
        const maxDist = Math.sqrt(2.5 * 2.5 + 2.5 * 2.5);
        const delay = distFromCenter / maxDist * 0.4;
        const itemT = subProgress(miniT, delay, delay + 0.6);

        const x = lerp(250, targetX, itemT);
        const y = lerp(250, targetY, itemT);
        m.setAttribute('transform', `translate(${x}, ${y}) scale(${itemT})`);
        m.setAttribute('opacity', String(Math.min(itemT * 2, 1)));
      });

      // Counter: 0 → 99.2
      if (counter) {
        const countT = subProgress(t, 0.5, 0.9);
        const val = (countT * 99.2).toFixed(1);
        const numEl = counter.querySelector('.hj-counter-num');
        const pctEl = counter.querySelector('.hj-counter-pct');
        if (numEl) numEl.textContent = countT > 0 ? val : '';
        if (pctEl) pctEl.textContent = countT > 0 ? '%' : '';
        counter.setAttribute('opacity', String(countT > 0 ? 1 : 0));
      }
    }

    function renderPhase3(t: number) {
      if (t <= 0) {
        // Reset helmet transform back to base position when leaving Phase 3
        const solidParent = solidDome?.parentElement;
        const outlineParent = outlines[0]?.parentElement;
        if (solidParent) solidParent.setAttribute('transform', 'translate(0, 50)');
        if (outlineParent) outlineParent.setAttribute('transform', 'translate(0, 50)');
        return;
      }

      // Hide particles
      particleData.forEach(pd => pd.el.setAttribute('opacity', '0'));

      // === Hide ALL Phase 1 & 2 elements ===
      if (spotlight) spotlight.setAttribute('opacity', '0');
      if (certShield) certShield.setAttribute('opacity', '0');
      stamps.forEach(s => s.setAttribute('opacity', '0'));
      sparkles.forEach(s => { s.setAttribute('opacity', '0'); s.classList.remove('animating'); });
      rings.forEach(r => { r.classList.remove('animating'); r.setAttribute('opacity', '0'); });

      // Mini helmets converge and vanish
      const convergeT = subProgress(t, 0, 0.25);
      if (convergeT < 1) {
        const gridSpacing = 45;
        const gridStartX = 250 - (MINI_COLS - 1) * gridSpacing / 2;
        const gridStartY = 120;
        miniEls.forEach((m, i) => {
          const row = Math.floor(i / MINI_COLS);
          const col = i % MINI_COLS;
          const fromX = gridStartX + col * gridSpacing;
          const fromY = gridStartY + row * gridSpacing;
          const x = lerp(fromX, 250, convergeT);
          const y = lerp(fromY, 200, convergeT);
          m.setAttribute('transform', `translate(${x}, ${y}) scale(${1 - convergeT})`);
          m.setAttribute('opacity', String(1 - convergeT));
        });
      } else {
        miniEls.forEach(m => m.setAttribute('opacity', '0'));
      }
      // Counter fade out
      if (counter) counter.setAttribute('opacity', String(Math.max(0, 1 - convergeT * 3)));

      // === Solid helmet → blue outline only ===
      const outlineT = subProgress(t, 0.15, 0.45);
      // Solid fill fades out
      if (solidDome) {
        solidDome.setAttribute('fill', '#3b82f6');
        solidDome.setAttribute('fill-opacity', String(1 - outlineT));
      }
      if (solidBrim) {
        solidBrim.setAttribute('fill', '#3b82f6');
        solidBrim.setAttribute('fill-opacity', String(1 - outlineT));
      }
      if (helmetText) helmetText.setAttribute('fill-opacity', String(1 - outlineT));
      // Wireframe outline fades in
      outlines.forEach(el => {
        el.setAttribute('stroke-dashoffset', '0');
        el.setAttribute('opacity', String(outlineT));
        el.setAttribute('stroke', '#3b82f6');
        el.setAttribute('stroke-width', '1.5');
      });

      // Float helmet up (move both solid + outline groups) — base offset is 50
      const floatT = subProgress(t, 0.2, 0.5);
      const helmY = lerp(50, -10, floatT);
      const solidParent = solidDome?.parentElement;
      const outlineParent = outlines[0]?.parentElement;
      if (solidParent) solidParent.setAttribute('transform', `translate(0, ${helmY})`);
      if (outlineParent) outlineParent.setAttribute('transform', `translate(0, ${helmY})`);

      // === Globe appear ===
      if (globe) {
        const globeT = subProgress(t, 0.3, 0.7);
        globe.setAttribute('opacity', String(globeT));
        globe.setAttribute('transform', `translate(250, 280) scale(${lerp(0.5, 1, globeT)})`);
      }

      // Pin points
      pins.forEach((pin, i) => {
        const pinT = subProgress(t, 0.5 + i * 0.06, 0.65 + i * 0.06);
        pin.setAttribute('opacity', String(pinT));
        if (pinT >= 1) pin.classList.add('animating');
        else pin.classList.remove('animating');
      });

      // Multilingual marquee
      if (langWrap && langText) {
        const langT = subProgress(t, 0.4, 1);
        langWrap.setAttribute('opacity', String(langT > 0 ? langT : 0));
        if (langT > 0) langText.classList.add('animating');
        else langText.classList.remove('animating');
      }
    }

    // ============ Main scroll controller ============
    let ticking = false;
    let prevActive = -1;

    // Reset all SVG to initial state on load
    function resetAll() {
      outlines.forEach(el => { el.setAttribute('stroke-dashoffset', el.getAttribute('stroke-dasharray') || '900'); el.setAttribute('opacity', '0'); });
      if (solidDome) { solidDome.setAttribute('fill-opacity', '0'); solidDome.setAttribute('fill', '#3b82f6'); }
      if (solidBrim) { solidBrim.setAttribute('fill-opacity', '0'); solidBrim.setAttribute('fill', '#3b82f6'); }
      if (helmetText) helmetText.setAttribute('fill-opacity', '0');
      particleData.forEach(pd => pd.el.setAttribute('opacity', '0'));
      if (spotlight) spotlight.setAttribute('opacity', '0');
      if (certShield) certShield.setAttribute('opacity', '0');
      stamps.forEach(s => s.setAttribute('opacity', '0'));
      sparkles.forEach(s => { s.setAttribute('opacity', '0'); s.classList.remove('animating'); });
      rings.forEach(r => { r.setAttribute('opacity', '0'); r.classList.remove('animating'); });
      miniEls.forEach(m => m.setAttribute('opacity', '0'));
      if (counter) counter.setAttribute('opacity', '0');
      if (globe) globe.setAttribute('opacity', '0');
      pins.forEach(p => { p.setAttribute('opacity', '0'); p.classList.remove('animating'); });
      if (langWrap) langWrap.setAttribute('opacity', '0');
      // Reset transforms
      const solidParent = solidDome?.parentElement;
      const outlineParent = outlines[0]?.parentElement;
      if (solidParent) solidParent.setAttribute('transform', 'translate(0, 50)');
      if (outlineParent) outlineParent.setAttribute('transform', 'translate(0, 50)');
      // Reset hero
      if (heroWrap) { heroWrap.style.opacity = '1'; heroWrap.style.visibility = 'visible'; }
    }
    resetAll();

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    function update() {
      ticking = false;

      const vh = window.innerHeight;
      const rect = section!.getBoundingClientRect();
      const scrollable = rect.height - vh;
      if (scrollable <= 0) return;

      const progress = clamp(-rect.top / scrollable, 0, 1);

      // Hero fade-out: fade during first ~8% of scroll (roughly 1 viewport of 400vh)
      if (heroWrap) {
        const heroFade = clamp(progress / 0.08, 0, 1);
        heroWrap.style.opacity = String(1 - heroFade);
        heroWrap.style.pointerEvents = heroFade >= 1 ? 'none' : 'none';
        if (heroFade >= 1) heroWrap.style.visibility = 'hidden';
        else heroWrap.style.visibility = 'visible';
      }

      // Toggle dark header + sub-nav when section is in viewport
      const sectionInView = rect.top < vh && rect.bottom > 0;
      // Show scroll animation UI after hero starts fading (progress > 3%)
      if (progress > 0.03) section!.classList.add('entered');
      else section!.classList.remove('entered');
      if (navWrap) {
        if (sectionInView) navWrap.classList.add('nav-dark');
        else navWrap.classList.remove('nav-dark');
      }
      if (hNav) {
        if (sectionInView) hNav.classList.add('h-nav-dark');
        else hNav.classList.remove('h-nav-dark');
      }

      // If section hasn't entered viewport yet, keep reset
      if (rect.top >= vh) {
        if (prevActive !== -1) {
          prevActive = -1;
          resetAll();
          panels.forEach(p => p.classList.remove('active'));
          dots.forEach(d => { d.classList.remove('active'); d.classList.remove('passed'); });
          if (timelineFill) timelineFill.style.height = '0%';
        }
        return;
      }

      // Remap: 0-0.1 = hero, 0.1-1.0 = 4 phases
      const journeyProgress = clamp((progress - 0.1) / 0.9, 0, 1);
      const activeIndex = Math.min(3, Math.floor(journeyProgress * 4));
      const phaseProgress = (journeyProgress * 4) - activeIndex;

      // Panel & timeline updates (on phase change only)
      if (activeIndex !== prevActive) {
        prevActive = activeIndex;
        panels.forEach((p, i) => p.classList.toggle('active', i === activeIndex));
        dots.forEach((d, i) => {
          d.classList.toggle('active', i === activeIndex);
          d.classList.toggle('passed', i < activeIndex);
        });
      }

      // Timeline fill
      if (timelineFill) timelineFill.style.height = `${journeyProgress * 100}%`;

      // Background gradient
      if (bgWarm) bgWarm.style.opacity = String(1 - journeyProgress);
      if (bgCool) bgCool.style.opacity = String(journeyProgress);

      // Render all phases (completed phases get t=1, future get t=0)
      renderPhase0(activeIndex === 0 ? phaseProgress : (activeIndex > 0 ? 1 : 0));
      renderPhase1(activeIndex === 1 ? phaseProgress : (activeIndex > 1 ? 1 : 0));
      renderPhase2(activeIndex === 2 ? phaseProgress : (activeIndex > 2 ? 1 : 0));
      renderPhase3(activeIndex === 3 ? phaseProgress : 0);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  })();
</script>
