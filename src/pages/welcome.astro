---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '회사개요', url: '/company-overview' },
  { name: '인사말', url: '/welcome' },
  { name: '비전 및 미션', url: '/vision-mission' },
  { name: '오시는 길', url: '/location' },
];

const milestones = [
  {
    year: '2020', title: '세이프디 설립',
    desc: '건설현장 스마트 안전관리의 새로운 장을 열다. 300여개 공종, 50,000개 위험요인·안전대책 데이터베이스 구축 착수.',
    stats: [{ num: '300+', label: '공종 DB' }, { num: '50,000+', label: '위험요인 DB' }],
    icon: 'star', color: '#E8A63A',
  },
  {
    year: '2021', title: '기술력 인정',
    desc: '국토교통부 스마트건설대상 안전부문 수상. IoT·AI 기반 핵심 기술 특허 2건 확보.',
    stats: [{ num: '대상', label: '스마트건설대상' }, { num: '2건', label: '기술 특허' }],
    icon: 'shield', color: '#E8A63A',
  },
  {
    year: '2022–23', title: '시장을 선도하다',
    desc: '중대재해처벌법 완벽 대응 시스템 출시. 주요 건설사 대규모 도입으로 100+ 현장 달성.',
    stats: [{ num: '100+', label: '도입 현장' }, { num: '99.2%', label: '사고 예방률' }],
    icon: 'counter', color: '#3b82f6',
  },
  {
    year: '2024–25', title: '글로벌 안전 플랫폼',
    desc: 'Google AI 기반 19개국어 자동번역 도입. 150+ 현장 운영, 국내 유일 올인원 스마트안전관리 플랫폼.',
    stats: [{ num: '150+', label: '현장 운영' }, { num: '19개국어', label: 'AI 번역' }],
    icon: 'globe', color: '#3b82f6',
  },
];
---

<SubPageLayout
  title="인사말 - SafeD | 스마트안전관리시스템"
  pageTitle="인사말"
  pageTitleEn="Welcome"
  description="SafeD 스마트 안전관리 시스템 - 산업안전의 미래를 설계합니다."
  navLinks={navLinks}
>
  <!-- Hero Statement + Cinematic Journey — seamless dark block -->
  <section id="cinematic-journey" class="hj-section">
    <!-- Hero overlay (sticky first screen) -->
    <div class="wc-hero-wrap">
      <div class="wc-hero-content">
        <p class="wc-hero-label eng">CEO Message</p>
        <h1 class="wc-hero-title">
          현장의 <span class="wc-hero-accent">안전</span>이 곧<br />기업의 <span class="wc-hero-accent">미래</span>입니다.
        </h1>
        <div class="wc-hero-divider"></div>
        <blockquote class="wc-hero-quote">
          "한 사람의 생명을 지키는 것, 그것이 SafeD가 존재하는 이유입니다."
        </blockquote>
      </div>
    </div>
    <div class="hj-bg hj-bg-warm" aria-hidden="true"></div>
    <div class="hj-bg hj-bg-cool" aria-hidden="true"></div>

    <!-- Sticky viewport panel -->
    <div class="hj-sticky">
      <div class="hj-inner">
        <!-- Header -->
        <div class="hj-header">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-2">Milestones</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-white">SafeD의 여정</h2>
        </div>

        <!-- Main: animation left + content right -->
        <div class="hj-main">
          <!-- Left: Cinematic Animation Area -->
          <div class="hj-anim-area">
            <svg class="hj-svg" viewBox="0 0 500 500" aria-label="SafeD 안전모 진화 애니메이션">
              <defs>
                <linearGradient id="hj-spotlight-grad" x1="0.5" y1="0" x2="0.5" y2="1">
                  <stop offset="0%" stop-color="#fff" stop-opacity="0.5" />
                  <stop offset="100%" stop-color="#fff" stop-opacity="0" />
                </linearGradient>
                <clipPath id="hj-helmet-clip">
                  <path d="M120 260 Q120 120,250 100 Q380 120,380 260 L395 275 Q395 295,380 295 L120 295 Q105 295,105 275 Z" />
                </clipPath>
              </defs>

              <!-- Phase 0: Wireframe outline (stroke-dashoffset animated) -->
              <g class="hj-phase-0" transform="translate(0, 50)">
                <path class="hj-helmet-outline" d="M120 260 Q120 120,250 100 Q380 120,380 260 L395 275 Q395 295,380 295 L120 295 Q105 295,105 275 Z" fill="none" stroke="#3b82f6" stroke-width="2" stroke-dasharray="900" stroke-dashoffset="900" />
                <rect class="hj-helmet-outline" x="105" y="280" width="290" height="15" rx="7" fill="none" stroke="#3b82f6" stroke-width="2" stroke-dasharray="620" stroke-dashoffset="620" />
              </g>

              <!-- Shared: Solid helmet (fill-opacity controlled by JS) -->
              <g class="hj-helmet-solid" transform="translate(0, 50)">
                <path class="hj-helmet-solid-dome" d="M120 260 Q120 120,250 100 Q380 120,380 260 L395 275 Q395 295,380 295 L120 295 Q105 295,105 275 Z" fill="#3b82f6" fill-opacity="0" />
                <rect class="hj-helmet-solid-brim" x="105" y="280" width="290" height="15" rx="7" fill="#3b82f6" fill-opacity="0" />
                <text class="hj-helmet-text" x="250" y="220" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="800" fill="#fff" fill-opacity="0" letter-spacing="4">SAFED</text>
              </g>

              <!-- Phase 0: Data particles -->
              <g class="hj-particles">
                <text class="hj-particle" data-idx="0" x="140" y="-20" font-size="16" fill="#60a5fa" opacity="0">위험요인</text>
                <text class="hj-particle" data-idx="1" x="220" y="-40" font-size="16" fill="#60a5fa" opacity="0">공종</text>
                <text class="hj-particle" data-idx="2" x="300" y="-10" font-size="16" fill="#60a5fa" opacity="0">DB</text>
                <text class="hj-particle" data-idx="3" x="170" y="-50" font-size="16" fill="#60a5fa" opacity="0">IoT</text>
                <text class="hj-particle" data-idx="4" x="350" y="-30" font-size="16" fill="#60a5fa" opacity="0">AI</text>
                <text class="hj-particle" data-idx="5" x="120" y="-60" font-size="14" fill="#60a5fa" opacity="0">GPS</text>
                <text class="hj-particle" data-idx="6" x="280" y="-45" font-size="14" fill="#60a5fa" opacity="0">센서</text>
                <text class="hj-particle" data-idx="7" x="200" y="-55" font-size="14" fill="#60a5fa" opacity="0">안전대책</text>
                <text class="hj-particle" data-idx="8" x="330" y="-35" font-size="14" fill="#60a5fa" opacity="0">모니터링</text>
                <text class="hj-particle" data-idx="9" x="160" y="-15" font-size="16" fill="#60a5fa" opacity="0">비콘</text>
                <text class="hj-particle" data-idx="10" x="370" y="-50" font-size="16" fill="#60a5fa" opacity="0">분석</text>
                <text class="hj-particle" data-idx="11" x="250" y="-60" font-size="12" fill="#60a5fa" opacity="0">예방</text>
              </g>

              <!-- Phase 1: Spotlight beam -->
              <polygon class="hj-spotlight-beam" points="200,0 300,0 370,300 130,300" fill="url(#hj-spotlight-grad)" opacity="0" />

              <!-- Phase 1: Patent stamps -->
              <g class="hj-stamp hj-stamp-1" transform="translate(160, 340)" opacity="0">
                <rect x="-32" y="14" width="65" height="24" rx="4" fill="none" stroke="#E8A63A" stroke-width="1.5" />
                <text x="0" y="30" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="#E8A63A">특허 제1호</text>
              </g>
              <g class="hj-stamp hj-stamp-2" transform="translate(340, 340)" opacity="0">
                <rect x="-32" y="14" width="65" height="24" rx="4" fill="none" stroke="#E8A63A" stroke-width="1.5" />
                <text x="0" y="30" text-anchor="middle" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="#E8A63A">특허 제2호</text>
              </g>

              <!-- Phase 1: Sparkles -->
              <circle class="hj-sparkle" data-idx="0" cx="100" cy="150" r="2" fill="#E8A63A" opacity="0" />
              <circle class="hj-sparkle" data-idx="1" cx="400" cy="130" r="2.5" fill="#E8A63A" opacity="0" />
              <circle class="hj-sparkle" data-idx="2" cx="130" cy="300" r="1.5" fill="#E8A63A" opacity="0" />
              <circle class="hj-sparkle" data-idx="3" cx="370" cy="280" r="2" fill="#E8A63A" opacity="0" />
              <circle class="hj-sparkle" data-idx="4" cx="180" cy="100" r="1.5" fill="#fff" opacity="0" />
              <circle class="hj-sparkle" data-idx="5" cx="320" cy="90" r="2" fill="#fff" opacity="0" />
              <circle class="hj-sparkle" data-idx="6" cx="90" cy="230" r="1.5" fill="#E8A63A" opacity="0" />
              <circle class="hj-sparkle" data-idx="7" cx="410" cy="220" r="2" fill="#E8A63A" opacity="0" />

              <!-- Phase 2: Pulse rings -->
              <circle class="hj-ring hj-ring-1" cx="250" cy="210" r="30" fill="none" stroke="#3b82f6" stroke-width="2" opacity="0" />
              <circle class="hj-ring hj-ring-2" cx="250" cy="210" r="30" fill="none" stroke="#3b82f6" stroke-width="2" opacity="0" />

              <!-- Phase 2: Mini helmets (36 = 6x6 grid) -->
              <g class="hj-minis">
                <!-- Generated by JS: 36 small helmet icons -->
              </g>

              <!-- Phase 2: Counter text -->
              <text class="hj-counter" x="250" y="400" text-anchor="middle" opacity="0">
                <tspan class="hj-counter-num" font-family="'DM Sans', sans-serif" font-size="42" font-weight="800" fill="#3b82f6">0</tspan><tspan class="hj-counter-pct" font-family="'DM Sans', sans-serif" font-size="20" font-weight="600" fill="#3b82f6" dx="2">%</tspan>
              </text>

              <!-- Phase 3: Globe -->
              <g class="hj-globe" transform="translate(250, 250)" opacity="0">
                <circle r="100" fill="none" stroke="#3b82f6" stroke-width="1" opacity="0.4" />
                <ellipse rx="100" ry="35" fill="none" stroke="#3b82f6" stroke-width="0.5" opacity="0.3" />
                <ellipse rx="35" ry="100" fill="none" stroke="#3b82f6" stroke-width="0.5" opacity="0.3" />
                <ellipse rx="70" ry="100" fill="none" stroke="#3b82f6" stroke-width="0.5" opacity="0.2" />
                <circle r="102" fill="none" stroke="#60a5fa" stroke-width="0.3" opacity="0.2" />
              </g>

              <!-- Phase 3: Pin points (7 continents) -->
              <g class="hj-pins">
                <g class="hj-pin" data-idx="0" opacity="0"><circle cx="200" cy="180" r="3" fill="#ef4444" /><circle cx="200" cy="180" r="5" fill="#ef4444" opacity="0.3" /></g>
                <g class="hj-pin" data-idx="1" opacity="0"><circle cx="280" cy="170" r="3" fill="#ef4444" /><circle cx="280" cy="170" r="5" fill="#ef4444" opacity="0.3" /></g>
                <g class="hj-pin" data-idx="2" opacity="0"><circle cx="310" cy="210" r="3" fill="#ef4444" /><circle cx="310" cy="210" r="5" fill="#ef4444" opacity="0.3" /></g>
                <g class="hj-pin" data-idx="3" opacity="0"><circle cx="230" cy="260" r="3" fill="#ef4444" /><circle cx="230" cy="260" r="5" fill="#ef4444" opacity="0.3" /></g>
                <g class="hj-pin" data-idx="4" opacity="0"><circle cx="170" cy="230" r="3" fill="#ef4444" /><circle cx="170" cy="230" r="5" fill="#ef4444" opacity="0.3" /></g>
                <g class="hj-pin" data-idx="5" opacity="0"><circle cx="340" cy="250" r="3" fill="#ef4444" /><circle cx="340" cy="250" r="5" fill="#ef4444" opacity="0.3" /></g>
                <g class="hj-pin" data-idx="6" opacity="0"><circle cx="250" cy="200" r="3" fill="#f59e0b" /><circle cx="250" cy="200" r="5" fill="#f59e0b" opacity="0.3" /></g>
              </g>

              <!-- Phase 3: Multilingual marquee -->
              <g class="hj-lang-wrap" clip-path="url(#hj-helmet-clip)" opacity="0">
                <text class="hj-lang-text" y="430" font-family="Arial, sans-serif" font-size="14" fill="rgba(255,255,255,0.6)">
                  <tspan>安全 &nbsp; Safety &nbsp; Sécurité &nbsp; 안전 &nbsp; Sicherheit &nbsp; 安全 &nbsp; Seguridad &nbsp; 安全 &nbsp; Safety &nbsp; Sécurité &nbsp; 안전 &nbsp; Sicherheit</tspan>
                </text>
              </g>
            </svg>
          </div>

          <!-- Right: Detail Panels -->
          <div class="hj-panels">
            {milestones.map((m, i) => (
              <div class={`hj-panel ${i === 0 ? 'active' : ''}`} data-panel={i}>
                <div class="hj-panel-icon" style={`color: ${m.color}; border-color: ${m.color}25;`}>
                  {m.icon === 'star' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  )}
                  {m.icon === 'shield' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  )}
                  {m.icon === 'counter' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 20V10M12 20V4M6 20v-6"/>
                    </svg>
                  )}
                  {m.icon === 'globe' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                  )}
                </div>
                <span class="hj-panel-year eng" style={`color: ${m.color}`}>{m.year}</span>
                <h3 class="hj-panel-title">{m.title}</h3>
                <p class="hj-panel-desc">{m.desc}</p>
                <div class="hj-panel-stats">
                  {m.stats.map((s) => (
                    <div class="hj-stat-card">
                      <span class="hj-stat-num eng">{s.num}</span>
                      <span class="hj-stat-label">{s.label}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Bottom: Horizontal Timeline -->
        <div class="hj-timeline">
          <div class="hj-timeline-track">
            <div class="hj-timeline-fill"></div>
          </div>
          {milestones.map((m, i) => (
            <div class={`hj-timeline-dot ${i === 0 ? 'active' : ''}`} data-dot={i} style={`--dot-color: ${m.color}`}>
              <div class="hj-dot-pip"></div>
              <span class="hj-dot-label eng">{m.year}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Greeting + CEO Image Row -->
  <section class="py-12 lg:py-16 bg-[#F5F5F5]">
    <div class="w-container max-w-5xl">
      <div class="flex flex-col lg:flex-row gap-8 items-stretch">
        <!-- Left: Greeting Text -->
        <div class="flex-1 bg-white border border-[#E0E0E0] p-5 lg:p-8 reveal">
          <div class="space-y-3 text-[#3A3A3A] text-[15px] leading-[1.75]">
            <p class="text-lg">안녕하세요, <strong class="text-[#111]">SafeD</strong>를 찾아주셔서 감사합니다.</p>

            <p>
              저희 SafeD는 건설현장과 산업 환경에서의 <strong class="text-[#111]">스마트 안전관리</strong>를 전문으로 하는 기업으로서,
              현장 근로자 한 분 한 분의 안전과 건강을 최우선으로 생각합니다.
              300여개 공종, 50,000개 위험요인·안전대책 데이터베이스와 최신 IoT·AI 기술을 바탕으로
              각종 재해 예방, 안전 시스템 구축, 위험 관리에 있어 최적의 솔루션을 제공하고 있습니다.
            </p>

            <p>
              특히, SafeD는 현장의 실질적인 안전 문제를 해결하기 위해
              <strong class="text-[#111]">GPS 기반 실시간 모니터링, 비콘(Beacon) 위험경고, Google AI 다국어 자동번역</strong> 등
              혁신적인 기술을 접목한 맞춤형 솔루션을 개발하고 있습니다.
            </p>

            <p>
              2022년 1월 <strong class="text-[#111]">중대재해처벌법</strong> 본격 시행 이후,
              SafeD는 안전보건관리체계 구축부터 의무이행 근거자료 자동생성까지,
              법적 의무사항을 시스템으로 완벽히 대응하여 경영책임자의 리스크를 관리합니다.
            </p>

            <p>
              앞으로도 SafeD는 고객님의 신뢰를 바탕으로 더욱 안전하고 건강한 미래를 만들어가기 위해
              최선을 다하겠습니다. 언제나 현장의 목소리에 귀 기울이며,
              안전 관리의 든든한 파트너가 되겠습니다.
            </p>

            <p class="text-[#6B6B6B] text-sm">감사합니다.</p>
          </div>

          <!-- Signature -->
          <div class="mt-5 pt-5 border-t border-[#E0E0E0] flex items-center justify-between flex-wrap gap-3">
            <div>
              <p class="text-[#6B6B6B] text-xs mb-0.5">세이프디 주식회사</p>
              <p class="text-lg font-bold tracking-tight text-[#111]">대표이사</p>
            </div>
            <img src="/images/sign_logo_new.gif" alt="대표 서명" class="h-10 object-contain" loading="lazy" />
          </div>
        </div>

        <!-- Right: CEO Image -->
        <div class="w-full lg:w-72 flex-shrink-0 reveal-right delay-200">
          <div class="relative h-full">
            <img src="/images/welcome.png" alt="SafeD CEO" class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute bottom-4 left-4 bg-[#2563EB] text-white px-4 py-2">
              <p class="eng font-bold text-xs">Since 2020</p>
              <p class="text-[10px] opacity-80">스마트안전관리 전문기업</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Commitments -->
  <section class="py-14 bg-white">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-10">
        <p class="text-[#2563EB] eng font-semibold text-sm tracking-widest uppercase mb-3 reveal">Our Commitment</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111] reveal delay-100">SafeD가 약속하는 3가지 가치</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0]">
        {[
          {
            iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
            title: '생명 최우선',
            desc: '모든 의사결정의 중심에 현장 근로자의 생명과 안전을 둡니다. 기술은 수단이고, 목적은 사람입니다.',
            num: '99.2%',
            numLabel: '사고 예방률',
          },
          {
            iconPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
            title: '기술 혁신',
            desc: 'IoT, AI, 빅데이터를 활용하여 서류 중심의 안전관리를 데이터 기반 스마트 관리로 전환합니다.',
            num: '19개국어',
            numLabel: 'AI 자동번역',
          },
          {
