---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '블로그', url: '/blog' },
  { name: '상담문의', url: '/inquiries' },
  { name: 'FAQ', url: '/faq' },
];

const releases = [
  {
    title: '건설현장 안전 지킴이 \'세이프디(SafeD) 2.0\' 업그레이드',
    description: '비콘(Beacon) 기반 위험지역 안내 기능 탑재…각종 산업 현장 안전관리 효율성 개선',
    link: 'https://www.dnews.co.kr/uhtml/view.jsp?idxno=202105271547123180545',
    source: '대한경제',
  },
  {
    title: '물류센터 산재예방 위해 \'세이프디(SafeD) 2.0\' 출시',
    description: '부동산 인프라 자산 관리 기업 산업 현장 사고예방을 효과적으로 도와주는 위험성 평가 프로세스 관리 솔루션',
    link: 'https://www.wowtv.co.kr/NewsCenter/News/Read?articleId=A202105280082&t=NN',
    source: '한국경제TV',
  },
  {
    title: '중대재해법 시행 앞두고 산업현장 안전관리 솔루션 주목',
    description: '업그레이드된 세이프디 2.0...정교한 감지로 위험 경고 및 자동 알람',
    link: 'https://www.newsclaim.co.kr/news/articleView.html?idxno=1645551',
    source: '뉴스클레임',
  },
  {
    title: '건설현장 안전지킴이 나선 밸류업 플랫폼 세이프디 2.0 선보여',
    description: '통합운영관리(O&M) 플랫폼 기업인 이도(YIDO)는 산업현장 사고 예방을 도와주는 위험성 평가 프로세스 관리 솔루션 개발',
    link: 'http://www.wikileaks-kr.org/news/articleView.html?idxno=108674',
    source: '위키리크스한국',
  },
  {
    title: 'GPS 기반 안전관리 \'세이프디\' 개발',
    description: '통합운영관리(O&M) 플랫폼 기업인 이도(YIDO)는 산업현장 사고 예방을 도와주는 솔루션 개발',
    link: 'https://news.heraldcorp.com/view.php?ud=20210122000473',
    source: '헤럴드경제',
  },
  {
    title: 'O&M 플랫폼 GPS 기반 안전관리 토탈 솔루션 선봬',
    description: '중대재해법이 1년 뒤부터 시행됨에 따라 기업들의 안전관리 책임이 강화된 가운데 GPS를 기반으로',
    link: 'https://www.sentv.co.kr/news/view/587097',
    source: '서울경제TV',
  },
];
---

<SubPageLayout
  title="보도자료 - SafeD | 스마트안전관리시스템"
  pageTitle="보도자료"
  pageTitleEn="Press Releases"
  description="SafeD 보도자료 - 스마트안전관리시스템 언론 보도"
  navLinks={navLinks}
>
  <!-- Hero Statement -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="w-container max-w-4xl text-center">
      <h2 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-[#111] reveal">
        현장의 변화,<br /><span class="text-[#2563EB]">언론이 주목합니다.</span>
      </h2>
      <p class="text-[#6B6B6B] text-lg lg:text-xl mt-8 leading-relaxed max-w-2xl mx-auto reveal delay-100">
        SafeD가 만들어가는 건설 안전의 새로운 기준.<br/>주요 언론이 보도한 SafeD의 성과와 기술 혁신을 확인하세요.
      </p>
    </div>
  </section>

  <!-- Award Highlight -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="w-container max-w-5xl">
      <div class="relative bg-white border border-[#E0E0E0] overflow-hidden reveal">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-0">
          <!-- Left: Award visual -->
          <div class="lg:col-span-2 bg-gradient-to-br from-gray-900 to-gray-800 p-8 lg:p-10 flex flex-col justify-center text-white relative overflow-hidden">
            <div class="relative z-10">
              <div class="w-14 h-14 bg-yellow-400/10 flex items-center justify-center mb-6">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#facc15" stroke-width="1.5">
                  <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
                </svg>
              </div>
              <p class="eng text-yellow-400 font-bold text-xs tracking-widest uppercase mb-3">Award</p>
              <h2 class="text-2xl lg:text-3xl font-extrabold tracking-tight leading-tight mb-4">
                2021 스마트건설대상<br />안전대상 수상
              </h2>
              <p class="text-white/50 text-sm leading-relaxed">
                플랫폼 부문 - 세이프디 주식회사
              </p>
            </div>
          </div>

          <!-- Right: Award details -->
          <div class="lg:col-span-3 p-8 lg:p-10">
            <p class="text-[#3A3A3A] leading-relaxed mb-8">
              세이프디 주식회사는 국내 유일의 스마트안전관리솔루션 개발 회사입니다.
              위험성평가 프로세스관리 솔루션 'SafeD'가 스마트건설대상에서 주목을 받았습니다.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-[1px] bg-[#E0E0E0]">
              {[
                { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z"/></svg>', title: '원클릭 안전관리', desc: '위험성 평가 회의 결과를 원클릭으로 해결. 약 25,000건 표준위험공종 자료화' },
                { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>', title: '비용 절감 효과', desc: '시간과 비용을 절감하는 효율적인 안전관리 솔루션' },
                { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>', title: 'GPS 경고 시스템', desc: '작업 위치·동선 분석으로 위험지역 접근 감지 및 즉시 경고' },
                { icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.4"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.4"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>', title: '비콘 기술 탑재', desc: '지하·터널 사각지대 제거, 복잡한 물류센터도 정교한 감지' },
              ].map((item) => (
                <div class="bg-white p-5">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="flex-shrink-0" set:html={item.icon} />
                    <h4 class="font-bold text-sm text-[#111]">{item.title}</h4>
                  </div>
                  <p class="text-xs text-[#6B6B6B] leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Press Coverage -->
  <section class="py-20">
    <div class="w-container max-w-5xl">
      <div class="flex items-end justify-between mb-10 pb-6 border-b border-[#E0E0E0] reveal">
        <div>
          <p class="text-[#2563EB] eng font-semibold text-sm tracking-widest uppercase mb-3">Media Coverage</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111]">언론 보도</h2>
        </div>
        <div class="hidden sm:flex items-center gap-3">
          <img src="/images/safedlogo.svg" alt="SafeD" class="h-5 opacity-40" style="filter: brightness(0);" />
          <p class="eng text-sm text-[#6B6B6B]">
            <span class="font-bold text-[#111]">{releases.length}</span> articles
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0] reveal delay-100">
        {releases.map((item, i) => (
          <a href={item.link} target="_blank" rel="noopener noreferrer"
             class="group bg-white p-6 hover:bg-[#F5F5F5] transition-colors">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-8 h-8 bg-[#F5F5F5] flex items-center justify-center">
                <span class="eng text-[#2563EB] font-bold text-xs">{String(i + 1).padStart(2, '0')}</span>
              </span>
              <span class="text-xs text-[#2563EB] bg-[#2563EB]/5 px-2.5 py-1 eng font-semibold">{item.source}</span>
              <svg class="w-4 h-4 text-[#E0E0E0] ml-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <h3 class="font-bold text-[#111] mb-2 leading-snug line-clamp-2">{item.title}</h3>
            <p class="text-sm text-[#6B6B6B] line-clamp-2 leading-relaxed">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-20 bg-[#1C1C1E] text-white text-center relative overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.04]" aria-hidden="true">
      <span class="pr-glow-d eng text-[300px] font-extrabold leading-none select-none">D</span>
    </div>
    <div class="w-container relative z-10 reveal">
      <p class="pr-first-step eng text-sm font-bold tracking-[0.3em] uppercase mb-6 text-[#2563EB]">First Step</p>
      <h2 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-4">
        안전관리의 <span class="pr-outline-text">첫걸음</span>,<br />SafeD와 함께
      </h2>
      <p class="text-white/50 mb-8">언론이 주목한 기술력, 직접 확인해 보세요.</p>
      <a href="/inquiries" class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#2563EB] text-white font-semibold hover:bg-[#1d4ed8] transition-colors text-sm">
        무료 상담받기
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</SubPageLayout>

<style>
  .pr-outline-text {
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(37, 99, 235, 0.8);
    animation: pr-outline-sparkle 3s ease-in-out infinite;
  }

  @keyframes pr-outline-sparkle {
    0%, 100% { -webkit-text-stroke-color: rgba(37, 99, 235, 0.5); }
    50% { -webkit-text-stroke-color: rgba(37, 99, 235, 1); }
  }

  .pr-glow-d {
    color: rgba(37, 99, 235, 0.3);
    text-shadow: 0 0 80px rgba(37, 99, 235, 0.15), 0 0 160px rgba(37, 99, 235, 0.05);
    animation: pr-d-glow 4s ease-in-out infinite;
  }

  @keyframes pr-d-glow {
    0%, 100% { opacity: 0.03; }
    50% { opacity: 0.06; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pr-outline-text { animation: none; -webkit-text-stroke-color: rgba(37, 99, 235, 0.8); color: transparent; }
    .pr-glow-d { animation: none; }
  }
</style>
