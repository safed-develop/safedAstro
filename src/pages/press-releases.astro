---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '상담문의', url: '/inquiries' },
  { name: 'FAQ', url: '/faq' },
];

const releases = [
  {
    title: '건설현장 안전 지킴이 \'세이프디(SafeD) 2.0\' 업그레이드',
    description: '비콘(Beacon) 기반 위험지역 안내 기능 탑재…각종 산업 현장 안전관리 효율성 개선',
    link: 'https://www.dnews.co.kr/uhtml/view.jsp?idxno=202105271547123180545',
    source: '대한경제',
  },
  {
    title: '물류센터 산재예방 위해 \'세이프디(SafeD) 2.0\' 출시',
    description: '부동산 인프라 자산 관리 기업 산업 현장 사고예방을 효과적으로 도와주는 위험성 평가 프로세스 관리 솔루션',
    link: 'https://www.wowtv.co.kr/NewsCenter/News/Read?articleId=A202105280082&t=NN',
    source: '한국경제TV',
  },
  {
    title: '중대재해법 시행 앞두고 산업현장 안전관리 솔루션 주목',
    description: '업그레이드된 세이프디 2.0...정교한 감지로 위험 경고 및 자동 알람',
    link: 'https://www.newsclaim.co.kr/news/articleView.html?idxno=1645551',
    source: '뉴스클레임',
  },
  {
    title: '건설현장 안전지킴이 나선 밸류업 플랫폼 세이프디 2.0 선보여',
    description: '통합운영관리(O&M) 플랫폼 기업인 이도(YIDO)는 산업현장 사고 예방을 도와주는 위험성 평가 프로세스 관리 솔루션 개발',
    link: 'http://www.wikileaks-kr.org/news/articleView.html?idxno=108674',
    source: '위키리크스한국',
  },
  {
    title: 'GPS 기반 안전관리 \'세이프디\' 개발',
    description: '통합운영관리(O&M) 플랫폼 기업인 이도(YIDO)는 산업현장 사고 예방을 도와주는 솔루션 개발',
    link: 'https://news.heraldcorp.com/view.php?ud=20210122000473',
    source: '헤럴드경제',
  },
  {
    title: 'O&M 플랫폼 GPS 기반 안전관리 토탈 솔루션 선봬',
    description: '중대재해법이 1년 뒤부터 시행됨에 따라 기업들의 안전관리 책임이 강화된 가운데 GPS를 기반으로',
    link: 'https://www.sentv.co.kr/news/view/587097',
    source: '서울경제TV',
  },
];
---

<SubPageLayout
  title="보도자료 - SafeD | 스마트안전관리시스템"
  pageTitle="보도자료"
  pageTitleEn="Press Releases"
  description="SafeD 보도자료 - 스마트안전관리시스템 언론 보도"
  navLinks={navLinks}
>
  <!-- Award Highlight -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="w-container max-w-5xl">
      <div class="relative bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm reveal">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-0">
          <!-- Left: Award visual -->
          <div class="lg:col-span-2 bg-gradient-to-br from-gray-900 to-gray-800 p-8 lg:p-10 flex flex-col justify-center text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-primary/10 rounded-full blur-[60px]"></div>
            <div class="relative z-10">
              <div class="w-14 h-14 bg-yellow-400/10 rounded-2xl flex items-center justify-center mb-6">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#facc15" stroke-width="1.5">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </div>
              <p class="eng text-yellow-400 font-bold text-xs tracking-widest uppercase mb-3">Award</p>
              <h2 class="text-2xl lg:text-3xl font-extrabold tracking-tight leading-tight mb-4">
                2021 스마트건설대상<br />안전대상 수상
              </h2>
              <p class="text-white/50 text-sm leading-relaxed">
                플랫폼 부문 - 세이프디 주식회사
              </p>
            </div>
          </div>

          <!-- Right: Award details -->
          <div class="lg:col-span-3 p-8 lg:p-10">
            <p class="text-gray-600 leading-relaxed mb-8">
              세이프디 주식회사는 국내 유일의 스마트안전관리솔루션 개발 회사입니다.
              위험성평가 프로세스관리 솔루션 'SafeD'가 스마트건설대상에서 주목을 받았습니다.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: '⚡', title: '원클릭 안전관리', desc: '위험성 평가 회의 결과를 원클릭으로 해결. 약 25,000건 표준위험공종 자료화' },
                { icon: '💰', title: '비용 절감 효과', desc: '시간과 비용을 절감하는 효율적인 안전관리 솔루션' },
                { icon: '📍', title: 'GPS 경고 시스템', desc: '작업 위치·동선 분석으로 위험지역 접근 감지 및 즉시 경고' },
                { icon: '📡', title: '비콘 기술 탑재', desc: '지하·터널 사각지대 제거, 복잡한 물류센터도 정교한 감지' },
              ].map((item) => (
                <div class="bg-gray-50 rounded-xl p-5 hover:bg-primary/5 transition-colors group">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-lg">{item.icon}</span>
                    <h4 class="font-bold text-sm text-gray-800 group-hover:text-primary transition-colors">{item.title}</h4>
                  </div>
                  <p class="text-xs text-gray-500 leading-relaxed">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Press Coverage -->
  <section class="py-20">
    <div class="w-container max-w-5xl">
      <div class="flex items-end justify-between mb-10 reveal">
        <div>
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-3">Media Coverage</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight">언론 보도</h2>
        </div>
        <p class="eng text-sm text-gray-400 hidden sm:block">
          <span class="font-bold text-gray-600">{releases.length}</span> articles
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 reveal delay-100">
        {releases.map((item, i) => (
          <a href={item.link} target="_blank" rel="noopener noreferrer"
             class="group relative bg-white border border-gray-100 rounded-2xl p-6 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-8 h-8 rounded-lg bg-primary/5 flex items-center justify-center">
                <span class="eng text-primary font-bold text-xs">{String(i + 1).padStart(2, '0')}</span>
              </span>
              <span class="text-xs text-primary bg-primary/5 px-2.5 py-1 rounded-full eng font-semibold">{item.source}</span>
              <svg class="w-4 h-4 text-gray-200 group-hover:text-primary ml-auto transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2 leading-snug group-hover:text-primary transition-colors line-clamp-2">{item.title}</h3>
            <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</SubPageLayout>
