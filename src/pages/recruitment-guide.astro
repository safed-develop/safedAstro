---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '채용안내', url: '/recruitment-guide' },
  { name: '채용정보', url: '/recruitment-info' },
];
---

<SubPageLayout
  title="채용안내 - SafeD | 스마트안전관리시스템"
  pageTitle="채용안내"
  pageTitleEn="Recruitment Guide"
  description="SafeD 채용안내 - 복리후생, 인재상, 채용절차 안내"
  navLinks={navLinks}
>
  <!-- ═══ HERO ═══ -->
  <section class="py-24 bg-white">
    <div class="w-container max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase mb-4 text-[#6B6B6B]">Join SafeD</p>
          <h2 class="text-3xl lg:text-[44px] font-bold tracking-tight leading-[1.1] mb-6 text-[#111]">
            기술로 생명을 지키는<br/>
            <span class="text-[#2563EB]">여정에 함께하세요.</span>
          </h2>
          <p class="text-[#6B6B6B] leading-relaxed mb-8 text-sm">
            SafeD는 건설현장의 안전을 혁신하는 스마트 안전관리 플랫폼 기업입니다.
            수평적 문화 속에서 기술로 세상을 바꾸고 싶은 인재를 찾고 있습니다.
          </p>
          <div class="flex flex-wrap gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0] w-fit">
            {['수평적 조직문화', '유연근무제', '성장 지원'].map((label) => (
              <div class="flex items-center gap-2 px-4 py-2.5 bg-white text-sm font-medium text-[#111]">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {label}
              </div>
            ))}
          </div>
        </div>

        <div class="reveal-right delay-200">
          <div class="bg-[#1C1C1E] p-8 text-white border border-white/10">
            <div class="divide-y divide-white/10">
              {[
                { label: '함께하는 팀', desc: '개발 · 안전공학 · 디자인 · 영업', iconPath: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75M8.5 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z' },
                { label: '도입 현장', desc: '150+ 건설현장 운영 중', iconPath: 'M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4L12 14.01l-3-3' },
                { label: '스마트건설대상 수상', desc: '국내 유일 올인원 안전관리 플랫폼', iconPath: 'M12 15l-3 3 1-4-3-3h4L12 7l1 4h4l-3 3 1 4z' },
                { label: '미션', desc: '기술로 생명을 지키는 안전관리', iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
              ].map((item) => (
                <div class="flex items-center gap-3 py-4 first:pt-0 last:pb-0">
                  <div class="w-8 h-8 border border-[#2563EB]/30 flex items-center justify-center flex-shrink-0">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d={item.iconPath}/></svg>
                  </div>
                  <div>
                    <p class="text-white/90 text-sm font-bold">{item.label}</p>
                    <p class="text-white/40 text-xs">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Benefits & Welfare ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="flex items-end justify-between mb-8 reveal">
        <div>
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2">Benefits & Welfare</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111]">일하기 좋은 이유</h2>
        </div>
        <p class="hidden sm:block text-xs text-[#6B6B6B]">SafeD 구성원이 누리는 <strong class="text-[#111]">20+ 혜택</strong></p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0] mb-6">
        {[
          {
            iconPath: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z',
            title: '급여 & 보상',
            items: [
              { name: '경쟁력 있는 연봉', sub: '업계 상위' },
              { name: '인센티브제', sub: '성과연동' },
              { name: '퇴직연금 · 4대보험', sub: '기본 보장' },
              { name: '자격증 · 직책수당', sub: '추가 수당' },
              { name: '장기근속자 포상', sub: '3년/5년' },
            ],
          },
          {
            iconPath: 'M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z',
            title: '건강 & 생활',
            items: [
              { name: '아침 · 점심 식사 제공', sub: '매일' },
              { name: '간식 · 음료 무한 제공', sub: '상시' },
              { name: '건강검진', sub: '연 1회' },
              { name: '경조사 지원금', sub: '규정 지급' },
              { name: '점심시간 연장', sub: '1.5시간' },
            ],
          },
          {
            iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
            title: '성장 & 교육',
            items: [
              { name: '자격증 취득 지원', sub: '전액 지원' },
              { name: '교육비 · 자기계발비', sub: '월 지원' },
              { name: '사내 워크샵', sub: '분기별' },
              { name: '우수사원 시상', sub: '반기별' },
              { name: '컨퍼런스 참가 지원', sub: '연 2회' },
            ],
          },
        ].map((item, i) => (
          <div class={`bg-white reveal delay-${(i + 1) * 100}`}>
            <div class="flex items-center gap-3 p-4 border-b border-[#E0E0E0]">
              <div class="w-8 h-8 border border-[#2563EB]/20 flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d={item.iconPath}/></svg>
              </div>
              <h3 class="font-bold text-sm text-[#111]">{item.title}</h3>
              <span class="ml-auto eng text-[10px] font-bold text-[#2563EB]">{item.items.length}</span>
            </div>
            <div class="divide-y divide-[#E0E0E0]/50">
              {item.items.map((benefit) => (
                <div class="flex items-center justify-between px-4 py-2.5">
                  <div class="flex items-center gap-2">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-sm text-[#3A3A3A]">{benefit.name}</span>
                  </div>
                  <span class="text-[10px] text-[#6B6B6B] eng flex-shrink-0">{benefit.sub}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0] reveal delay-300">
        {[
          { icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>', title: '최고 사양 장비', desc: '노트북·PC·듀얼모니터' },
          { icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>', title: '수평적 문화', desc: '야근·회식 강요 없음' },
          { icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12v10H4V12"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>', title: '생일 파티 & 선물', desc: '웰컴키트·생일 축하' },
          { icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>', title: '자유로운 연차', desc: '연차·경조·육아휴직' },
        ].map((item) => (
          <div class="flex items-center gap-3 bg-white p-3">
            <span class="flex-shrink-0" set:html={item.icon} />
            <div class="min-w-0">
              <p class="font-bold text-xs text-[#111] truncate">{item.title}</p>
              <p class="text-[10px] text-[#6B6B6B] truncate">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ Ideal Candidate ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0 reveal">
        <div class="lg:col-span-4 lg:pr-8">
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2">Ideal Candidate</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111] mb-3">SafeD가 찾는 인재</h2>
          <p class="text-[#6B6B6B] text-sm leading-relaxed mb-4">이런 분과 함께 일하고 싶습니다.</p>
          <div class="border border-[#2563EB]/15 bg-[#2563EB]/[0.03] p-4">
            <p class="text-xs text-[#2563EB] font-semibold mb-2">핵심 요건</p>
            <div class="space-y-2">
              {['안전관리에 대한 사명감', '기술 기반 문제해결 역량', '팀 중심 협업 마인드'].map((t) => (
                <div class="flex items-center gap-2 text-sm text-[#3A3A3A]">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{t}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-8 lg:border-l lg:border-[#E0E0E0] lg:pl-8">
          <div class="grid grid-cols-2 md:grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0]">
            {[
              { title: '창의적 사고', desc: '기존의 틀을 깨는 혁신적 아이디어', iconPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', keyword: 'Innovation' },
              { title: '팀워크', desc: '소통과 협력으로 함께 성장', iconPath: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75M8.5 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z', keyword: 'Collaboration' },
              { title: '책임감', desc: '맡은 일을 끝까지 책임지는 자세', iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', keyword: 'Ownership' },
              { title: '성장 지향', desc: '새로운 도전을 두려워하지 않는 마인드', iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z', keyword: 'Growth' },
              { title: '긍정적 마인드', desc: '적극적으로 해결책을 찾는 자세', iconPath: 'M14.828 14.828a4 4 0 0 1-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z', keyword: 'Positivity' },
              { title: '고객 중심', desc: '현장 안전이라는 본질적 가치에 공감', iconPath: 'M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z', keyword: 'Empathy' },
            ].map((item) => (
              <div class="bg-white p-5">
                <div class="flex items-center gap-2.5 mb-3">
                  <div class="w-8 h-8 border border-[#2563EB]/20 flex items-center justify-center flex-shrink-0">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d={item.iconPath}/></svg>
                  </div>
                  <div class="min-w-0">
                    <p class="font-bold text-sm text-[#111] leading-tight">{item.title}</p>
                    <p class="eng text-[10px] font-medium text-[#2563EB]">{item.keyword}</p>
                  </div>
                </div>
                <p class="text-[#6B6B6B] text-xs leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Hiring Process ═══ -->
  <section class="bg-[#1C1C1E] text-white">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="text-center mb-14">
        <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2 reveal">Hiring Process</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight reveal delay-100">채용 절차</h2>
        <p class="text-white/40 mt-3 text-sm reveal delay-200">지원서 접수부터 최종합격까지, 투명하고 빠른 프로세스.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-[1px] bg-white/10 border border-white/10">
        {[
          { step: '01', title: '서류전형', desc: '이력서·포트폴리오 검토', iconPath: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8', duration: '1~3일' },
          { step: '02', title: '1차 면접', desc: '실무진 역량 면접', iconPath: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z', duration: '1주 내' },
          { step: '03', title: '과제전형', desc: '직무 관련 실무 과제', iconPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', duration: '1주 내' },
          { step: '04', title: '2차 면접', desc: '대표 면접 · 컬쳐핏', iconPath: 'M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M8.5 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z', duration: '1주 내' },
          { step: '05', title: '최종합격', desc: '처우 협의 · 입사', iconPath: 'M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4L12 14.01l-3-3', duration: '즉시' },
        ].map((item, i) => (
          <div class={`bg-[#1C1C1E] p-6 text-center reveal delay-${(i + 1) * 100}`}>
            <div class="w-10 h-10 border border-[#2563EB]/30 flex items-center justify-center mx-auto mb-4">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d={item.iconPath}/></svg>
            </div>
            <p class="eng text-xs font-semibold text-[#2563EB] mb-1">Step {item.step}</p>
            <h3 class="font-bold text-white/90 text-sm mb-1">{item.title}</h3>
            <p class="text-white/40 text-xs leading-relaxed">{item.desc}</p>
            <p class="eng text-[10px] text-white/25 mt-2 font-medium">{item.duration}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="bg-[#1C1C1E] text-white py-20 border-t border-white/10">
    <div class="w-container text-center reveal">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4 tracking-tight">SafeD와 함께 성장하세요</h2>
      <p class="text-white/50 mb-8 text-sm">기술로 생명을 지키는 여정, 지금 합류하세요</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/recruitment-info" class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#2563EB] text-white font-semibold hover:bg-[#1d4ed8] transition-colors text-sm">
          채용정보 보기
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/inquiries" class="inline-flex items-center gap-2 px-8 py-3.5 border border-white/20 text-white font-semibold hover:bg-white/5 transition-colors text-sm">
          문의하기
        </a>
      </div>
    </div>
  </section>
</SubPageLayout>
