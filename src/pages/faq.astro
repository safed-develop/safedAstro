---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import Accordion from '../components/ui/Accordion.astro';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '상담문의', url: '/inquiries' },
  { name: 'FAQ', url: '/faq' },
];

const faqs = [
  { question: 'SafeD는 어떤 서비스인가요?', answer: 'SafeD는 건설 현장 및 산업 현장의 안전관리를 위한 스마트 솔루션입니다. 위험성평가, GPS 기반 모니터링, 비콘 기술 등을 활용하여 체계적인 안전관리를 지원합니다.' },
  { question: '도입 비용은 어떻게 되나요?', answer: '프로젝트 규모와 필요한 기능에 따라 맞춤형 견적을 제공해 드립니다. 상담문의를 통해 자세한 안내를 받으실 수 있습니다.' },
  { question: '설치 및 도입 기간은 얼마나 걸리나요?', answer: '현장 규모와 요구사항에 따라 다르지만, 일반적으로 컨설팅부터 시스템 구축까지 약 2~4주 정도 소요됩니다.' },
  { question: '기술 지원은 어떻게 받을 수 있나요?', answer: '전화(02-6748-0835) 또는 이메일(sales@safed.co.kr)을 통해 기술 지원을 받으실 수 있습니다. 전담 기술팀이 신속하게 대응해 드립니다.' },
];
---

<SubPageLayout
  title="FAQ - SafeD | 스마트안전관리시스템"
  pageTitle="FAQ"
  pageTitleEn="Frequently Asked Questions"
  description="SafeD 자주 묻는 질문 - 스마트안전관리시스템"
  keywords="SafeD FAQ, 자주묻는질문, 안전관리시스템 문의, SafeD 도입"
  navLinks={navLinks}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  }}
>
  <section class="py-20">
    <div class="w-container max-w-3xl">
      <div class="mb-12 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">FAQ</p>
        <h2 class="text-2xl font-bold tracking-tight">자주 묻는 질문</h2>
        <p class="text-gray-500 mt-2">SafeD에 대해 궁금하신 점을 확인해 보세요.</p>
      </div>

      <div class="reveal delay-100">
        <Accordion items={faqs} />
      </div>

      <div class="mt-16 bg-gray-50 rounded-2xl p-8 text-center reveal delay-200">
        <p class="text-gray-600 mb-4">원하시는 답변을 찾지 못하셨나요?</p>
        <a href="/inquiries" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-full font-semibold text-sm hover:bg-primary/90 transition-colors">
          상담문의 바로가기
        </a>
      </div>
    </div>
  </section>
</SubPageLayout>
