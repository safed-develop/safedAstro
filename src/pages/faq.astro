---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import Accordion from '../components/ui/Accordion.astro';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '블로그', url: '/blog' },
  { name: '상담문의', url: '/inquiries' },
  { name: 'FAQ', url: '/faq' },
];

const faqs = [
  { question: 'SafeD는 어떤 서비스인가요?', answer: 'SafeD는 건설 현장 및 산업 현장의 안전관리를 위한 스마트 솔루션입니다. 위험성평가, GPS 기반 모니터링, 비콘 기술 등을 활용하여 체계적인 안전관리를 지원합니다.' },
  { question: '도입 비용은 어떻게 되나요?', answer: '프로젝트 규모와 필요한 기능에 따라 맞춤형 견적을 제공해 드립니다. 상담문의를 통해 자세한 안내를 받으실 수 있습니다.' },
  { question: '설치 및 도입 기간은 얼마나 걸리나요?', answer: '현장 규모와 요구사항에 따라 다르지만, 일반적으로 컨설팅부터 시스템 구축까지 약 2~4주 정도 소요됩니다.' },
  { question: '기술 지원은 어떻게 받을 수 있나요?', answer: '전화(02-6748-0836) 또는 이메일(sales@safed.co.kr)을 통해 기술 지원을 받으실 수 있습니다. 전담 기술팀이 신속하게 대응해 드립니다.' },
];
---

<SubPageLayout
  title="FAQ - SafeD | 스마트안전관리시스템"
  pageTitle="FAQ"
  pageTitleEn="Frequently Asked Questions"
  description="SafeD 자주 묻는 질문 - 스마트안전관리시스템"
  keywords="SafeD FAQ, 자주묻는질문, 안전관리시스템 문의, SafeD 도입"
  navLinks={navLinks}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  }}
>
  <!-- Quick stats -->
  <section class="py-6 border-b border-[#E0E0E0]">
    <div class="w-container">
      <div class="flex items-center justify-center gap-8 flex-wrap text-sm">
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span class="text-[#6B6B6B]"><span class="eng font-bold text-[#111]">{faqs.length}</span>개 질문</span>
        </div>
        <span class="text-[#E0E0E0]">|</span>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72"/></svg>
          <span class="text-[#6B6B6B]">추가 문의: <span class="eng font-bold text-[#111]">02-6748-0836</span></span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="w-container max-w-3xl">
      <div class="text-center mb-14 reveal">
        <p class="text-[#2563EB] eng font-semibold text-sm tracking-widest uppercase mb-3">FAQ</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-3 text-[#111]">자주 묻는 질문</h2>
        <p class="text-[#6B6B6B] text-sm">SafeD에 대해 궁금하신 점을 확인해 보세요.</p>
      </div>

      <div class="reveal delay-100">
        <Accordion items={faqs} />
      </div>

      <!-- Still have questions -->
      <div class="mt-16 reveal delay-200">
        <div class="relative bg-gradient-to-r from-gray-900 to-gray-800 p-8 lg:p-10 text-center overflow-hidden">
          <div class="relative z-10">
            <div class="w-12 h-12 bg-white/10 flex items-center justify-center mx-auto mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <p class="text-white font-bold text-lg mb-2">원하시는 답변을 찾지 못하셨나요?</p>
            <p class="text-white/50 text-sm mb-6">SafeD 전문 상담사가 직접 답변해 드립니다.</p>
            <div class="flex items-center justify-center gap-3 flex-wrap">
              <a href="/inquiries" class="inline-flex items-center gap-2 px-6 py-3 bg-[#2563EB] text-white font-semibold text-sm hover:bg-[#1d4ed8] transition-colors">
                상담문의
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="tel:02-6748-0836" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold text-sm hover:bg-white/20 transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6"/></svg>
                전화하기
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</SubPageLayout>
