<style>
  /* Proven Results — Aurora mesh gradient */
  .pr-aurora {
    background: #0A1628;
  }

  .pr-aurora::before {
    content: '';
    position: absolute;
    inset: -50%;
    z-index: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(26,10,46,0.7) 0%, transparent 60%),
      radial-gradient(ellipse 60% 70% at 75% 60%, rgba(10,31,46,0.65) 0%, transparent 55%),
      radial-gradient(ellipse 70% 55% at 50% 80%, rgba(15,22,42,0.5) 0%, transparent 50%),
      radial-gradient(ellipse 50% 60% at 30% 20%, rgba(10,31,46,0.4) 0%, transparent 50%);
    animation: aurora-mesh 1s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes aurora-mesh {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(-2%, 1.5%) rotate(0.5deg) scale(1.02); }
    50% { transform: translate(1.5%, -1%) rotate(-0.5deg) scale(1); }
    75% { transform: translate(2%, 1%) rotate(0.3deg) scale(1.01); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pr-aurora::before {
