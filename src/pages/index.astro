---
import BaseLayout from '../layouts/BaseLayout.astro';
import SlideShow from '../components/ui/SlideShow.tsx';
import MultiSlide from '../components/ui/MultiSlide.tsx';
import HoverComponent from '../components/ui/HoverComponent.astro';
import TestimonialCarousel from '../components/ui/TestimonialCarousel.tsx';
import PinScrollSection from '../components/ui/PinScrollSection.tsx';
---

<BaseLayout
  title="SafeD - 스마트 안전관리 시스템 | 건설현장 안전관리의 새로운 기준"
  description="SafeD는 건설현장 스마트 안전관리 시스템입니다. 위험성평가, GPS 모니터링, 비콘 기술로 중대재해를 예방합니다."
  keywords="SafeD, 스마트안전관리, 건설현장안전, 중대재해처벌법, 위험성평가, 안전관리시스템, 건설안전, 산업안전"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SafeD - 스마트안전관리시스템",
    "url": "https://www.safed.co.kr",
    "description": "건설현장 안전관리의 새로운 기준을 제시하는 스마트 안전관리 시스템",
    "publisher": {
      "@type": "Organization",
      "name": "세이프디 주식회사"
    }
  }}
>
  <!-- Hero Slide -->
  <SlideShow
    client:load
    slides={[
      {
        image: '/images/mainslide01.jpg',
        featureImage: '/images/safed1.png',
        tag: '#1 Smart Safety Platform',
        title: '사고를 기다리시겠습니까?\n지금 바로 예방하십시오.',
        subtitle: '매년 건설현장 사망사고 400건 이상. SafeD는 위험성평가·GPS·비콘·AI 번역을 하나로 통합하여, 사고가 발생하기 전에 차단합니다.',
        highlights: ['사고 예방률 99.2%', '업무 시간 80% 절감', '150+ 현장 검증'],
        link: '/safed-features',
        linkText: '지금 기능 확인하기',
      },
      {
        image: '/images/mainslide02.jpg',
        featureImage: '/images/dboard.png',
        tag: '국내 150+ 현장이 선택',
        title: '대한민국 1위 건설사들이\n이미 도입했습니다.',
        subtitle: '스마트건설대상 수상, 특허 2건 보유. 150개 이상의 건설현장에서 검증된 유일한 올인원 안전관리 플랫폼.',
        highlights: ['스마트건설대상 수상', '특허 2건', '국내 유일 올인원'],
        link: '/company-overview',
        linkText: '도입 사례 보기',
      },
      {
        image: '/images/mainslide03.jpg',
        featureImage: '/images/safed2.png',
        tag: '경영책임자 징역 1년 이상',
        title: '중대재해처벌법,\n아직도 서류로 대응하십니까?',
        subtitle: '경영책임자 1년 이상 징역, 법인 10억 벌금. SafeD는 4대 의무사항을 시스템으로 100% 매핑하고, 근거자료를 자동 생성합니다.',
        highlights: ['4대 의무 100% 매핑', '근거자료 자동생성', '리스크 완벽 차단'],
        link: '/business-background',
        linkText: '법적 리스크 확인하기',
      },
    ]}
  />

  <!-- Pin Scroll Marketing Section -->
  <section class="py-20 lg:py-28 bg-white">
    <PinScrollSection
      client:visible
      items={[
        {
          tag: 'Safety Platform',
          headline: '종이 위험성평가,\n그 사이 사고가 납니다.',
          desc: '260종 3만여 건의 위험 Case를 눈으로 확인하시겠습니까? SafeD는 1-click으로 위험요인을 즉시 조회하고, 현장에서 바로 조치합니다. 서류 더미가 아닌 시스템이 생명을 지킵니다.',
          stat: '80%',
          statLabel: '반복 업무 즉시 제거',
          image: '/images/safed_feature_01.png',
        },
        {
          tag: 'Risk Assessment',
          headline: '위험성평가, 아직 4시간\n걸리고 계십니까?',
          desc: '300여개 공종, 50,000개 위험요인·안전대책 DB가 자동 매칭됩니다. 협력업체도 10분 안에 작성 완료. 최초/정기/수시/일일 평가 모두 지원. 더 이상 시간 낭비하지 마십시오.',
          stat: '70%',
          statLabel: '작성 시간 단축',
          image: '/images/safed_feature_02.png',
        },
        {
          tag: 'Legal Compliance',
          headline: '징역 1년, 벌금 10억.\n준비 안 된 당신의 리스크.',
          desc: '중대재해처벌법 4대 의무사항을 SafeD가 100% 시스템으로 매핑합니다. 안전보건관리체계 구축부터 의무이행 근거자료 자동생성까지. 법적 리스크를 완벽 차단합니다.',
          stat: '100%',
          statLabel: '법적 의무 완벽 대응',
          image: '/images/safed_feature_06.png',
        },
        {
          tag: 'Cost Savings',
          headline: '월 120만원이 절감됩니다.\n도입 안 할 이유가 없습니다.',
          desc: '탐색 60분→10분, 발굴 120분→20분, 기록 60분→10분. 하루 240분의 업무가 40분으로. 현장당 월 120만원, 연간 1,440만원 절감. 투자 대비 ROI가 압도적입니다.',
          stat: '1,440만원',
          statLabel: '연간 절감 (현장당)',
          image: '/images/safed_feature_05.png',
        },
        {
          tag: 'Multilingual',
          headline: '외국인 근로자가 위험을\n모르면, 사고가 됩니다.',
          desc: '베트남·중국·태국·미얀마 등 19개국어를 Google AI가 실시간 번역합니다. 위험성평가·TBM·안전교육을 모국어로 확인하고 음성으로 듣습니다. 소통 단절이 곧 사고입니다.',
          stat: '19개국어',
          statLabel: '실시간 자동번역',
          image: '/images/safed_feature_03.png',
        },
      ]}
    />
  </section>

  <!-- Numbers Section -->
  <section class="py-24 bg-gray-950 text-white overflow-hidden relative">
    <!-- Wave bar decoration -->
    <div class="absolute bottom-0 left-0 right-0 flex items-end gap-[2px] h-16 opacity-20 px-4" aria-hidden="true">
      {Array.from({length: 80}).map((_, i) => {
        const h = 20 + Math.sin(i * 0.5) * 25 + Math.sin(i * 1.2) * 15;
        const dur = (0.5 + Math.sin(i * 0.4) * 0.3).toFixed(2);
        const del = (i * 0.03).toFixed(2);
        return (
          <div class="flex-1 rounded-t-sm" style={`height: ${h}%; background: linear-gradient(to top, rgba(0,123,255,0.6), rgba(0,198,255,0.2)); animation: wave-bar ${dur}s ease-in-out infinite alternate; animation-delay: ${del}s;`}></div>
        );
      })}
    </div>
    <div class="w-container relative z-10">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Proven Results</p>
        <h2 class="sub-headline reveal delay-100">말이 아니라,<br />숫자가 증명합니다.</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        {[
          { num: '25,000+', label: '표준위험공종 데이터', sub: '업계 최다 위험공종 DB 보유' },
          { num: '99.2%', label: '사고 예방률', sub: '도입 현장 기준' },
          { num: '150+', label: '도입 현장', sub: '국내 주요 건설사 파트너' },
          { num: '24/7', label: '실시간 모니터링', sub: 'GPS · Beacon · Push' },
        ].map((item, i) => (
          <div class={`text-center reveal delay-${(i + 1) * 100}`}>
            <p class="eng text-4xl lg:text-5xl font-extrabold text-gradient-blue counter-num mb-2">{item.num}</p>
            <p class="font-semibold text-white/90 mb-1">{item.label}</p>
            <p class="text-sm text-white/40">{item.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why SafeD - Problem/Solution -->
  <section class="py-28 bg-white">
    <div class="w-container max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Why SafeD?</p>
          <h2 class="sub-headline mb-6">
            같은 사고가 반복되는 이유?<br />
            <span class="text-primary">관리 방식이 잘못됐습니다.</span>
          </h2>
          <p class="text-gray-500 leading-relaxed mb-4">
            엑셀 위험성평가, 서류 더미에 묻힌 안전 데이터, 실시간 현황 파악 불가.
            <strong class="text-gray-700">이것이 매년 400명이 사망하는 현실의 원인입니다.</strong>
          </p>
          <p class="text-gray-500 leading-relaxed mb-8">
            SafeD는 모바일·GPS·비콘·AI 번역을 하나로 통합하여
            현장에서 <strong class="text-gray-700">즉시 작동하는</strong> 안전관리 체계를 구축합니다.
          </p>
          <div class="space-y-4">
            {[
              '위험성평가 작성 시간 70% 단축',
              '현장-본사 간 실시간 안전 데이터 공유',
              '다국적 근로자 언어 장벽 해소',
              '중대재해처벌법 의무이행 완벽 대응',
            ].map((text) => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-gray-700 text-sm font-medium">{text}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal-right delay-200">
          <div class="relative">
            <img src="/images/dboard.png" alt="SafeD 대시보드" class="rounded-2xl shadow-2xl glow" />
            <div class="absolute -bottom-6 -left-6 bg-primary text-white rounded-2xl px-6 py-4 shadow-lg">
              <p class="eng font-bold text-2xl">70%</p>
              <p class="text-xs opacity-80">업무 효율 향상</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Core Features -->
  <section class="py-24 bg-gray-50">
    <div class="w-container">
      <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 text-center reveal">Core Features</p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-6 text-center tracking-tight reveal delay-100">
        하나의 플랫폼에서<br />안전관리의 <span class="text-gradient-blue">모든 것</span>을.
      </h2>
      <p class="text-gray-500 text-center mb-16 reveal delay-200">6가지 핵심 기능으로 현장 안전을 완벽하게 커버합니다.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '/images/safed_feature_01.png', title: '스마트 위험성평가', desc: '위험요인을 찾아 위험성의 크기를 평가하고 조치·검토할 수 있는 시스템', color: 'from-red-900/80 to-red-800/60' },
          { icon: '/images/safed_feature_02.png', title: '위험요소 제거', desc: '추가위험을 발굴하고 위험요소들을 사전에 제거합니다', color: 'from-green-900/80 to-green-800/60' },
          { icon: '/images/safed_feature_03.png', title: '다국어 지원', desc: '현장 별 다국적 근로자를 고려하여 Google AI 자동번역 기능 제공', color: 'from-lime-900/80 to-lime-800/60' },
          { icon: '/images/safed_feature_04.png', title: '안전 모니터링', desc: 'GPS를 통해 출역·작업위치·동선 등을 실시간으로 확인', color: 'from-blue-900/80 to-blue-800/60' },
          { icon: '/images/safed_feature_05.png', title: '비콘 경고', desc: '이동식 장비에 탈·부착 가능하며 접근경고로 작업자 안전 확보', color: 'from-cyan-900/80 to-cyan-800/60' },
          { icon: '/images/safed_feature_06.png', title: '커뮤니케이션', desc: 'SMS, Mobile Push 알람으로 오늘할일, 잔여과제 자동 발송', color: 'from-emerald-900/80 to-emerald-800/60' },
        ].map((feat, i) => (
          <div class={`group relative overflow-hidden rounded-2xl p-8 bg-gradient-to-br ${feat.color} text-white min-h-[220px] flex flex-col justify-end reveal delay-${(i % 3 + 1) * 100}`}>
            <img src={feat.icon} alt={feat.title} class="w-16 h-16 mb-4 object-contain opacity-90 group-hover:scale-110 transition-transform" />
            <h3 class="text-lg font-bold mb-2">{feat.title}</h3>
            <p class="text-sm opacity-80 leading-relaxed">{feat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Interactive Feature Demo -->
  <section class="py-24 bg-white">
    <div class="w-container">
      <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 text-center reveal">Key Functions</p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-12 text-center tracking-tight reveal delay-100">SafeD 주요 기능</h2>
      <div class="reveal delay-200">
        <HoverComponent items={[
          { label: '모바일 위험성평가', title: '스마트 위험성평가', text: '현장에서 모바일로 간편하게 위험성평가를 작성하고 관리할 수 있습니다.', image: '/images/feature01.jpg' },
          { label: 'BEACON 경고', title: '비콘 위험경고 시스템', text: '비콘 기술로 위험지역 접근 시 자동 알림을 발송합니다.', image: '/images/feature02.jpg' },
          { label: 'GPS 분석', title: 'GPS 동선 분석', text: 'GPS를 통한 근로자 위치 추적 및 동선 분석이 가능합니다.', image: '/images/feature04.jpg' },
          { label: '다국어 번역', title: '다국어 자동번역', text: '다국적 근로자를 위한 실시간 AI 자동번역 기능을 제공합니다.', image: '/images/feature05.jpg' },
        ]} />
      </div>
    </div>
  </section>

  <!-- Safety Management System Mapping -->
  <section class="py-24 bg-gray-950 text-white relative overflow-hidden">
    <!-- Top wave bars -->
    <div class="absolute top-0 left-0 right-0 flex items-start gap-[2px] h-12 opacity-15 px-4 rotate-180" aria-hidden="true">
      {Array.from({length: 60}).map((_, i) => {
        const h = 15 + Math.sin(i * 0.6) * 20 + Math.cos(i * 0.9) * 12;
        const dur = (0.6 + Math.sin(i * 0.3) * 0.4).toFixed(2);
        const del = (i * 0.04).toFixed(2);
        return (
          <div class="flex-1 rounded-t-sm" style={`height: ${h}%; background: linear-gradient(to top, rgba(0,123,255,0.5), rgba(0,198,255,0.15)); animation: wave-bar ${dur}s ease-in-out infinite alternate; animation-delay: ${del}s;`}></div>
        );
      })}
    </div>
    <div class="w-container max-w-5xl relative z-10">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Safety System</p>
        <h2 class="sub-headline reveal delay-100">안전보건관리체계를<br /><span class="text-gradient-blue">SafeD로 구축합니다</span></h2>
        <p class="text-white/50 mt-4 reveal delay-200">중대재해처벌법 제4조의 의무사항을 SafeD 기능으로 완벽 매핑</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal delay-200">
        {[
          { duty: '안전보건관리체계 구축·이행', solution: '위험성평가, 점검활동, DB 시스템 구축', iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', iconColor: '#ef4444' },
          { duty: '재발방지 대책 수립·이행', solution: '사고사례 DB, 현장 안전 데이터 분석', iconPath: 'M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15', iconColor: '#f59e0b' },
          { duty: '개선·시정 명령 이행', solution: '실시간 모니터링, 자동 알림·조치 추적', iconPath: 'M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11', iconColor: '#3b82f6' },
          { duty: '의무이행 관리 조치', solution: '대시보드, 보고서 자동 생성, 근거자료 보관', iconPath: 'M18 20V10M12 20V4M6 20v-6', iconColor: '#8b5cf6' },
        ].map((item) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center" style={`background: ${item.iconColor}15`}>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={item.iconColor} stroke-width="1.5"><path d={item.iconPath}/></svg>
              </div>
              <div>
                <p class="text-red-400 text-xs font-semibold mb-1 eng uppercase">법적 의무</p>
                <p class="font-semibold text-white/90 mb-2">{item.duty}</p>
                <p class="text-primary text-xs font-semibold mb-1 eng uppercase">SafeD 솔루션</p>
                <p class="text-white/60 text-sm">{item.solution}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Voices from the Field + Industries - 2 Column -->
  <section class="py-24 bg-gray-50">
    <div class="w-container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Left: Testimonials with auto-scroll -->
        <div class="lg:col-span-7">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">Voices from the Field</p>
          <h2 class="text-3xl font-bold mb-8 tracking-tight reveal delay-100">현장의 목소리</h2>
          <div class="reveal delay-200">
            <TestimonialCarousel
              client:visible
              testimonials={[
