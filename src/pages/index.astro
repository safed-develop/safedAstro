---
import BaseLayout from '../layouts/BaseLayout.astro';
import SlideShow from '../components/ui/SlideShow.tsx';
import MultiSlide from '../components/ui/MultiSlide.tsx';
import TestimonialCarousel from '../components/ui/TestimonialCarousel.tsx';
import PinScrollSection from '../components/ui/PinScrollSection.tsx';
---

<BaseLayout
  title="SafeD - 스마트 안전관리 시스템 | 건설현장 안전관리의 새로운 기준"
  description="SafeD는 건설현장 스마트 안전관리 시스템입니다. 위험성평가, GPS 모니터링, 비콘 기술로 중대재해를 예방합니다."
  keywords="SafeD, 스마트안전관리, 건설현장안전, 중대재해처벌법, 위험성평가, 안전관리시스템, 건설안전, 산업안전"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SafeD - 스마트안전관리시스템",
    "url": "https://www.safed.co.kr",
    "description": "건설현장 안전관리의 새로운 기준을 제시하는 스마트 안전관리 시스템",
    "publisher": {
      "@type": "Organization",
      "name": "세이프디 주식회사"
    }
  }}
>
  <!-- Blur Intro -->
  <div id="blur-intro" aria-hidden="true"></div>

  <!-- Hero Slide -->
  <SlideShow
    client:load
    slides={[
      {
        image: '/images/dmainslide01.jpg',
        featureImage: '/images/mainslide_01_f.png',
        title: '사고를 기다리시겠습니까?\n지금 바로 예방하십시오.',
        subtitle: '매년 건설현장 사망사고 400건 이상. SafeD는 위험성평가·GPS·비콘·AI 번역을 하나로 통합하여, 사고가 발생하기 전에 차단합니다.',
        highlights: ['사고 예방률 99.2%', '업무 시간 80% 절감', '150+ 현장 검증'],
        link: '/safed-features',
        linkText: '지금 기능 확인하기',
      },
      {
        image: '/images/mainslide_02_2026.jpg',
        featureImage: '/images/cap01.png',
        title: '대한민국 1위 건설사들이\n이미 도입했습니다.',
        subtitle: '스마트건설대상 수상, 특허 2건 보유. 150개 이상의 건설현장에서 검증된 유일한 올인원 안전관리 플랫폼.',
        highlights: ['스마트건설대상 수상', '특허 2건', '국내 유일 올인원'],
        link: '/company-overview',
        linkText: '도입 사례 보기',
      },
      {
        image: '/images/mainslide_03_2026.jpg',
        title: '중대재해처벌법,\n아직도 서류로 대응하십니까?',
        subtitle: '경영책임자 1년 이상 징역, 법인 10억 벌금. SafeD는 4대 의무사항을 시스템으로 100% 매핑하고, 근거자료를 자동 생성합니다.',
        highlights: ['4대 의무 100% 매핑', '근거자료 자동생성', '리스크 완벽 차단'],
        link: '/business-background',
        linkText: '법적 리스크 확인하기',
      },
    ]}
  />

  <!-- Pin Scroll Marketing Section -->
  <section class="py-6 md:py-10 lg:py-28 bg-white">
    <PinScrollSection
      client:visible
      items={[
        {
          tag: 'Safety Platform',
          tagKo: '안전관리 플랫폼',
          headline: '종이 위험성평가,\n그 사이 사고가 납니다.',
          desc: '260종 3만여 건의 위험 Case를 눈으로 확인하시겠습니까? SafeD는 1-click으로 위험요인을 즉시 조회하고, 현장에서 바로 조치합니다. 서류 더미가 아닌 시스템이 생명을 지킵니다.',
          stat: '80%',
          statLabel: '반복 업무 즉시 제거',
          image: '/images/main_img_01.png',
        },
        {
          tag: 'Risk Assessment',
          tagKo: '위험성평가',
          headline: '위험성평가, 아직 4시간\n걸리고 계십니까?',
          desc: '300여개 공종, 50,000개 위험요인·안전대책 DB가 자동 매칭됩니다. 협력업체도 10분 안에 작성 완료. 최초/정기/수시/일일 평가 모두 지원. 더 이상 시간 낭비하지 마십시오.',
          stat: '70%',
          statLabel: '작성 시간 단축',
          image: '/images/main_img_02.png',
        },
        {
          tag: 'Legal Compliance',
          tagKo: '법적 대응',
          headline: '징역 1년, 벌금 10억.\n준비 안 된 당신의 리스크.',
          desc: '중대재해처벌법 4대 의무사항을 SafeD가 100% 시스템으로 매핑합니다. 안전보건관리체계 구축부터 의무이행 근거자료 자동생성까지. 법적 리스크를 완벽 차단합니다.',
          stat: '100%',
          statLabel: '법적 의무 완벽 대응',
          image: '/images/feature05.jpg',
        },
        {
          tag: 'Cost Savings',
          tagKo: '비용 절감',
          headline: '월 120만원이 절감됩니다.\n도입 안 할 이유가 없습니다.',
          desc: '탐색 60분→10분, 발굴 120분→20분, 기록 60분→10분. 하루 240분의 업무가 40분으로. 현장당 월 120만원, 연간 1,440만원 절감. 투자 대비 ROI가 압도적입니다.',
          stat: '1,440만원',
          statLabel: '연간 절감 (현장당)',
          image: '/images/main03.png',
        },
        {
          tag: 'Multilingual',
          tagKo: '다국어 지원',
          headline: '외국인 근로자가 위험을\n모르면, 사고가 됩니다.',
          desc: '베트남·중국·태국·미얀마 등 19개국어를 Google AI가 실시간 번역합니다. 위험성평가·TBM·안전교육을 모국어로 확인하고 음성으로 듣습니다. 소통 단절이 곧 사고입니다.',
          stat: '19개국어',
          statLabel: '실시간 자동번역',
          image: '/images/main_img_03.png',
        },
      ]}
    />
  </section>

  <!-- Numbers Section -->
  <section class="pr-aurora py-10 md:py-14 text-white overflow-hidden relative">

    <div class="w-container relative z-10">
      <div class="text-center mb-6 md:mb-10">
        <p class="eng font-semibold text-xs md:text-sm tracking-widest uppercase mb-2 md:mb-4 text-primary reveal">Proven Results</p>
        <h2 class="sub-headline text-lg md:text-2xl lg:text-3xl reveal delay-100">말이 아니라,<br />숫자가 증명합니다.</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8 lg:gap-12">
        {[
          { num: '150+', label: '도입 현장', sub: '전국',
            icon: 'M3 21h18M5 21V7l8-4 8 4v14M9 21v-6h6v6M9 9h.01M15 9h.01M9 13h.01M15 13h.01' },
          { num: '50,000', label: '위험요인 DB', sub: '업계 최다',
            icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM9 12l2 2 4-4' },
          { num: '99.2%', label: '사고 예방률', sub: '도입 후',
            icon: 'M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4L12 14.01l-3-3' },
          { num: '2건', label: '특허 보유', sub: '핵심 기술',
            icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M9 15l2 2 4-4' },
        ].map((item, i) => (
          <div class={`text-center reveal delay-${(i + 1) * 100}`}>
            <div class="flex justify-center mb-2 md:mb-4">
              <svg class="stat-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path class="stat-icon-path" d={item.icon} />
              </svg>
            </div>
            <p class="eng text-2xl md:text-4xl lg:text-5xl font-extrabold text-gradient-blue counter-num mb-1 md:mb-2">{item.num}</p>
            <p class="font-semibold text-white/90 mb-0.5 md:mb-1 text-xs md:text-base">{item.label}</p>
            <p class="text-[10px] md:text-sm text-white/40">{item.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why SafeD - Problem/Solution -->
  <section class="py-10 md:py-14 bg-white">
    <div class="w-container max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-12 items-center">
        <!-- Image: mobile first (order-first), desktop second (md:order-last) -->
        <div class="reveal-right delay-200 order-first md:order-last">
          <div class="relative">
            <img src="/images/main03.png" alt="SafeD 대시보드" class="rounded-2xl shadow-2xl glow w-full" />
            <div class="absolute -bottom-4 -left-4 md:-bottom-6 md:-left-6 bg-primary text-white rounded-2xl px-4 py-2 md:px-6 md:py-4 shadow-lg">
              <p class="eng font-bold text-lg md:text-2xl">70%</p>
              <p class="text-[10px] md:text-xs opacity-80">업무 효율 향상</p>
            </div>
          </div>
        </div>
        <!-- Text: mobile second, desktop first -->
        <div class="reveal order-last md:order-first">
          <p class="text-primary eng font-semibold text-xs md:text-sm tracking-widest uppercase mb-3 md:mb-4">Why SafeD?</p>
          <h2 class="sub-headline mb-4 md:mb-6 text-lg md:text-2xl lg:text-3xl">
            같은 사고가 반복되는 이유?<br />
            <span class="text-primary">관리 방식이 잘못됐습니다.</span>
          </h2>
          <p class="text-gray-500 leading-relaxed mb-3 md:mb-4 text-xs md:text-base">
            엑셀 위험성평가, 서류 더미에 묻힌 안전 데이터, 실시간 현황 파악 불가.
            <strong class="text-gray-700">이것이 매년 400명이 사망하는 현실의 원인입니다.</strong>
          </p>
          <p class="text-gray-500 leading-relaxed mb-3 md:mb-4 text-xs md:text-base">
            SafeD는 모바일·GPS·비콘·AI 번역을 하나로 통합하여
            현장에서 <strong class="text-gray-700">즉시 작동하는</strong> 안전관리 체계를 구축합니다.
          </p>
          <div class="space-y-1.5 md:space-y-2">
            {[
              '위험성평가 작성 시간 70% 단축',
              '현장-본사 간 실시간 안전 데이터 공유',
              '다국적 근로자 언어 장벽 해소',
              '중대재해처벌법 의무이행 완벽 대응',
            ].map((text) => (
              <div class="flex items-center gap-2 md:gap-3">
                <div class="w-5 h-5 md:w-6 md:h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-gray-700 text-xs md:text-sm font-medium">{text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Core Features — Convergence Scroll -->
  <section id="core-features-section" class="cf-section">
    <div class="cf-sticky">
      <!-- Dynamic background & glow -->
      <div class="cf-bg-layer" aria-hidden="true"></div>
      <div class="cf-glow-center" aria-hidden="true"></div>

      <!-- Content layer: heading + grid -->
      <div class="cf-content w-container">
        <div class="cf-heading">
          <p class="text-primary eng font-semibold text-[10px] md:text-xs tracking-widest uppercase mb-1 md:mb-2">Core Features</p>
          <h2 class="text-lg md:text-2xl lg:text-4xl font-bold mb-2 md:mb-3 tracking-tight">
            하나의 플랫폼에서<br />안전관리의 <span class="text-gradient-blue">모든 것</span>을.
          </h2>
          <p class="text-gray-500 text-[10px] md:text-sm mb-4 md:mb-6 lg:mb-10">6가지 핵심 기능으로 현장 안전을 완벽하게 커버합니다.</p>
        </div>
        <div class="cf-grid">
          {[
            { icon: '/images/icon_01.png', title: '스마트 위험성평가', desc: '위험요인 평가·조치·검토', accent: '#ef4444', glow: '#ef4444' },
            { icon: '/images/icon_02.png', title: '위험요소 제거', desc: '추가위험 발굴·사전 제거', accent: '#22c55e', glow: '#22c55e' },
            { icon: '/images/icon_03.png', title: '다국어 지원', desc: 'AI 자동번역 19개국어', accent: '#eab308', glow: '#eab308' },
            { icon: '/images/icon_04.png', title: '안전 모니터링', desc: 'GPS 실시간 위치 추적', accent: '#3b82f6', glow: '#3b82f6' },
            { icon: '/images/icon_05.png', title: '비콘 경고', desc: '접근경고 안전 확보', accent: '#06b6d4', glow: '#06b6d4' },
            { icon: '/images/icon_06.png', title: '커뮤니케이션', desc: 'SMS·Push 자동 발송', accent: '#10b981', glow: '#10b981' },
          ].map((feat, i) => (
            <div class="cf-card" data-cf-card={i} style={`--card-accent: ${feat.accent}; --card-glow: ${feat.glow}; --label-color: ${feat.accent}`}>
              <img src={feat.icon} alt={feat.title} class="cf-card-icon" loading="lazy" />
              <div class="cf-card-label">
                <strong class="cf-card-title">{feat.title}</strong>
                <span class="cf-card-desc">{feat.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA (convergence target — dramatic reveal) -->
      <div class="cf-cta-block">
        <div class="cf-cta-ring" aria-hidden="true"></div>
        <p class="cf-cta-badge eng">ALL-IN-ONE PLATFORM</p>
        <h3 class="cf-cta-title">SafeD 하나로,<br/>안전관리 끝.</h3>
        <p class="cf-cta-sub">6가지 핵심 기능이 하나의 플랫폼에서 완벽하게 통합됩니다.</p>
        <a href="/inquiries" class="cf-cta-btn">
          <span>무료 상담받기</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Safety System Mapping Panel (scroll-linked, Toss Style) -->
      <div class="ss-panel">
        <div class="w-container max-w-4xl">
          <div class="ss-header text-center mb-6 lg:mb-10">
            <p class="eng font-semibold text-xs tracking-widest uppercase mb-3" style="color: #3182F6">Safety System</p>
            <h3 class="text-2xl lg:text-[36px] font-extrabold tracking-tight leading-[1.2] mb-3" style="color: #191F28">안전보건관리체계를<br/>SafeD로 구축합니다</h3>
            <p class="text-sm" style="color: #8B95A1">중대재해처벌법 제4조의 의무사항을 SafeD 기능으로 완벽 매핑</p>
          </div>
          <div class="ss-rows">
            {[
              { duty: '안전보건관리체계 구축·이행', clause: '제4조 제1항 제1호', title: '위험성평가 시스템', desc: '위험성평가, 점검활동, DB 시스템 구축', color: '#3182F6', icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
              { duty: '재발방지 대책 수립·이행', clause: '제4조 제1항 제2호', title: '사고 분석 엔진', desc: '사고사례 DB, 현장 안전 데이터 분석', color: '#6366F1', icon: 'M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15' },
              { duty: '개선·시정 명령 이행', clause: '제4조 제1항 제3호', title: '실시간 모니터링', desc: '실시간 모니터링, 자동 알림·조치 추적', color: '#10B981', icon: 'M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11' },
              { duty: '의무이행 관리 조치', clause: '제4조 제1항 제4호', title: '자동 보고 시스템', desc: '대시보드, 보고서 자동 생성, 근거자료 보관', color: '#F59E0B', icon: 'M18 20V10M12 20V4M6 20v-6' },
            ].map((item) => (
              <div class="ss-row" style={`--row-color: ${item.color}`}>
                <div class="ss-left">
                  <p class="ss-clause">{item.clause}</p>
                  <p class="ss-duty-text">{item.duty}</p>
                </div>
                <div class="ss-conn">
                  <svg class="ss-svg-desktop" viewBox="0 0 80 40" fill="none">
                    <path class="ss-path-base" d="M0,20 L80,20" stroke="#E5E8EB" stroke-width="1.5" stroke-dasharray="4 4" fill="none"/>
                    <path class="ss-path-active" d="M0,20 L80,20" stroke={item.color} stroke-width="2" fill="none"/>
                    <circle class="ss-dot" r="4" cx="0" cy="20" fill={item.color}/>
                    <g class="ss-check">
                      <circle cx="40" cy="20" r="12" fill={item.color}/>
                      <path d="M34,20.5 L38,24.5 L46,16.5" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </g>
                  </svg>
                  <div class="ss-conn-mobile">
                    <div class="ss-check-mobile" style={`background: ${item.color}`}>
                      <svg viewBox="0 0 24 24" fill="none" width="14" height="14"><path d="M5 12l5 5L20 7" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                  </div>
                </div>
                <div class="ss-right">
                  <div class="ss-icon-wrap" style={`background: ${item.color}`}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d={item.icon}/></svg>
                  </div>
                  <div>
                    <p class="ss-solution-title">{item.title}</p>
                    <p class="ss-solution-desc">{item.desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="ss-complete text-center">
            <div class="ss-complete-inner">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span>4/4 법적 의무 완벽 매핑</span>
            </div>
            <p class="ss-complete-sub">중대재해처벌법 대응, SafeD 하나로 완성됩니다</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Voices from the Field - Editorial Quote -->
