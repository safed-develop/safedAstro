<script>
  (function() {
    const el = document.getElementById('blur-intro');
    if (!el) return;

    // Skip if already played this session
    if (sessionStorage.getItem('safed-intro-played')) {
      el.classList.add('hidden');
      return;
    }

    // Skip for reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.classList.add('hidden');
      sessionStorage.setItem('safed-intro-played', '1');
      return;
    }

    // Fade out after brief delay
    requestAnimationFrame(() => {
      setTimeout(() => {
        el.classList.add('fade-out');
        setTimeout(() => {
          el.classList.add('hidden');
        }, 900);
        sessionStorage.setItem('safed-intro-played', '1');
      }, 300);
    });
  })();

  // ===== Core Features + Safety System Unified Scroll =====
  (function() {
    const section = document.getElementById('core-features-section');
    if (!section) return;

    const heading = section.querySelector<HTMLElement>('.cf-heading');
    const headingEls = heading ? Array.from(heading.children) as HTMLElement[] : [];
    const cards = section.querySelectorAll<HTMLElement>('.cf-card');
    const cta = section.querySelector<HTMLElement>('.cf-cta-block');
    const bgLayer = section.querySelector<HTMLElement>('.cf-bg-layer');
    const glowCenter = section.querySelector<HTMLElement>('.cf-glow-center');
    const mainNav = document.getElementById('main-nav');

    // SS elements
    const ssPanel = section.querySelector<HTMLElement>('.ss-panel');
    const ssHeader = ssPanel?.querySelector<HTMLElement>('.ss-header');
    const ssRows = ssPanel ? Array.from(ssPanel.querySelectorAll<HTMLElement>('.ss-row')) : [];
    const ssComplete = ssPanel?.querySelector<HTMLElement>('.ss-complete');

    if (!heading || !cta || cards.length === 0) return;

    // Reduced motion: show everything statically
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // SS panel handled by CSS reduced-motion rules
      ssRows.forEach(row => {
        const left = row.querySelector<HTMLElement>('.ss-left');
        const right = row.querySelector<HTMLElement>('.ss-right');
        if (left) left.style.opacity = '1';
        if (right) { right.style.opacity = '1'; right.style.borderLeft = '3px solid var(--row-color)'; }
        const check = row.querySelector<HTMLElement>('.ss-check');
        const checkM = row.querySelector<HTMLElement>('.ss-check-mobile');
        if (check) check.style.opacity = '1';
        if (checkM) { checkM.style.opacity = '1'; checkM.style.transform = 'scale(1)'; }
      });
      if (ssComplete) ssComplete.style.opacity = '1';
      return;
    }

    // Scatter offsets — cards start far displaced + very faint
    const isMobile = window.innerWidth < 768;
    const scaleF = isMobile ? 0.5 : 1;
    const scatterData = [
      { x: -220 * scaleF, y: -160 * scaleF, r: -22 },
      { x: 100 * scaleF, y: -200 * scaleF, r: 18 },
      { x: 260 * scaleF, y: -90 * scaleF, r: 30 },
      { x: -190 * scaleF, y: 170 * scaleF, r: 20 },
      { x: -80 * scaleF, y: 220 * scaleF, r: -25 },
      { x: 240 * scaleF, y: 140 * scaleF, r: -28 },
    ];

    // Cache SS row data + SVG path lengths
    const rowData = ssRows.map(row => {
      const pathActive = row.querySelector<SVGGeometryElement>('.ss-path-active');
      const dot = row.querySelector<SVGCircleElement>('.ss-dot');
      const totalLen = (pathActive && !isMobile) ? pathActive.getTotalLength() : 0;
      return {
        left: row.querySelector<HTMLElement>('.ss-left'),
        right: row.querySelector<HTMLElement>('.ss-right'),
        path: pathActive,
        dot,
        totalLen,
        check: row.querySelector<HTMLElement>('.ss-check'),
        checkMobile: row.querySelector<HTMLElement>('.ss-check-mobile'),
      };
    });

    let convergeOffsets: { x: number; y: number }[] = [];
    let ticking = false;

    function calcConvergeOffsets() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const cx = vw / 2;
      const cy = vh / 2;
      convergeOffsets = Array.from(cards).map(card => {
        const r = card.getBoundingClientRect();
        return {
          x: cx - (r.left + r.width / 2),
          y: cy - (r.top + r.height / 2),
        };
      });
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    function easeIO(t: number) {
      return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
    }
    function easeOut(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    // Helper: hide SS panel
    function hideSSPanel() {
      if (ssPanel) { ssPanel.style.opacity = '0'; ssPanel.style.pointerEvents = 'none'; }
    }

    // Helper: reset SS rows to hidden state
    function resetSSRows() {
      rowData.forEach(d => {
        if (d.left) { d.left.style.opacity = '0'; d.left.style.transform = 'translateX(-30px)'; d.left.classList.remove('visible'); }
        if (d.right) { d.right.style.opacity = '0'; d.right.style.transform = 'translateX(30px)'; }
        if (d.path) { (d.path as SVGElement).style.opacity = '0'; }
        if (d.dot) { (d.dot as SVGElement).style.opacity = '0'; }
        if (d.check) { (d.check as SVGElement).style.opacity = '0'; (d.check as SVGElement).style.transform = 'scale(0)'; }
        if (d.checkMobile) { d.checkMobile.style.opacity = '0'; d.checkMobile.style.transform = 'scale(0)'; }
      });
      if (ssComplete) { ssComplete.style.opacity = '0'; ssComplete.style.transform = 'translateY(20px) scale(0.7)'; ssComplete.style.filter = 'blur(8px)'; ssComplete.classList.remove('visible'); }
    }

    /*
     * Scroll progress phases (total height ~550vh, scrollable ~450vh):
     *   0.00–0.07  Phase 0: Heading children stagger in (blur→clear), cards ghost
     *   0.07–0.14  Phase 1: Cards settle into grid from scatter
     *   0.14–0.30  Phase 2: Cards converge, bg darkens, CTA appears
     *   0.30–0.42  Phase 3: CTA fully visible (hold)
     *   0.42–0.50  Phase 4: CTA → SS crossfade
     *   0.50–0.90  Phase 5: SS rows (10% each × 4 rows)
     *   0.90–1.00  Phase 6: Completion badge
     */
    function update() {
      ticking = false;
      const vh = window.innerHeight;
      const rect = section!.getBoundingClientRect();
      const scrollable = rect.height - vh;
      if (scrollable <= 0) return;

      const progress = Math.max(0, Math.min(1, -rect.top / scrollable));

      // Nav dark mode sync
      if (mainNav) {
        if (progress > 0.18 && progress < 0.46) mainNav.classList.add('nav-dark');
        else mainNav.classList.remove('nav-dark');
      }

      // ── Phase 0: 0–0.07 → heading blur-stagger at scale 1.6 ──
      if (progress < 0.07) {
        if (bgLayer) bgLayer.style.opacity = '0';
        if (glowCenter) { glowCenter.style.opacity = '0'; glowCenter.style.transform = 'translate(-50%,-50%) scale(0.3)'; }
        cta!.style.opacity = '0';
        cta!.style.transform = 'translate(-50%,-50%) scale(0.8)';
        cta!.style.pointerEvents = 'none';
        hideSSPanel();

        const hp = progress / 0.07;
        heading!.style.opacity = '1';
        heading!.style.transform = 'scale(1.6)';

        const stagger = [
          { blur: 8,  y: 15, delay: 0,    dur: 0.45 },
          { blur: 14, y: 30, delay: 0.28, dur: 0.45 },
          { blur: 8,  y: 18, delay: 0.52, dur: 0.45 },
        ];
        headingEls.forEach((el, ci) => {
          const st = stagger[ci] || stagger[2];
          const cp = easeOut(Math.max(0, Math.min(1, (hp - st.delay) / st.dur)));
          el.style.opacity = String(cp);
          el.style.filter = `blur(${st.blur * (1 - cp)}px)`;
          el.style.transform = `translateY(${st.y * (1 - cp)}px)`;
        });

        cards.forEach((card, i) => {
          const s = scatterData[i] || { x: 0, y: 0, r: 0 };
          card.style.transform = `translate(${s.x}px, ${s.y}px) rotate(${s.r}deg)`;
          card.style.opacity = String(0.04 + hp * 0.04);
        });
        return;
      }

      // Clear heading children inline styles from Phase 0
      headingEls.forEach(el => { el.style.opacity = ''; el.style.filter = ''; el.style.transform = ''; });

      // ── Phase 0b: 0.07–0.12 → heading scale 1.6 → 1.0 ──
      if (progress < 0.12) {
        if (bgLayer) bgLayer.style.opacity = '0';
        if (glowCenter) { glowCenter.style.opacity = '0'; glowCenter.style.transform = 'translate(-50%,-50%) scale(0.3)'; }
        cta!.style.opacity = '0';
        cta!.style.transform = 'translate(-50%,-50%) scale(0.8)';
        cta!.style.pointerEvents = 'none';
        hideSSPanel();

        const shrink = easeIO((progress - 0.07) / 0.05);
        heading!.style.opacity = '1';
        heading!.style.transform = `scale(${1.6 - 0.6 * shrink})`;

        cards.forEach((card, i) => {
          const s = scatterData[i] || { x: 0, y: 0, r: 0 };
          card.style.transform = `translate(${s.x}px, ${s.y}px) rotate(${s.r}deg)`;
          card.style.opacity = String(0.08 + shrink * 0.07);
        });
        return;
      }

      // ── Phase 1: 0.12–0.18 → cards settle into grid ──
      if (progress < 0.18) {
        if (bgLayer) bgLayer.style.opacity = '0';
        if (glowCenter) { glowCenter.style.opacity = '0'; glowCenter.style.transform = 'translate(-50%,-50%) scale(0.3)'; }
        heading!.style.opacity = '1';
        heading!.style.transform = 'scale(1)';
        cta!.style.opacity = '0';
        cta!.style.transform = 'translate(-50%,-50%) scale(0.8)';
        cta!.style.pointerEvents = 'none';
        hideSSPanel();

        const settle = easeIO((progress - 0.12) / 0.06);
        cards.forEach((card, i) => {
          const s = scatterData[i] || { x: 0, y: 0, r: 0 };
          card.style.transform = `translate(${s.x * (1 - settle)}px, ${s.y * (1 - settle)}px) rotate(${s.r * (1 - settle)}deg)`;
          card.style.opacity = String(0.15 + settle * 0.85);
        });
        return;
      }

      // ── Phase 2: 0.18–0.32 → converge + darken + CTA ──
      if (progress < 0.32) {
        if (convergeOffsets.length === 0) calcConvergeOffsets();
        const p2 = (progress - 0.18) / 0.14;
        hideSSPanel();

        if (bgLayer) bgLayer.style.opacity = String(Math.min(1, p2 * 1.6));
        if (glowCenter) {
          const gp = Math.max(0, (p2 - 0.2) / 0.8);
          glowCenter.style.opacity = String(gp * 0.85);
          glowCenter.style.transform = `translate(-50%,-50%) scale(${0.3 + gp * 0.7})`;
        }

        heading!.style.transform = `translateY(${-p2 * 40}px)`;
        heading!.style.opacity = String(Math.max(0, 1 - p2 * 2));

        cards.forEach((card, i) => {
          const stagger = 0.05 * i;
          const cp = Math.max(0, Math.min(1, (p2 - stagger) / (1 - stagger)));
          const ease = easeIO(cp);
          const tx = convergeOffsets[i] ? convergeOffsets[i].x * ease : 0;
          const ty = convergeOffsets[i] ? convergeOffsets[i].y * ease : 0;
          card.style.transform = `translate(${tx}px, ${ty}px) scale(${1 - ease * 0.8}) rotate(${(i % 2 === 0 ? 1 : -1) * ease * 10}deg)`;
          card.style.opacity = String(Math.max(0, 1 - ease * 1.3));
          const icon = card.querySelector<HTMLElement>('.cf-card-icon');
          if (icon) {
            const gc = getComputedStyle(card).getPropertyValue('--card-glow').trim();
            icon.style.filter = `drop-shadow(0 ${18 - ease * 10}px ${24 + ease * 30}px ${gc}60) drop-shadow(0 6px 8px rgba(0,0,0,${0.12 + ease * 0.2}))`;
          }
        });

        const ctaP = Math.max(0, (p2 - 0.5) * 2);
        cta!.style.opacity = String(ctaP);
        cta!.style.transform = `translate(-50%,-50%) scale(${0.8 + ctaP * 0.2})`;
        cta!.style.pointerEvents = ctaP > 0.5 ? 'auto' : 'none';
        return;
      }

      // From here on: bg fully dark, cards hidden
      if (bgLayer) bgLayer.style.opacity = '1';
      if (glowCenter) { glowCenter.style.opacity = '0.85'; glowCenter.style.transform = 'translate(-50%,-50%) scale(1)'; }
      heading!.style.opacity = '0';
      cards.forEach(c => { c.style.opacity = '0'; });

      // ── Phase 3: 0.30–0.42 → CTA hold ──
      if (progress < 0.42) {
        cta!.style.opacity = '1';
        cta!.style.transform = 'translate(-50%,-50%) scale(1)';
        cta!.style.pointerEvents = 'auto';
        hideSSPanel();
        return;
      }

      // ── Phase 4: 0.42–0.50 → CTA out, SS header in ──
      if (progress < 0.50) {
        const t = (progress - 0.42) / 0.08;
        cta!.style.opacity = String(1 - t);
        cta!.style.transform = `translate(-50%,-50%) scale(${1 - t * 0.1})`;
        cta!.style.pointerEvents = 'none';

        if (ssPanel) { ssPanel.style.opacity = String(t); ssPanel.style.pointerEvents = t > 0.5 ? 'auto' : 'none'; }
        if (ssHeader) { ssHeader.style.opacity = String(t); ssHeader.style.transform = `translateY(${(1 - t) * 20}px)`; }
        resetSSRows();
        return;
      }

      // ── Phase 5: 0.50–0.90 → SS rows scroll-driven ──
      cta!.style.opacity = '0';
      cta!.style.pointerEvents = 'none';
      if (ssPanel) { ssPanel.style.opacity = '1'; ssPanel.style.pointerEvents = 'auto'; }
      if (ssHeader) { ssHeader.style.opacity = '1'; ssHeader.style.transform = 'translateY(0)'; }

      const ROW_START = 0.50;
      const ROW_END = 0.90;
      const rowRange = (ROW_END - ROW_START) / rowData.length;

      rowData.forEach((d, i) => {
        const rStart = ROW_START + i * rowRange;
        const rp = Math.max(0, Math.min(1, (progress - rStart) / rowRange));

        // Left card: 0–0.25 of row range
        const lp = easeOut(Math.max(0, Math.min(1, rp / 0.25)));
        if (d.left) {
          d.left.style.opacity = String(lp);
          d.left.style.transform = `translateX(${-30 * (1 - lp)}px)`;
          if (lp > 0.9) d.left.classList.add('visible');
          else d.left.classList.remove('visible');
        }

        // Connector line + dot: 0.20–0.60
        const cp = easeOut(Math.max(0, Math.min(1, (rp - 0.20) / 0.40)));
        if (!isMobile && d.path && d.dot && d.totalLen > 0) {
          (d.path as SVGElement).style.opacity = cp > 0 ? '1' : '0';
          (d.path as SVGElement).style.strokeDasharray = String(d.totalLen);
          (d.path as SVGElement).style.strokeDashoffset = String(d.totalLen * (1 - cp));
          if (cp > 0 && cp < 1) {
            (d.dot as SVGElement).style.opacity = '1';
            const pt = d.path.getPointAtLength(cp * d.totalLen);
            d.dot.setAttribute('cx', String(pt.x));
            d.dot.setAttribute('cy', String(pt.y));
          } else {
            (d.dot as SVGElement).style.opacity = '0';
          }
        }

        // Right card: 0.55–0.80
        const rrp = easeOut(Math.max(0, Math.min(1, (rp - 0.55) / 0.25)));
        if (d.right) {
          d.right.style.opacity = String(rrp);
          d.right.style.transform = `translateX(${30 * (1 - rrp)}px)`;
          d.right.style.borderLeft = rrp > 0.5 ? '3px solid var(--row-color)' : '1px solid #E5E8EB';
        }

        // Check pop: 0.80–1.0
        const ckp = easeOut(Math.max(0, Math.min(1, (rp - 0.80) / 0.20)));
        if (d.check) { (d.check as SVGElement).style.opacity = String(ckp); (d.check as SVGElement).style.transform = `scale(${ckp})`; }
        if (d.checkMobile) { d.checkMobile.style.opacity = String(ckp); d.checkMobile.style.transform = `scale(${ckp})`; }
      });

      // ── Phase 6: 0.90–1.0 → Completion badge ──
      if (progress > 0.90) {
        const cp = easeOut(Math.max(0, Math.min(1, (progress - 0.90) / 0.07)));
        const blurV = 8 * (1 - cp);
        if (ssComplete) {
          ssComplete.style.opacity = String(cp);
          ssComplete.style.transform = `translateY(${20 * (1 - cp)}px) scale(${0.7 + 0.3 * cp})`;
          ssComplete.style.filter = `blur(${blurV}px)`;
          if (cp > 0.95) ssComplete.classList.add('visible');
          else ssComplete.classList.remove('visible');
        }
      } else {
        if (ssComplete) { ssComplete.style.opacity = '0'; ssComplete.style.transform = 'translateY(20px) scale(0.7)'; ssComplete.style.filter = 'blur(8px)'; ssComplete.classList.remove('visible'); }
      }
    }

    function onScrollWrapped() {
      onScroll();
    }

    function checkCompletion() {
      const rect = section!.getBoundingClientRect();
      const vh = window.innerHeight;
      const scrollable = rect.height - vh;
      if (scrollable <= 0) return;
      const progress = Math.max(0, Math.min(1, -rect.top / scrollable));
      // Allow scroll in both directions
    }

    window.addEventListener('scroll', () => {
      onScrollWrapped();
      checkCompletion();
    }, { passive: true });
    window.addEventListener('resize', () => { convergeOffsets = []; }, { passive: true });
    onScroll();
  })();
</script>
