---
import BaseLayout from '../layouts/BaseLayout.astro';
import SlideShow from '../components/ui/SlideShow.tsx';
import MultiSlide from '../components/ui/MultiSlide.tsx';
import HoverComponent from '../components/ui/HoverComponent.astro';
---

<BaseLayout
  title="SafeD - 스마트 안전관리 시스템 | 건설현장 안전관리의 새로운 기준"
  description="SafeD는 건설현장 스마트 안전관리 시스템입니다. 위험성평가, GPS 모니터링, 비콘 기술로 중대재해를 예방합니다."
  keywords="SafeD, 스마트안전관리, 건설현장안전, 중대재해처벌법, 위험성평가, 안전관리시스템, 건설안전, 산업안전"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SafeD - 스마트안전관리시스템",
    "url": "https://www.safed.co.kr",
    "description": "건설현장 안전관리의 새로운 기준을 제시하는 스마트 안전관리 시스템",
    "publisher": {
      "@type": "Organization",
      "name": "세이프디 주식회사"
    }
  }}
>
  <!-- Hero Slide -->
  <SlideShow
    client:load
    slides={[
      {
        image: '/images/mainslide01.jpg',
        title: '건설현장 안전관리의\n새로운 기준을 제시합니다',
        subtitle: 'SafeD는 스마트 기술을 활용한 건설현장 안전관리 솔루션입니다.',
        link: '/safed-features',
      },
      {
        image: '/images/mainslide02.jpg',
        title: '중대재해처벌법 대응\n체계적인 안전관리',
        subtitle: '안전보건관리체계 구축부터 위험성평가까지 한번에 해결합니다.',
        link: '/business-background',
      },
      {
        image: '/images/mainslide03.jpg',
        title: '스마트 안전관리\nContech Future Leader',
        subtitle: 'IoT, GPS, 빅데이터를 활용한 차세대 안전관리 플랫폼',
        link: '/inquiries',
      },
    ]}
  />

  <!-- Big Statement -->
  <section class="py-32 lg:py-40 bg-white">
    <div class="w-container max-w-5xl">
      <div class="text-center">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-6 reveal">About SafeD</p>
        <h2 class="hero-headline tracking-tight leading-tight reveal delay-100">
          현장의 생명을 지키는<br /><span class="text-gradient-blue">단 하나의 플랫폼.</span>
        </h2>
        <p class="text-gray-500 text-lg lg:text-xl leading-relaxed mt-8 max-w-2xl mx-auto reveal delay-200">
          건설현장, 플랜트, 제조시설, 유지보수 — 어디서든.<br class="hidden lg:block" />
          SafeD는 중대재해처벌법 대응부터 위험성평가, 실시간 모니터링까지<br class="hidden lg:block" />
          안전관리의 모든 것을 하나로 연결합니다.
        </p>
        <a href="/safed-features" class="inline-flex items-center gap-2 mt-10 text-primary font-semibold hover:gap-3 transition-all reveal delay-300">
          SafeD 자세히 알아보기
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Numbers Section -->
  <section class="py-24 bg-gray-950 text-white overflow-hidden">
    <div class="w-container">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Proven Results</p>
        <h2 class="sub-headline reveal delay-100">숫자가 증명하는 SafeD의 가치</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        {[
          { num: '25,000+', label: '표준위험공종 데이터', sub: '업계 최다 위험공종 DB 보유' },
          { num: '99.2%', label: '사고 예방률', sub: '도입 현장 기준' },
          { num: '150+', label: '도입 현장', sub: '국내 주요 건설사 파트너' },
          { num: '24/7', label: '실시간 모니터링', sub: 'GPS · Beacon · Push' },
        ].map((item, i) => (
          <div class={`text-center reveal delay-${(i + 1) * 100}`}>
            <p class="eng text-4xl lg:text-5xl font-extrabold text-gradient-blue counter-num mb-2">{item.num}</p>
            <p class="font-semibold text-white/90 mb-1">{item.label}</p>
            <p class="text-sm text-white/40">{item.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why SafeD - Problem/Solution -->
  <section class="py-28 bg-white">
    <div class="w-container max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Why SafeD?</p>
          <h2 class="sub-headline mb-6">
            사고는 반복됩니다.<br />
            <span class="text-primary">관리 방식이 바뀌어야 합니다.</span>
          </h2>
          <p class="text-gray-500 leading-relaxed mb-8">
            서류 중심의 안전관리는 한계가 있습니다. SafeD는 모바일, GPS, 비콘, AI 번역을
            결합하여 현장에서 즉시 작동하는 안전관리 체계를 구축합니다.
            종이 한 장이 아닌, 기술로 생명을 지킵니다.
          </p>
          <div class="space-y-4">
            {[
              '위험성평가 작성 시간 70% 단축',
              '현장-본사 간 실시간 안전 데이터 공유',
              '다국적 근로자 언어 장벽 해소',
              '중대재해처벌법 의무이행 완벽 대응',
            ].map((text) => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-gray-700 text-sm font-medium">{text}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal-right delay-200">
          <div class="relative">
            <img src="/images/dboard.png" alt="SafeD 대시보드" class="rounded-2xl shadow-2xl glow" />
            <div class="absolute -bottom-6 -left-6 bg-primary text-white rounded-2xl px-6 py-4 shadow-lg">
              <p class="eng font-bold text-2xl">70%</p>
              <p class="text-xs opacity-80">업무 효율 향상</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Core Features -->
  <section class="py-24 bg-gray-50">
    <div class="w-container">
      <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 text-center reveal">Core Features</p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-16 text-center tracking-tight reveal delay-100">
        안전관리를 쉽고 간편하게!<br />SafeD 핵심기능
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '/images/safed_feature_01.png', title: '스마트 위험성평가', desc: '위험요인을 찾아 위험성의 크기를 평가하고 조치·검토할 수 있는 시스템', color: 'from-red-900/80 to-red-800/60' },
          { icon: '/images/safed_feature_02.png', title: '위험요소 제거', desc: '추가위험을 발굴하고 위험요소들을 사전에 제거합니다', color: 'from-green-900/80 to-green-800/60' },
          { icon: '/images/safed_feature_03.png', title: '다국어 지원', desc: '현장 별 다국적 근로자를 고려하여 Google AI 자동번역 기능 제공', color: 'from-lime-900/80 to-lime-800/60' },
          { icon: '/images/safed_feature_04.png', title: '안전 모니터링', desc: 'GPS를 통해 출역·작업위치·동선 등을 실시간으로 확인', color: 'from-blue-900/80 to-blue-800/60' },
          { icon: '/images/safed_feature_05.png', title: '비콘 경고', desc: '이동식 장비에 탈·부착 가능하며 접근경고로 작업자 안전 확보', color: 'from-cyan-900/80 to-cyan-800/60' },
          { icon: '/images/safed_feature_06.png', title: '커뮤니케이션', desc: 'SMS, Mobile Push 알람으로 오늘할일, 잔여과제 자동 발송', color: 'from-emerald-900/80 to-emerald-800/60' },
        ].map((feat, i) => (
          <div class={`group relative overflow-hidden rounded-2xl p-8 bg-gradient-to-br ${feat.color} text-white min-h-[220px] flex flex-col justify-end reveal delay-${(i % 3 + 1) * 100}`}>
            <img src={feat.icon} alt={feat.title} class="w-16 h-16 mb-4 object-contain opacity-90 group-hover:scale-110 transition-transform" />
            <h3 class="text-lg font-bold mb-2">{feat.title}</h3>
            <p class="text-sm opacity-80 leading-relaxed">{feat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Interactive Feature Demo -->
  <section class="py-24 bg-white">
    <div class="w-container">
      <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 text-center reveal">Key Functions</p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-12 text-center tracking-tight reveal delay-100">SafeD 주요 기능</h2>
      <div class="reveal delay-200">
        <HoverComponent items={[
          { label: '모바일 위험성평가', title: '스마트 위험성평가', text: '현장에서 모바일로 간편하게 위험성평가를 작성하고 관리할 수 있습니다.', image: '/images/feature01.jpg' },
          { label: 'BEACON 경고', title: '비콘 위험경고 시스템', text: '비콘 기술로 위험지역 접근 시 자동 알림을 발송합니다.', image: '/images/feature02.jpg' },
          { label: 'GPS 분석', title: 'GPS 동선 분석', text: 'GPS를 통한 근로자 위치 추적 및 동선 분석이 가능합니다.', image: '/images/feature04.jpg' },
          { label: '다국어 번역', title: '다국어 자동번역', text: '다국적 근로자를 위한 실시간 AI 자동번역 기능을 제공합니다.', image: '/images/feature05.jpg' },
        ]} />
      </div>
    </div>
  </section>

  <!-- Section 4: Voices from the Field -->
  <section class="py-24 bg-gray-50">
    <div class="w-container">
      <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 text-center reveal">Voices from the Field</p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-16 text-center tracking-tight reveal delay-100">현장의 목소리</h2>
      <div class="reveal delay-200">
        <MultiSlide
          client:visible
          slides={[
            { title: '현장소장', review: '위험성평가가 현장 안전에 최우선이 되는데, SafeD를 통해 파트너사의 위험성평가 내용이 더 세밀해졌습니다.', background: '#fdeee3' },
            { title: '안전관리자', review: 'SafeD 적용 후 위험성평가 항목 개선으로 위험요소를 세밀하게 검토하여 제거할 수 있었습니다.', background: '#eae2f0' },
            { title: '보건관리자', review: 'SafeD 앱을 통해 근로자와 소통하며 세심한 요구사항을 처리하고 있습니다.', background: '#e3f3fd' },
            { title: '관리감독자', review: 'SafeD 적용 후 모든 관리감독자가 체계적으로 안전활동을 할 수 있게 되었습니다.', background: '#fdeee3' },
            { title: '협력업체', review: '공종에 투입되는 작업에 대해 세밀하게 작성할 수 있어 편리합니다.', background: '#eae2f0' },
            { title: '근로자', review: '앱으로 간단히 사진을 찍고 전송하면 위험요소를 제거해주고 있습니다.', background: '#e3f3fd' },
          ]}
          slidesPerView={3}
          slideHeight="260px"
        />
      </div>
    </div>
  </section>

  <!-- Section: Trust Logos / Awards -->
  <section class="py-20 bg-white border-t border-gray-100">
    <div class="w-container">
      <div class="text-center mb-12">
        <p class="eng text-gray-400 text-sm tracking-widest uppercase font-semibold reveal">Trusted & Certified</p>
        <h2 class="text-2xl font-bold tracking-tight mt-3 reveal delay-100">특허 · 인증 · 수상</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center reveal delay-100">
          <div class="w-20 h-20 mx-auto mb-4 bg-primary/5 rounded-2xl flex items-center justify-center">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M12 15l-3 3 1-4-3-3h4L12 7l1 4h4l-3 3 1 4z"/><circle cx="12" cy="12" r="10"/></svg>
          </div>
          <p class="font-bold text-gray-800 mb-1">스마트건설대상 수상</p>
          <p class="text-sm text-gray-400">2021 안전대상 플랫폼 부문</p>
        </div>
        <div class="text-center reveal delay-200">
          <div class="w-20 h-20 mx-auto mb-4 bg-primary/5 rounded-2xl flex items-center justify-center">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <p class="font-bold text-gray-800 mb-1">특허 2건 보유</p>
          <p class="text-sm text-gray-400">안전관리 핵심 기술 특허</p>
        </div>
        <div class="text-center reveal delay-300">
          <div class="w-20 h-20 mx-auto mb-4 bg-primary/5 rounded-2xl flex items-center justify-center">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <p class="font-bold text-gray-800 mb-1">국내 유일 전문기업</p>
          <p class="text-sm text-gray-400">스마트안전관리 솔루션 개발사</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: How It Works -->
  <section class="py-28 bg-gray-50">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">How It Works</p>
        <h2 class="sub-headline reveal delay-100">도입은 간단합니다.</h2>
        <p class="text-gray-500 mt-4 reveal delay-200">3단계로 현장에 맞는 안전관리 체계를 구축합니다.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: '상담 & 컨설팅', desc: '현장 규모와 업종에 맞는 맞춤 안전관리 전략을 설계합니다. 무료 상담으로 시작하세요.', icon: '💬' },
          { step: '02', title: '시스템 구축', desc: '2~4주 내 SafeD 플랫폼을 현장에 세팅합니다. 교육부터 데이터 이관까지 원스톱 지원.', icon: '⚙️' },
          { step: '03', title: '운영 & 개선', desc: '실시간 대시보드로 안전 현황을 모니터링하고, 전담팀이 지속적으로 개선을 지원합니다.', icon: '📊' },
        ].map((item, i) => (
          <div class={`relative bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl transition-shadow reveal delay-${(i + 1) * 100}`}>
            <div class="flex items-center justify-between mb-6">
              <span class="text-5xl">{item.icon}</span>
              <span class="eng text-6xl font-extrabold text-gray-100">{item.step}</span>
            </div>
            <h3 class="text-xl font-bold mb-3 tracking-tight">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            {i < 2 && (
              <div class="hidden md:block absolute top-1/2 -right-5 transform -translate-y-1/2 z-10">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
      <div class="text-center mt-12 reveal delay-400">
        <a href="/inquiries" class="inline-flex items-center gap-2 px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition-colors">
          무료 상담 시작하기
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Section: Marquee -->
  <section class="py-8 bg-white overflow-hidden border-y border-gray-100">
    <div class="marquee-track">
      {Array.from({ length: 8 }).map(() => (
        <span class="eng text-5xl font-extrabold text-gray-100 mx-6 whitespace-nowrap select-none">
          Contech Future Leader ·
        </span>
      ))}
    </div>
  </section>

  <!-- Section 5: CTA -->
  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#2e4692] to-[#001f31]"></div>
    <div class="absolute inset-0 bg-[url('/images/feature02.jpg')] bg-cover bg-center bg-fixed opacity-20"></div>
    <div class="relative z-10 w-container">
      <div class="bg-white rounded-2xl p-12 lg:p-16 max-w-3xl mx-auto text-center shadow-2xl reveal-scale">
        <p class="eng text-gray-400 text-sm tracking-widest uppercase mb-4 font-semibold">Get Connected!</p>
        <h2 class="text-2xl lg:text-3xl font-bold mb-4 tracking-tight">
          SafeD와 함께 체계적인<br />건설현장을 만들어보세요!
        </h2>
        <p class="text-gray-500 mb-8 text-sm leading-relaxed max-w-md mx-auto">
          SafeD는 2022년 1월 중대재해처벌법 본격 시행에 이어<br />
          국내 다수 건설사에서 도입 중에 있습니다.
        </p>
        <a href="/inquiries" class="inline-flex items-center gap-2 px-8 py-3.5 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition-colors text-sm">
          상담문의
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
