---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '회사개요', url: '/company-overview' },
  { name: '인사말', url: '/welcome' },
  { name: '비전 및 미션', url: '/vision-mission' },
  { name: '오시는 길', url: '/location' },
];
---

<SubPageLayout
  title="비전 및 미션 - SafeD | 스마트안전관리시스템"
  pageTitle="비전 및 미션"
  pageTitleEn="Vision & Mission"
  description="SafeD의 비전과 미션 - 기술로 생명을 지키는 스마트안전관리 플랫폼"
  navLinks={navLinks}
>
  <!-- Vision Statement - Big Typography -->
  <section class="py-24 bg-white">
    <div class="w-container max-w-5xl">
      <div class="text-center reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-6">Our Vision</p>
        <h2 class="text-4xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-8">
          기술로 생명을 지키는<br />
          <span class="text-gradient-blue">안전관리의 새로운 기준.</span>
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mx-auto">
          SafeD는 건설현장에서 한 명의 사망자도 나오지 않는 세상을 만듭니다.<br />
          서류가 아닌 시스템으로, 사후 대응이 아닌 사전 예방으로.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Cards - Full Width -->
  <section class="py-24 bg-gray-50">
    <div class="w-container max-w-6xl">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">Our Mission</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">우리가 매일 실행하는 미션</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            num: '01',
            title: '사고 제로 달성',
            desc: '50,000개 위험요인 DB와 실시간 모니터링으로 현장의 모든 위험을 사전에 차단합니다. 형식적인 안전관리가 아닌, 실제로 작동하는 안전 시스템을 구축합니다.',
            iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
            iconColor: '#ef4444',
            stat: '99.2%',
            statLabel: '사고 예방률',
          },
          {
            num: '02',
            title: '디지털 전환 가속',
            desc: 'GPS·비콘·AI 번역·자동 알림을 하나의 플랫폼에 통합합니다. 종이와 엑셀에 의존하는 구시대적 관리를 끝내고, 데이터 기반 스마트 안전관리로 전환합니다.',
            iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
            iconColor: '#3b82f6',
            stat: '80%',
            statLabel: '업무 효율 향상',
          },
          {
            num: '03',
            title: '모두의 안전 참여',
            desc: '원청·협력업체·관리자·근로자 모두가 참여하는 안전관리 생태계를 만듭니다. 19개국어 지원으로 언어 장벽도 해소합니다.',
            iconPath: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75M8.5 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
            iconColor: '#16a34a',
            stat: '19개국어',
            statLabel: 'AI 자동번역',
          },
        ].map((item, i) => (
          <div class={`bg-white rounded-3xl p-8 lg:p-10 shadow-sm hover:shadow-xl transition-all group reveal delay-${(i + 1) * 100}`}>
            <div class="flex items-center justify-between mb-8">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform" style={`background: ${item.iconColor}12`}>
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke={item.iconColor} stroke-width="1.5"><path d={item.iconPath}/></svg>
              </div>
              <span class="eng text-5xl font-extrabold text-gray-100 group-hover:text-gray-200 transition-colors">{item.num}</span>
            </div>
            <h3 class="text-xl font-bold mb-4 tracking-tight">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6">{item.desc}</p>
            <div class="pt-4 border-t border-gray-100">
              <div class="flex items-baseline gap-2">
                <span class="eng text-2xl font-extrabold text-gradient-blue">{item.stat}</span>
                <span class="text-xs text-gray-400 font-medium">{item.statLabel}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core Values - Horizontal Scroll Effect -->
  <section class="py-24 bg-gray-950 text-white relative overflow-hidden">
    <!-- Wave bars -->
    <div class="absolute bottom-0 left-0 right-0 flex items-end gap-[2px] h-14 opacity-15 px-4" aria-hidden="true">
      {Array.from({length: 70}).map((_, i) => {
        const h = 20 + Math.sin(i * 0.5) * 22 + Math.sin(i * 1.1) * 12;
        const dur = (0.5 + Math.sin(i * 0.4) * 0.3).toFixed(2);
        const del = (i * 0.03).toFixed(2);
        return (
          <div class="flex-1 rounded-t-sm" style={`height: ${h}%; background: linear-gradient(to top, rgba(0,123,255,0.5), rgba(0,198,255,0.15)); animation: wave-bar ${dur}s ease-in-out infinite alternate; animation-delay: ${del}s;`}></div>
        );
      })}
    </div>
    <div class="w-container max-w-5xl relative z-10">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Core Values</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">SafeD를 움직이는 가치</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { title: '생명 최우선', desc: '모든 결정의 기준은 현장 근로자의 생명입니다.', icon: '❤️' },
          { title: '기술 혁신', desc: 'IoT·AI·빅데이터로 안전의 패러다임을 바꿉니다.', icon: '⚡' },
          { title: '현장 중심', desc: '사무실이 아닌 현장에서 바로 작동해야 합니다.', icon: '🏗️' },
          { title: '함께 성장', desc: '원청부터 근로자까지 모두의 안전에 기여합니다.', icon: '🤝' },
        ].map((item, i) => (
          <div class={`bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-all reveal delay-${(i + 1) * 100}`}>
            <p class="text-3xl mb-4">{item.icon}</p>
            <h3 class="font-bold text-white/90 mb-2">{item.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Vision Roadmap -->
  <section class="py-24 bg-white">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">Roadmap</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">SafeD가 그리는 미래</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            phase: 'Phase 1',
            year: '2020-2023',
            title: '플랫폼 구축',
            items: ['스마트 위험성평가 시스템 개발', '50,000개 위험요인 DB 구축', 'GPS·비콘 모니터링 기술 확보', '150+ 현장 도입 달성'],
            color: '#3b82f6',
            status: '완료',
          },
          {
            phase: 'Phase 2',
            year: '2024-2025',
            title: '기술 고도화',
            items: ['19개국어 AI 자동번역 도입', '빅데이터 기반 사고 예측 모델', '대시보드 실시간 모니터링 강화', '전국 현장 확대 적용'],
            color: '#8b5cf6',
            status: '진행 중',
          },
          {
            phase: 'Phase 3',
            year: '2026-',
            title: 'AI 안전관리',
            items: ['AI 자동 위험 감지 & 경고', 'IoT 센서 통합 안전 네트워크', '글로벌 시장 진출 (동남아)', '산업 전 분야 확대'],
            color: '#16a34a',
            status: '계획',
          },
        ].map((item, i) => (
          <div class={`relative reveal delay-${(i + 1) * 100}`}>
            <div class="bg-gray-50 rounded-3xl p-8 h-full">
              <div class="flex items-center gap-3 mb-6">
                <span class="eng text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full" style={`background: ${item.color}12; color: ${item.color}`}>{item.phase}</span>
                <span class="eng text-xs text-gray-400 font-medium">{item.year}</span>
              </div>
              <h3 class="text-xl font-bold mb-1 tracking-tight">{item.title}</h3>
              <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full mb-4" style={`background: ${item.color}12; color: ${item.color}`}>{item.status}</span>
              <ul class="space-y-3">
                {item.items.map((text) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke={item.color} stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{text}</span>
                  </li>
                ))}
              </ul>
            </div>
            {i < 2 && (
              <div class="hidden md:block absolute top-1/2 -right-5 transform -translate-y-1/2 z-10">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Impact Numbers -->
  <section class="py-20 bg-gray-50">
    <div class="w-container max-w-4xl">
      <div class="text-center mb-14">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">Impact</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight reveal delay-100">비전을 향한 성과</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { num: '150+', label: '도입 현장', desc: '전국' },
          { num: '50,000', label: '위험요인 DB', desc: '업계 최다' },
          { num: '99.2%', label: '사고 예방률', desc: '도입 후' },
          { num: '2건', label: '특허 보유', desc: '핵심 기술' },
        ].map((item, i) => (
          <div class={`text-center reveal delay-${(i + 1) * 100}`}>
            <p class="eng text-3xl lg:text-4xl font-extrabold text-gradient-blue mb-1">{item.num}</p>
            <p class="font-semibold text-sm mb-0.5">{item.label}</p>
            <p class="text-xs text-gray-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="w-container reveal">
      <h2 class="text-2xl font-bold mb-4 tracking-tight">SafeD의 비전에 함께 하세요</h2>
      <p class="opacity-80 mb-8 text-sm">현장의 안전을 바꾸는 여정, 지금 시작하세요</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/inquiries" class="inline-flex items-center gap-2 px-8 py-3 bg-white text-primary rounded-full font-semibold hover:bg-gray-100 transition-colors text-sm">
          무료 상담받기
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/safed-features" class="inline-flex items-center gap-2 px-8 py-3 border border-white/30 text-white rounded-full font-semibold hover:bg-white/10 transition-colors text-sm">
          SafeD 기능 살펴보기
        </a>
      </div>
    </div>
  </section>
</SubPageLayout>

<style>
  @keyframes wave-bar {
    0% { transform: scaleY(0.3); }
    100% { transform: scaleY(1); }
  }
</style>
