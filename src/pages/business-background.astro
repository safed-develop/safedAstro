---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '사업배경', url: '/business-background' },
  { name: 'SafeD Development', url: '/safed-features' },
];
---

<SubPageLayout
  title="사업배경 - SafeD | 스마트안전관리시스템"
  pageTitle="사업배경"
  pageTitleEn="Business Background"
  description="중대재해처벌법 대응을 위한 SafeD 안전관리 솔루션. 안전보건관리체계 구축 및 이행을 지원합니다."
  keywords="중대재해처벌법, 안전보건관리체계, 중대재해예방, 경영책임자의무, SafeD, 안전관리솔루션"
  navLinks={navLinks}
>
  <!-- Hero: Shocking Stats -->
  <section class="relative py-28 bg-gray-950 text-white overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/danger_bg.jpg')] bg-cover bg-center opacity-15"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-gray-950/60 via-gray-950/80 to-gray-950"></div>
    <div class="w-container max-w-5xl relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-red-400">Serious Accident Punishment Act</p>
          <h2 class="text-3xl lg:text-5xl font-extrabold tracking-tight leading-[1.1] mb-6">
            매년 <span class="text-red-400">400명</span>이<br />건설현장에서 사망합니다.
          </h2>
          <p class="text-white/50 leading-relaxed mb-8">
            반복되는 중대재해, '사고 공화국'이라는 부끄러운 오명.<br />
            중대재해처벌법은 이 악순환의 고리를 끊기 위해 제정되었습니다.
          </p>
          <div class="inline-flex items-center gap-2 bg-red-500/10 border border-red-500/20 rounded-full px-5 py-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span class="text-red-400 text-sm font-semibold">2024.1.27부터 5인 이상 사업장 전면 적용</span>
          </div>
        </div>
        <!-- Right: Stat cards -->
        <div class="reveal-right delay-200">
          <div class="grid grid-cols-1 gap-4">
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 flex items-center gap-6">
              <div class="w-16 h-16 rounded-2xl bg-red-500/20 flex items-center justify-center flex-shrink-0">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <div>
                <p class="eng text-3xl font-extrabold text-red-400">401건</p>
                <p class="text-white/50 text-sm">2024년 건설업 사망사고</p>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-5 text-center">
                <p class="eng text-2xl font-extrabold text-amber-400">1년+</p>
                <p class="text-white/40 text-xs mt-1">징역 (사망사고)</p>
              </div>
              <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-5 text-center">
                <p class="eng text-2xl font-extrabold text-amber-400">50억</p>
                <p class="text-white/40 text-xs mt-1">법인 최대 벌금</p>
              </div>
            </div>
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 flex items-center gap-6">
              <div class="w-16 h-16 rounded-2xl bg-primary/20 flex items-center justify-center flex-shrink-0">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <p class="text-lg font-bold text-white/90">SafeD로 완벽 대비</p>
                <p class="text-white/50 text-sm">4대 의무사항 100% 시스템 매핑</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 중대재해 기준 - Visual Infographic -->
  <section class="py-24 bg-white">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Definition</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight">중대재해란?</h2>
        <p class="text-gray-500 mt-3">다음 중 하나에 해당하면 '중대산업재해'로 분류됩니다.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        {[
          { num: '1명', label: '사망', desc: '이상 발생', color: '#ef4444', iconPath: 'M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01' },
          { num: '10명', label: '부상', desc: '이상 (2개월+ 치료)', color: '#f59e0b', iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2' },
          { num: '10명', label: '질병', desc: '이상 (3개월+ 치료)', color: '#8b5cf6', iconPath: 'M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3.332.88-4.5 2.23A6.65 6.65 0 0 0 7.5 3 5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7 7-7z' },
        ].map((item, i) => (
          <div class={`relative overflow-hidden rounded-3xl p-8 text-center reveal delay-${(i + 1) * 100}`} style={`background: linear-gradient(135deg, ${item.color}08, ${item.color}03);`}>
            <div class="absolute top-4 right-4 opacity-[0.06]">
              <svg width="80" height="80" viewBox="0 0 24 24" fill={item.color} stroke="none"><path d={item.iconPath}/></svg>
            </div>
            <div class="relative z-10">
              <div class="w-16 h-16 rounded-2xl mx-auto mb-4 flex items-center justify-center" style={`background: ${item.color}15`}>
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke={item.color} stroke-width="1.5"><path d={item.iconPath}/></svg>
              </div>
              <p class="eng text-5xl font-extrabold mb-1" style={`color: ${item.color}`}>{item.num}</p>
              <p class="font-bold text-lg text-gray-800">{item.label}</p>
              <p class="text-sm text-gray-400 mt-1">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Visual flow: 법 제정 배경 -->
      <div class="bg-gray-50 rounded-3xl p-8 lg:p-10 reveal delay-200">
        <h3 class="font-bold text-lg mb-6 text-center">법 제정 배경</h3>
        <div class="flex flex-col md:flex-row items-center gap-4 md:gap-2">
          {[
            { text: '안전법령 개편에도\n중대재해 반복', icon: '🔄' },
            { text: '현장 안전조치 위주\n규정의 한계', icon: '📋' },
            { text: '경영책임자에게\n안전확보 의무 부과', icon: '⚖️' },
            { text: '안전관리체계\n구축 의무화', icon: '🏗️' },
          ].map((item, i) => (
            <>
              <div class="flex-1 bg-white rounded-2xl p-5 text-center shadow-sm min-w-0">
                <p class="text-2xl mb-2">{item.icon}</p>
                <p class="text-sm text-gray-600 font-medium whitespace-pre-line leading-relaxed">{item.text}</p>
              </div>
              {i < 3 && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="2" class="flex-shrink-0 hidden md:block"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              )}
            </>
          ))}
        </div>
        <p class="text-xs text-gray-400 text-center mt-6">
          적용 대상: 상시근로자 5명 이상 사업장 (건설업: 공사금액 50억원 미만은 '24.1.27부터)
        </p>
      </div>
    </div>
  </section>

  <!-- 도입 필요성 - Visual Split -->
  <section class="py-24 bg-gray-950 text-white relative overflow-hidden">
    <div class="absolute bottom-0 left-0 right-0 flex items-end gap-[2px] h-14 opacity-15 px-4" aria-hidden="true">
      {Array.from({length: 70}).map((_, i) => {
        const h = 20 + Math.sin(i * 0.5) * 22 + Math.sin(i * 1.1) * 12;
        const dur = (0.5 + Math.sin(i * 0.4) * 0.3).toFixed(2);
        const del = (i * 0.03).toFixed(2);
        return (
          <div class="flex-1 rounded-t-sm" style={`height: ${h}%; background: linear-gradient(to top, rgba(0,123,255,0.6), rgba(0,198,255,0.15)); animation: wave-bar ${dur}s ease-in-out infinite alternate; animation-delay: ${del}s;`}></div>
        );
      })}
    </div>
    <div class="w-container max-w-5xl relative z-10">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Why We Need It</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">왜 시스템이 필요한가?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 외부 요인 -->
        <div class="reveal">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <h3 class="text-xl font-bold">외부 요인</h3>
          </div>
          <div class="space-y-3">
            {[
              { title: '법령 강화', desc: '중대재해처벌법 전면 시행, 경영책임자 직접 처벌', pct: 100 },
              { title: '처벌 수위', desc: '사망사고 시 1년 이상 징역, 10억 이하 벌금', pct: 90 },
              { title: '적용 확대', desc: '상시근로자 5명 이상 모든 사업장으로 확대', pct: 80 },
            ].map((item) => (
              <div class="bg-white/5 border border-white/10 rounded-xl p-5">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <div>
                    <p class="font-semibold text-sm text-white/90">{item.title}</p>
                    <p class="text-xs text-white/40 mt-1">{item.desc}</p>
                  </div>
                  <span class="eng text-sm font-bold text-red-400 flex-shrink-0">{item.pct}%</span>
                </div>
                <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-red-500 to-red-400 rounded-full" style={`width: ${item.pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <!-- 내부 요인 -->
        <div class="reveal delay-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-xl font-bold">내부 요인</h3>
          </div>
          <div class="space-y-3">
            {[
              { title: '관리 포인트 증가', desc: '위험성평가, 안전교육 등 교육·작성·기록·보관 비효율', pct: 95 },
              { title: '현장 복잡도', desc: '협력사, 근로자 수, 외국인 근로자 대응 필요', pct: 85 },
              { title: 'DB·분석 부재', desc: '현장별 안전 데이터 취합/분석/모니터링 체계 부재', pct: 90 },
            ].map((item) => (
              <div class="bg-white/5 border border-white/10 rounded-xl p-5">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <div>
                    <p class="font-semibold text-sm text-white/90">{item.title}</p>
                    <p class="text-xs text-white/40 mt-1">{item.desc}</p>
                  </div>
                  <span class="eng text-sm font-bold text-primary flex-shrink-0">{item.pct}%</span>
                </div>
                <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-primary to-blue-400 rounded-full" style={`width: ${item.pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- 대응 방향 flow -->
      <div class="mt-12 reveal delay-300">
        <div class="flex flex-col md:flex-row items-stretch gap-3">
          {[
            { label: '사고예방', desc: '안전 프로세스 확립', color: 'rgba(239,68,68,0.15)', border: 'rgba(239,68,68,0.3)' },
            { label: '안전활동', desc: '위험성평가 이행·검증', color: 'rgba(245,158,11,0.15)', border: 'rgba(245,158,11,0.3)' },
            { label: '사후대응', desc: '근거자료 기록·보관', color: 'rgba(59,130,246,0.15)', border: 'rgba(59,130,246,0.3)' },
            { label: 'SafeD', desc: '스마트 안전관리 시스템', color: 'rgba(0,123,255,0.3)', border: 'rgba(0,123,255,0.6)' },
          ].map((item, i) => (
            <>
              <div class="flex-1 rounded-xl p-4 text-center" style={`background: ${item.color}; border: 1px solid ${item.border};`}>
                <p class="eng text-xs uppercase font-bold mb-1" style={`color: ${item.border}`}>{item.label}</p>
                <p class="text-xs text-white/60">{item.desc}</p>
              </div>
              {i < 3 && (
                <div class="flex items-center justify-center flex-shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2" class="hidden md:block"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              )}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 위험성평가 = 법적 의무 - Visual Diagram -->
  <section class="py-24 bg-white">
    <div class="w-container max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Article 4, Paragraph 3</p>
          <h2 class="text-3xl lg:text-4xl font-bold tracking-tight leading-tight mb-6">
            위험성평가 이행 =<br/><span class="text-gradient-blue">법적 의무 충족.</span>
          </h2>
          <div class="bg-gray-50 border-l-4 border-primary rounded-xl p-5 mb-6">
            <p class="text-sm text-gray-600 leading-relaxed">
              유해·위험요인을 확인하여 개선하는 업무절차를 마련하고,
              <strong class="text-gray-800">반기 1회 이상 점검</strong>한 후 필요한 조치를 할 것.
            </p>
          </div>
          <div class="bg-primary/5 rounded-xl p-5 border border-primary/10">
            <div class="flex items-start gap-3">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <p class="text-sm text-gray-700 leading-relaxed">
                <strong class="text-primary">위험성평가를 실시</strong>하고 결과를 보고받은 경우,
                유해·위험요인의 확인 및 개선에 대한 점검을 한 것으로 <strong>간주</strong>합니다.
              </p>
            </div>
          </div>
        </div>
        <!-- Right: Visual mapping -->
        <div class="reveal-right delay-200">
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-br from-primary/5 to-transparent rounded-3xl -z-10"></div>
            <div class="space-y-4">
              <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                  </div>
                  <p class="font-bold text-sm text-red-600">AS-IS: 기존 방식</p>
                </div>
                <div class="space-y-2">
                  {['서류 기반 위험성평가', '엑셀 수기 관리', '근거자료 부재'].map((t) => (
                    <div class="flex items-center gap-2 text-sm text-gray-400">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                      <span class="line-through">{t}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div class="flex justify-center">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </div>
              <div class="bg-primary/5 rounded-2xl p-6 border-2 border-primary/20 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  </div>
                  <p class="font-bold text-sm text-primary">TO-BE: SafeD 도입</p>
                </div>
                <div class="space-y-2">
                  {['시스템 기반 위험성평가 (50,000 DB)', '실시간 모니터링·자동 알림', '근거자료 자동 생성·보관'].map((t) => (
                    <div class="flex items-center gap-2 text-sm text-gray-700">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                      <span class="font-medium">{t}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4대 의무사항 - Connected Flow -->
  <section class="py-24 bg-gray-50">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">Key Obligations</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">4대 의무사항 × SafeD 대응</h2>
        <p class="text-gray-500 mt-3 reveal delay-200">경영책임자가 이행해야 할 4대 의무를 SafeD가 시스템으로 해결합니다.</p>
      </div>

      <div class="space-y-6">
        {[
          { num: '01', title: '안전보건관리체계 구축·이행', desc: '재해 예방에 필요한 인력 및 예산 등 안전보건관리체계의 구축 및 이행', safed: '위험성평가, 점검활동, DB 시스템 구축', image: '/images/safed_feature_01.png', color: '#ef4444' },
