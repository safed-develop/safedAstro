<style>
  @keyframes wave-bar {
    0% { transform: scaleY(0.3); }
    100% { transform: scaleY(1); }
  }

  .impact-bar {
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .impact-pct {
    transition: opacity 0.5s ease;
  }

  .impact-summary {
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
</style>

<script>
  function initImpactBars() {
    const wrap = document.querySelector('.impact-chart-wrap');
    if (!wrap) return;

    let animated = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !animated) {
          animated = true;

          const rows = wrap.querySelectorAll('.impact-bar-row');
          rows.forEach((row, i) => {
            setTimeout(() => {
              const bars = row.querySelectorAll('.impact-bar') as NodeListOf<HTMLElement>;
              bars.forEach((bar) => {
                const target = bar.getAttribute('data-target-width');
                if (target) bar.style.width = target;
              });

              const pct = row.querySelector('.impact-pct') as HTMLElement;
              if (pct) pct.style.opacity = '1';
            }, i * 300);
          });

          // Show summary after all bars
          setTimeout(() => {
            const summary = wrap.querySelector('.impact-summary') as HTMLElement;
            if (summary) {
              summary.style.opacity = '1';
              summary.style.transform = 'translateY(0)';
            }
          }, rows.length * 300 + 600);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(wrap);
  }

  document.addEventListener('DOMContentLoaded', initImpactBars);
  document.addEventListener('astro:page-load', initImpactBars);
</script>
