---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '사업배경', url: '/business-background' },
  { name: 'SafeD Development', url: '/safed-features' },
];
---

<SubPageLayout
  title="사업배경 - SafeD | 스마트안전관리시스템"
  pageTitle="사업배경"
  pageTitleEn="Business Background"
  description="중대재해처벌법 대응을 위한 SafeD 안전관리 솔루션. 안전보건관리체계 구축 및 이행을 지원합니다."
  keywords="중대재해처벌법, 안전보건관리체계, 중대재해예방, 경영책임자의무, SafeD, 안전관리솔루션"
  navLinks={navLinks}
>
  <!-- Section 1 -->
  <section class="py-20">
    <div class="w-container max-w-4xl">
      <div class="text-center reveal">
        <h2 class="text-3xl lg:text-4xl font-bold mb-6 tracking-tight">중대재해처벌법이란?</h2>
        <p class="text-gray-600 leading-relaxed text-lg">
          반복되는 재해 사망사고와 악순환 '사고 공화국'이라는 부끄러운 오명을 이제
          그 고리를 끊어내야 합니다. 작은 관심이 소중한 생명을 살리고 더 안전한 사회를
          만듭니다.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6 reveal delay-200">
        {[
          { num: '1명', label: '사망', desc: '이상' },
          { num: '10명', label: '부상', desc: '이상 (2개월 이상 치료)' },
          { num: '10명', label: '질병', desc: '이상 (3개월 이상 치료)' },
        ].map((item) => (
          <div class="bg-primary/5 rounded-2xl p-6 text-center">
            <p class="text-4xl font-bold text-primary eng mb-2">{item.num}</p>
            <p class="font-semibold text-gray-800 mb-1">{item.label}</p>
            <p class="text-sm text-gray-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 도입 필요성 - 외부/내부 요인 -->
  <section class="py-24 bg-gray-950 text-white">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Why We Need It</p>
        <h2 class="sub-headline reveal delay-100">도입 필요성</h2>
        <p class="text-white/50 mt-4 reveal delay-200">'24년 중대재해특별법 전면 시행에 따라 체계적인 시스템 구축이 필요합니다.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 외부 요인 -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 reveal">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <h3 class="text-xl font-bold">외부 요인</h3>
          </div>
          <div class="space-y-4">
            {[
              { title: '법령 강화', desc: '중대재해처벌법 전면 시행, 경영책임자 직접 처벌' },
              { title: '처벌 수위', desc: '사망사고 시 1년 이상 징역, 10억 이하 벌금' },
              { title: '적용 확대', desc: '상시근로자 5명 이상 모든 사업장으로 확대' },
            ].map((item) => (
              <div class="bg-white/5 rounded-xl p-4">
                <p class="font-semibold text-sm text-white/90 mb-1">{item.title}</p>
                <p class="text-sm text-white/50">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
        <!-- 내부 요인 -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 reveal delay-200">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="text-xl font-bold">내부 요인</h3>
          </div>
          <div class="space-y-4">
            {[
              { title: '관리 포인트 증가', desc: '위험성평가, 안전교육 등 교육·작성·기록·보관 비효율 증가' },
              { title: '현장 복잡도', desc: '협력사(수), 근로자(수), 외국인 근로자 대응 필요' },
              { title: 'DB·분석 필요', desc: '현장별 안전 데이터 취합/분석/모니터링 체계 부재' },
            ].map((item) => (
              <div class="bg-white/5 rounded-xl p-4">
                <p class="font-semibold text-sm text-white/90 mb-1">{item.title}</p>
                <p class="text-sm text-white/50">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- 대응 방향 -->
      <div class="mt-8 bg-primary/10 border border-primary/30 rounded-2xl p-6 text-center reveal delay-300">
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8">
          <div class="text-center">
            <p class="text-xs text-white/40 eng uppercase">사고예방</p>
            <p class="text-sm text-white/80">현장 안전 프로세스 확립</p>
          </div>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2" class="hidden md:block"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          <div class="text-center">
            <p class="text-xs text-white/40 eng uppercase">안전활동</p>
            <p class="text-sm text-white/80">위험성평가 엄수·이행·검증</p>
          </div>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2" class="hidden md:block"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          <div class="text-center">
            <p class="text-xs text-white/40 eng uppercase">사후대응</p>
            <p class="text-sm text-white/80">근거 마련 (기록/보관)</p>
          </div>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#007BFF" stroke-width="2" class="hidden md:block"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          <div class="bg-primary rounded-xl px-4 py-2">
            <p class="text-xs eng uppercase font-semibold">SMART</p>
            <p class="text-sm font-bold">안전관리 시스템</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: 법 제정 목적 -->
  <section class="py-20 bg-gray-50 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/danger_bg.jpg')] bg-cover bg-center opacity-10"></div>
    <div class="relative z-10 w-container max-w-4xl">
      <h2 class="text-3xl font-bold mb-8 text-center tracking-tight reveal">법 제정 목적</h2>
      <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-8 lg:p-12 reveal delay-100">
        <ul class="space-y-4">
          {[
            '다양한 안전·보건 관계 법령 및 제도 개편에도 불구하고 중대재해 반복 발생',
            '종전 안전·보건 관계법령은 대부분 현장의 안전조치 위주로 규정하여 중대재해 예방에 한계 존재',
            '경영책임자등에게 안전·보건 확보 의무를 부과',
            '기업/기관이 중대재해 예방을 위한 안전·보건관리체계 구축 유도',
          ].map((text) => (
            <li class="flex items-start gap-3 text-gray-700 leading-relaxed">
              <div class="w-2 h-2 rounded-full bg-primary mt-2 flex-shrink-0"></div>
              <span>{text}</span>
            </li>
          ))}
        </ul>
        <p class="mt-8 text-sm text-gray-500 border-t pt-6">
          적용 대상: 상시근로자 5명 이상인 사업 또는 사업장
          (건설업은 공사금액 50억원 미만의 공사는 24.1.27부터 적용)
        </p>
      </div>
    </div>
  </section>

  <!-- 제4조 3항 - 위험성평가 -->
  <section class="py-20">
    <div class="w-container max-w-4xl">
      <div class="text-center mb-12 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Article 4-3</p>
        <h2 class="text-3xl font-bold tracking-tight">위험성평가 = 법적 의무 이행</h2>
      </div>
      <div class="bg-gray-50 border-l-4 border-primary rounded-2xl p-8 lg:p-10 reveal delay-100">
        <p class="text-sm text-primary font-semibold mb-3 eng">제4조 3항</p>
        <p class="text-gray-700 leading-relaxed text-sm mb-4">
          사업 또는 사업장의 특성에 따른 유해·위험요인을 확인하여 개선하는 업무절차를 마련하고,
          해당 업무절차에 따라 유해·위험요인의 확인 및 개선이 이루어지는지를 <strong>반기 1회 이상 점검</strong>한 후 필요한 조치를 할 것.
        </p>
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <p class="text-primary font-bold text-sm mb-2">핵심 포인트</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            「산업안전보건법」 제36조에 따른 <strong class="text-primary">위험성평가</strong>를 하는 절차를 마련하고,
            그 절차에 따라 위험성평가를 직접 실시하거나 실시하도록 하여 실시 결과를 보고받은 경우에는
            <strong>유해·위험요인의 확인 및 개선에 대한 점검을 한 것으로 봅니다.</strong>
          </p>
        </div>
        <div class="mt-6 bg-primary/5 rounded-xl p-4 text-center">
          <p class="text-primary font-bold text-sm">즉, '위험성평가' 이행 = '유해·위험요인 확인 및 개선에 대한 점검'으로 간주!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Key Obligations -->
  <section class="py-20 bg-gray-50">
    <div class="w-container max-w-4xl">
      <h2 class="text-3xl font-bold mb-8 text-center tracking-tight reveal">주요의무사항</h2>
      <p class="text-gray-600 text-center mb-12 reveal delay-100">
        사업주 또는 경영책임자 등은 종사자의 안전·보건상 유해 또는 위험을 방지하기 위해
        다음의 조치를 취해야 합니다.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { num: '01', title: '안전보건관리체계', desc: '재해 예방에 필요한 인력 및 예산 등 안전보건관리체계의 구축 및 이행', safed: '위험성평가, DB 시스템, 점검활동' },
          { num: '02', title: '재발방지 대책', desc: '재해 발생 시 재발방지 대책의 수립 및 이행', safed: '사고사례 DB, 데이터 분석, 사례 공유' },
          { num: '03', title: '개선·시정 명령', desc: '관계 법령에 따라 개선, 시정 등을 명한 사항의 이행', safed: '자동 알림, 조치 추적, 실시간 모니터링' },
          { num: '04', title: '관리상 조치', desc: '안전·보건 관계 법령에 따른 의무이행에 필요한 관리상의 조치', safed: '대시보드, 보고서 자동생성, 근거자료 보관' },
        ].map((item, i) => (
          <div class={`bg-white border border-gray-100 rounded-2xl p-6 reveal delay-${(i + 1) * 100}`}>
            <span class="text-primary eng font-bold text-2xl opacity-30">{item.num}</span>
            <h3 class="font-bold text-lg mt-2 mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-3">{item.desc}</p>
            <div class="bg-primary/5 rounded-lg px-3 py-2">
              <p class="text-xs text-primary font-semibold">SafeD 대응: {item.safed}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 현장·본사 니즈 -->
  <section class="py-24">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">Needs Analysis</p>
        <h2 class="sub-headline reveal delay-100">현장과 본사의 요구사항</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reveal">
          <div class="bg-orange-50 border border-orange-200 rounded-2xl p-8">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">🏗️</span>
              <h3 class="text-xl font-bold">현장 Needs</h3>
            </div>
            <div class="space-y-4">
              {[
                { num: '#1', title: '위험성평가 프로세스 체계화', items: ['최초/정기/수시/일일 위험성평가', '데이터 기반 위험요인 매칭'] },
                { num: '#2', title: '안전관리체계 강화', items: ['위험성평가, 안전교육 관리 포인트 증가', '협력사·근로자·외국인 대응'] },
                { num: '#3', title: 'DB·분석·모니터링', items: ['각 현장 안전활동 Database', '취합/분석/모니터링 체계'] },
              ].map((need) => (
                <div class="bg-white rounded-xl p-4">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-bold text-orange-600 eng">{need.num}</span>
                    <p class="font-semibold text-sm">{need.title}</p>
                  </div>
                  <ul class="space-y-1">
                    {need.items.map((item) => (
                      <li class="text-xs text-gray-500 flex items-start gap-2">
                        <span class="text-orange-400">•</span>{item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="reveal delay-200">
          <div class="bg-blue-50 border border-blue-200 rounded-2xl p-8">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">🏢</span>
              <h3 class="text-xl font-bold">본사 Needs</h3>
            </div>
            <div class="space-y-4">
              {[
                { num: '#1', title: '전 현장 통합 모니터링', items: ['현장별 이행률 실시간 비교', '안전활동 KPI 대시보드'] },
                { num: '#2', title: '법적 근거자료 확보', items: ['의무이행 증빙 자동 생성', '보고서 자동 출력·보관'] },
                { num: '#3', title: '표준 안전관리 프로세스', items: ['전 현장 동일 프로세스 적용', '공종 DB·교육자료·가이드 제공'] },
              ].map((need) => (
                <div class="bg-white rounded-xl p-4">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-bold text-blue-600 eng">{need.num}</span>
                    <p class="font-semibold text-sm">{need.title}</p>
                  </div>
                  <ul class="space-y-1">
                    {need.items.map((item) => (
                      <li class="text-xs text-gray-500 flex items-start gap-2">
                        <span class="text-blue-400">•</span>{item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SafeD 안전보건관리체계 매핑 -->
  <section class="py-24 bg-gray-50">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">SafeD Solution</p>
        <h2 class="sub-headline reveal delay-100">안전보건관리체계를 SafeD로 구축</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal delay-200">
        {[
          { icon: '📋', title: '시스템 기반 위험성평가', items: ['300+ 공종, 50,000+ 위험요인 DB', '최초/정기/수시/일일 평가 지원', '가능성·중대성 자동 점수 산출'] },
          { icon: '📊', title: 'Database 구축', items: ['260종 3만여 Case 탑재', '공종별 위험요인·안전대책 자동 매칭', '사고사례 DB 공유·학습'] },
          { icon: '📝', title: 'TBM·점검일지·안전교육', items: ['PC+모바일 동시 작성', '참석자 서명·문자 인증', '교육일지 자동 생성'] },
          { icon: '📑', title: '작업계획서·허가서', items: ['사전 양식 빠른 작성', '결재선 승인 프로세스', '고위험작업 PTW 관리'] },
          { icon: '📡', title: '비콘+GPS 센싱', items: ['위험지역 접근 경고', 'GPS 출역·동선 추적', '비용 90% 절감 비콘'] },
          { icon: '🌏', title: '다국어 번역', items: ['Google AI 19개국어 지원', '모국어 자동 번역 + 음성 안내', '외국인 근로자 완전 참여'] },
        ].map((item) => (
          <div class="bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-lg transition-shadow">
            <p class="text-3xl mb-3">{item.icon}</p>
            <h3 class="font-bold mb-3">{item.title}</h3>
            <ul class="space-y-2">
              {item.items.map((text) => (
                <li class="text-xs text-gray-500 flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {text}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 도입 효과 비교 -->
  <section class="py-24">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-16">
