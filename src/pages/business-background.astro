---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '사업배경', url: '/business-background' },
  { name: 'SafeD Development', url: '/safed-features' },
];
---

<SubPageLayout
  title="사업배경 - SafeD | 스마트안전관리시스템"
  pageTitle="사업배경"
  pageTitleEn="Business Background"
  description="중대재해처벌법 대응을 위한 SafeD 안전관리 솔루션. 안전보건관리체계 구축 및 이행을 지원합니다."
  keywords="중대재해처벌법, 안전보건관리체계, 중대재해예방, 경영책임자의무, SafeD, 안전관리솔루션"
  navLinks={navLinks}
>
  <!-- ═══ HERO ═══ -->
  <section class="relative bg-[#1C1C1E] text-white overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/danger_bg.jpg')] bg-cover bg-center grayscale contrast-[1.08] opacity-25"></div>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute top-1/2 left-[15%] -translate-y-1/2 w-[180px] h-[180px] rounded-full border-[1.5px] border-white/[0.08] pointer-events-none hidden lg:block"></div>

    <div class="w-container max-w-5xl relative z-10 py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase mb-6 text-[#6B6B6B]">Serious Accident Punishment Act</p>
          <h2 class="text-3xl lg:text-[44px] font-bold tracking-tight leading-[1.15] mb-6">
            매년 <span class="text-[#2563EB]">400명</span>이<br/>건설현장에서 사망합니다.
          </h2>
          <p class="text-white/50 text-sm leading-relaxed mb-10">
            반복되는 중대재해, '사고 공화국'이라는 부끄러운 오명.<br/>
            중대재해처벌법은 이 악순환의 고리를 끊기 위해 제정되었습니다.
          </p>
          <div class="inline-flex items-center gap-2.5 border border-white/10 px-5 py-2.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span class="text-white/60 text-sm">2024.1.27부터 5인 이상 사업장 전면 적용</span>
          </div>
        </div>

        <div class="reveal-right delay-200">
          <div class="divide-y divide-white/10 border border-white/10">
            <div class="p-6 flex items-center gap-6">
              <div class="w-14 h-14 border border-[#2563EB]/30 flex items-center justify-center flex-shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <div>
                <p class="eng text-3xl font-bold text-[#2563EB]">401건</p>
                <p class="text-white/40 text-sm">2024년 건설업 사망사고</p>
              </div>
            </div>
            <div class="grid grid-cols-2 divide-x divide-white/10">
              <div class="p-5 text-center">
                <p class="eng text-2xl font-bold">1년+</p>
                <p class="text-white/40 text-xs mt-1">징역 (사망사고)</p>
              </div>
              <div class="p-5 text-center">
                <p class="eng text-2xl font-bold">50억</p>
                <p class="text-white/40 text-xs mt-1">법인 최대 벌금</p>
              </div>
            </div>
            <div class="p-6 flex items-center gap-6">
              <div class="w-14 h-14 border border-[#2563EB]/30 flex items-center justify-center flex-shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <p class="text-lg font-bold">SafeD로 완벽 대비</p>
                <p class="text-white/40 text-sm">4대 의무사항 100% 시스템 매핑</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 01. 중대재해란? ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0 reveal">
        <div class="lg:col-span-4 lg:pr-8">
          <span class="eng text-[80px] lg:text-[120px] font-bold leading-none text-[#2563EB] block -mb-2">01</span>
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2 mt-4">Definition</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111]">중대재해란?</h2>
          <p class="text-[#6B6B6B] text-sm mt-3 leading-relaxed">
            다음 중 하나에 해당하면 <strong class="text-[#111]">'중대산업재해'</strong>로 분류됩니다.
          </p>
          <div class="mt-6 border border-[#E0E0E0] p-4 text-xs text-[#6B6B6B] leading-relaxed">
            <p class="font-bold text-[#111] mb-1.5">관련 법률</p>
            <p>중대재해 처벌 등에 관한 법률 <span class="eng">제2조 제2호</span></p>
            <div class="border-t border-[#E0E0E0] mt-3 pt-3">
              <p class="font-semibold text-[#3A3A3A] mb-1">적용 대상</p>
              <p>상시근로자 <strong class="eng text-[#111]">5명</strong> 이상 사업장</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-8 lg:border-l lg:border-[#E0E0E0] lg:pl-8">
          <div class="grid grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0] mb-6">
            {[
              { num: '1명', label: '사망', desc: '이상 발생', iconPath: 'M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01' },
              { num: '10명', label: '부상', desc: '2개월+ 치료', iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2' },
              { num: '10명', label: '질병', desc: '3개월+ 치료', iconPath: 'M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3.332.88-4.5 2.23A6.65 6.65 0 0 0 7.5 3 5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7 7-7z' },
            ].map((item) => (
              <div class="bg-white p-5 text-center">
                <div class="flex items-center justify-center gap-2 mb-3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d={item.iconPath}/></svg>
                  <span class="font-semibold text-sm text-[#111]">{item.label}</span>
                </div>
                <p class="eng text-3xl font-bold text-[#2563EB]">{item.num}</p>
                <p class="text-xs text-[#6B6B6B] mt-1">{item.desc}</p>
              </div>
            ))}
          </div>

          <div class="border border-[#E0E0E0] p-5">
            <div class="flex items-center gap-2 mb-4">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              <h3 class="font-bold text-sm text-[#111]">법 제정 배경</h3>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-[1px] bg-[#E0E0E0]">
              {[
                { text: '안전법령 개편에도 중대재해 반복', sub: '산안법 한계' },
                { text: '현장 안전조치 위주 규정의 한계', sub: '구조적 문제' },
                { text: '경영책임자에게 안전확보 의무 부과', sub: '책임 강화' },
                { text: '안전관리체계 구축 의무화', sub: '시스템 전환' },
              ].map((item) => (
                <div class="bg-white p-3 text-center">
                  <p class="text-xs text-[#3A3A3A] font-medium leading-snug">{item.text}</p>
                  <p class="text-[10px] text-[#6B6B6B] mt-1 eng font-medium">{item.sub}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 02. 도입 필요성 ═══ -->
  <section class="bg-[#1C1C1E] text-white">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="lg:col-span-4 lg:pr-8 reveal">
          <span class="eng text-[80px] lg:text-[120px] font-bold leading-none text-[#2563EB] block -mb-2">02</span>
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2 mt-4">Why We Need It</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight leading-tight">왜 시스템이<br/>필요한가?</h2>
          <p class="text-white/40 text-sm mt-3 leading-relaxed">중대재해처벌법 대응과 현장 안전관리 효율화, 두 가지 과제를 동시에 해결합니다.</p>
        </div>

        <div class="lg:col-span-8 lg:border-l lg:border-white/10 lg:pl-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="reveal">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-9 h-9 border border-white/20 flex items-center justify-center">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <h3 class="font-bold">외부 요인</h3>
              </div>
              <div class="divide-y divide-white/10 border border-white/10">
                {[
                  { title: '법령 강화', desc: '중대재해처벌법 전면 시행, 경영책임자 직접 처벌' },
                  { title: '처벌 수위', desc: '사망사고 시 1년 이상 징역, 10억 이하 벌금' },
                  { title: '적용 확대', desc: '상시근로자 5명 이상 모든 사업장으로 확대' },
                ].map((item) => (
                  <div class="p-4">
                    <p class="font-semibold text-sm mb-1">{item.title}</p>
                    <p class="text-xs text-white/40">{item.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="reveal delay-200">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-9 h-9 border border-white/20 flex items-center justify-center">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3 class="font-bold">내부 요인</h3>
              </div>
              <div class="divide-y divide-white/10 border border-white/10">
                {[
                  { title: '관리 포인트 증가', desc: '위험성평가, 안전교육 등 교육·작성·기록·보관 비효율' },
                  { title: '현장 복잡도', desc: '협력사, 근로자 수, 외국인 근로자 대응 필요' },
                  { title: 'DB·분석 부재', desc: '현장별 안전 데이터 취합/분석/모니터링 체계 부재' },
                ].map((item) => (
                  <div class="p-4">
                    <p class="font-semibold text-sm mb-1">{item.title}</p>
                    <p class="text-xs text-white/40">{item.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="mt-8 reveal delay-300">
            <div class="grid grid-cols-4 gap-[1px] bg-white/10">
              {[
                { label: '사고예방', desc: '안전 프로세스 확립' },
                { label: '안전활동', desc: '위험성평가 이행·검증' },
                { label: '사후대응', desc: '근거자료 기록·보관' },
                { label: 'SafeD', desc: '스마트 안전관리 시스템' },
              ].map((item, i) => (
                <div class={`p-4 text-center ${i === 3 ? 'bg-[#2563EB]/15' : 'bg-[#1C1C1E]'}`}>
                  <p class={`eng text-xs uppercase font-bold mb-1 ${i === 3 ? 'text-[#2563EB]' : 'text-white/60'}`}>{item.label}</p>
                  <p class="text-xs text-white/40">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 03. 위험성평가 = 법적 의무 ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="lg:col-span-4 lg:pr-8 reveal">
          <span class="eng text-[80px] lg:text-[120px] font-bold leading-none text-[#2563EB] block -mb-2">03</span>
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2 mt-4">Article 4, Paragraph 3</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight leading-tight text-[#111]">
            위험성평가 이행 =<br/><span class="text-[#2563EB]">법적 의무 충족.</span>
          </h2>
          <div class="mt-6 border-l-2 border-[#2563EB] pl-4">
            <p class="text-sm text-[#3A3A3A] leading-relaxed">
              유해·위험요인을 확인하여 개선하는 업무절차를 마련하고,
              <strong class="text-[#111]">반기 1회 이상 점검</strong>한 후 필요한 조치를 할 것.
            </p>
          </div>
          <div class="mt-4 border border-[#E0E0E0] p-4">
            <div class="flex items-start gap-2.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" class="flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
              <p class="text-sm text-[#3A3A3A] leading-relaxed">
                <strong class="text-[#2563EB]">위험성평가를 실시</strong>하고 결과를 보고받은 경우,
                유해·위험요인의 확인 및 개선에 대한 점검을 한 것으로 <strong>간주</strong>합니다.
              </p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-8 lg:border-l lg:border-[#E0E0E0] lg:pl-8 reveal-right delay-200">
          <div class="space-y-4">
            <div class="border border-[#E0E0E0] p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 border border-[#E0E0E0] flex items-center justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B6B6B" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                </div>
                <p class="font-bold text-sm text-[#6B6B6B]">AS-IS: 기존 방식</p>
              </div>
              <div class="space-y-2">
                {['서류 기반 위험성평가', '엑셀 수기 관리', '근거자료 부재'].map((t) => (
                  <div class="flex items-center gap-2 text-sm text-[#6B6B6B]">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B6B6B" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    <span class="line-through">{t}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="flex justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
            </div>

            <div class="border-2 border-[#2563EB]/30 p-6 bg-[#2563EB]/[0.03]">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 border border-[#2563EB]/30 flex items-center justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <p class="font-bold text-sm text-[#2563EB]">TO-BE: SafeD 도입</p>
              </div>
              <div class="space-y-2">
                {['시스템 기반 위험성평가 (50,000 DB)', '실시간 모니터링·자동 알림', '근거자료 자동 생성·보관'].map((t) => (
                  <div class="flex items-center gap-2 text-sm text-[#111]">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="font-medium">{t}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 04. 4대 의무사항 ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-5xl py-20 lg:py-24">
      <div class="mb-12 reveal">
        <span class="eng text-[80px] lg:text-[120px] font-bold leading-none text-[#2563EB] block -mb-2">04</span>
        <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2 mt-4">Key Obligations</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111]">4대 의무사항 × SafeD 대응</h2>
        <p class="text-[#6B6B6B] text-sm mt-3">경영책임자가 이행해야 할 4대 의무를 SafeD가 시스템으로 해결합니다.</p>
      </div>

      <div class="space-y-[1px] bg-[#E0E0E0] border border-[#E0E0E0]">
        {[
          { num: '01', title: '안전보건관리체계 구축·이행', desc: '재해 예방에 필요한 인력 및 예산 등 안전보건관리체계의 구축 및 이행', safed: '위험성평가, 점검활동, DB 시스템 구축', image: '/images/safed_feature_01.png' },
          { num: '02', title: '재발방지 대책 수립·이행', desc: '재해 발생 시 재발방지 대책의 수립 및 이행', safed: '사고사례 DB, 현장 안전 데이터 분석, 사례 공유', image: '/images/safed_feature_02.png' },
          { num: '03', title: '개선·시정 명령 이행', desc: '관계 법령에 따라 개선, 시정 등을 명한 사항의 이행', safed: '자동 알림, 조치 추적, 실시간 모니터링', image: '/images/safed_feature_04.png' },
