---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '회사개요', url: '/company-overview' },
  { name: '인사말', url: '/welcome' },
  { name: '비전 및 미션', url: '/vision-mission' },
  { name: '오시는 길', url: '/location' },
];
---

<SubPageLayout
  title="오시는 길 - SafeD | 스마트안전관리시스템"
  pageTitle="오시는 길"
  pageTitleEn="Location"
  description="세이프디 주식회사 오시는 길 안내"
  navLinks={navLinks}
>
  <section class="py-20">
    <div class="w-container">
      <div class="mb-12 pb-6 border-b border-[#E0E0E0] reveal">
        <p class="text-[#2563EB] eng font-semibold text-sm tracking-widest uppercase mb-4">Welcome, SafeD</p>
        <h2 class="text-2xl font-bold mb-2 tracking-tight text-[#111]">세이프디 오시는 길을 안내드립니다</h2>
        <p class="text-[#6B6B6B]">서울 강남구 테헤란로 534, 21층 (대치동, 글라스타워) 세이프디 주식회사</p>
      </div>

      <!-- Naver Map -->
      <div class="w-full h-[400px] lg:h-[500px] bg-[#F5F5F5] border border-[#E0E0E0] mb-8 overflow-hidden reveal delay-100" id="map">
        <p class="text-[#6B6B6B] flex items-center justify-center h-full">지도 로딩 중...</p>
      </div>

      <!-- Map buttons -->
      <div class="flex gap-3 mb-16 reveal delay-200">
        <a href="https://place.map.kakao.com/m/8224697" target="_blank" rel="noopener noreferrer"
           class="px-6 py-2.5 bg-[#ffbd09] text-gray-900 font-semibold text-sm hover:opacity-90 transition-opacity">
          카카오 지도
        </a>
        <a href="https://map.naver.com/p/entry/place/12368833" target="_blank" rel="noopener noreferrer"
           class="px-6 py-2.5 bg-[#03c75a] text-white font-semibold text-sm hover:opacity-90 transition-opacity">
          네이버 지도
        </a>
      </div>

      <!-- Contact Info -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0]">
        <div class="flex items-start gap-4 bg-white p-6 reveal delay-100">
          <div class="w-12 h-12 bg-[#F5F5F5] flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-[#111] mb-1">전화</p>
            <p class="text-[#6B6B6B] text-sm">02-6748-0836</p>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-white p-6 reveal delay-200">
          <div class="w-12 h-12 bg-[#F5F5F5] flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-[#111] mb-1">이메일</p>
            <a href="mailto:sales@safed.co.kr" class="text-[#6B6B6B] text-sm hover:text-[#2563EB] transition-colors">sales@safed.co.kr</a>
          </div>
        </div>

        <div class="flex items-start gap-4 bg-white p-6 reveal delay-300">
          <div class="w-12 h-12 bg-[#F5F5F5] flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-[#111] mb-1">교통편</p>
            <p class="text-[#6B6B6B] text-sm">2호선 삼성역 3번 출구 글라스타워</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline src="https://openapi.map.naver.com/openapi/v3/maps.js?ncpClientId=wae3aemm99"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof naver === 'undefined') return;

      var mapDiv = document.getElementById('map');
      if (!mapDiv) return;

      mapDiv.innerHTML = '';

      var map = new naver.maps.Map(mapDiv, {
        center: new naver.maps.LatLng(37.5080512, 127.0628172),
        zoom: 17,
        zoomControl: true,
        zoomControlOptions: {
          position: naver.maps.Position.TOP_RIGHT
        }
      });

      new naver.maps.Marker({
        position: new naver.maps.LatLng(37.5080512, 127.0628172),
        map: map,
        icon: {
          content: '<img src="/images/mapMarker.png" alt="SafeD" style="width:45px;display:block;">',
          size: new naver.maps.Size(38, 58),
          anchor: new naver.maps.Point(22, 58)
        }
      });
    });
  </script>
</SubPageLayout>
