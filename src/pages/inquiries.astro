---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import ContactForm from '../components/ui/ContactForm';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '상담문의', url: '/inquiries' },
  { name: 'FAQ', url: '/faq' },
];
---

<SubPageLayout
  title="상담문의 - SafeD | 스마트안전관리시스템"
  pageTitle="상담문의"
  pageTitleEn="Contact Us"
  description="SafeD 도입 상담 및 문의. 건설현장 안전관리 시스템 도입을 위한 무료 상담을 받아보세요."
  keywords="SafeD문의, 안전관리시스템도입, 건설안전상담, SafeD견적"
  navLinks={navLinks}
>
  <!-- Trust indicators -->
  <section class="py-5 bg-[#F5F5F5] border-b border-[#E0E0E0]">
    <div class="w-container">
      <div class="flex items-center justify-center gap-8 flex-wrap">
        {[
          { num: '150+', label: '도입 현장', iconPath: 'M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5' },
          { num: '24h', label: '내 빠른 응답', iconPath: 'M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z' },
          { num: '무료', label: '초기 상담', iconPath: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z' },
        ].map((item) => (
          <div class="flex items-center gap-2.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" class="opacity-50"><path d={item.iconPath}/></svg>
            <span class="eng font-bold text-[#2563EB] text-sm">{item.num}</span>
            <span class="text-[#6B6B6B] text-sm">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 lg:py-14">
    <div class="w-container max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-8">
        <!-- Left: Info (2/5) -->
        <div class="lg:col-span-2 reveal">
          <p class="text-[#2563EB] eng font-semibold text-xs tracking-widest uppercase mb-1.5">Get in Touch</p>
          <h2 class="text-xl lg:text-2xl font-bold mb-2 tracking-tight leading-tight text-[#111]">SafeD 도입을 위한<br />상담을 신청하세요</h2>
          <p class="text-[#6B6B6B] leading-relaxed mb-4 text-sm">
            담당자가 <strong class="text-[#111]">24시간 내</strong> 연락드립니다.
          </p>

          <!-- Contact cards -->
          <div class="space-y-2 mb-4">
            <a href="tel:02-6748-0835" class="flex items-center gap-3 p-3 bg-[#F5F5F5] border border-[#E0E0E0] hover:bg-[#2563EB]/5 transition-colors">
              <div class="w-9 h-9 bg-white border border-[#E0E0E0] flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[#111] text-xs">전화 문의</p>
                <p class="text-[#6B6B6B] text-xs eng">02-6748-0835 / 0836</p>
              </div>
            </a>

            <a href="mailto:sales@safed.co.kr" class="flex items-center gap-3 p-3 bg-[#F5F5F5] border border-[#E0E0E0] hover:bg-[#2563EB]/5 transition-colors">
              <div class="w-9 h-9 bg-white border border-[#E0E0E0] flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[#111] text-xs">이메일</p>
                <p class="text-[#6B6B6B] text-xs eng">sales@safed.co.kr</p>
              </div>
            </a>

            <div class="flex items-center gap-3 p-3 bg-[#F5F5F5] border border-[#E0E0E0]">
              <div class="w-9 h-9 bg-white border border-[#E0E0E0] flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[#111] text-xs">방문 상담</p>
                <p class="text-[#6B6B6B] text-xs">서울시 강남구 테헤란로 534, 21층</p>
              </div>
            </div>
          </div>

          <!-- Response time badge -->
          <div class="bg-[#2563EB]/5 border border-[#2563EB]/10 p-3 text-center">
            <p class="text-[11px] text-[#2563EB] font-semibold">평균 응답 시간</p>
            <p class="eng text-xl font-extrabold text-[#2563EB] mt-0.5">4<span class="text-xs font-medium ml-0.5">시간</span></p>
          </div>
        </div>

        <!-- Right: Form (3/5) -->
        <div class="lg:col-span-3 reveal delay-200">
          <div class="bg-[#F5F5F5] border border-[#E0E0E0] p-5 lg:p-6">
            <div class="mb-3">
              <h3 class="font-bold text-base text-[#111]">상담 신청서</h3>
              <p class="text-xs text-[#6B6B6B] mt-0.5">아래 양식을 작성해 주시면 빠르게 안내드리겠습니다.</p>
            </div>
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</SubPageLayout>
