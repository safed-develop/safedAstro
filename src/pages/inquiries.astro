---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import ContactForm from '../components/ui/ContactForm';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '상담문의', url: '/inquiries' },
];
---

<SubPageLayout
  title="상담문의 - SafeD | 스마트안전관리시스템"
  pageTitle="상담문의"
  pageTitleEn="Contact Us"
  description="SafeD 도입 상담 및 문의 - 스마트안전관리시스템"
  navLinks={navLinks}
>
  <section class="py-20">
    <div class="w-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left: Info -->
        <div class="reveal">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Get in Touch</p>
          <h2 class="text-3xl font-bold mb-6 tracking-tight">SafeD 도입을 위한<br />상담을 신청해 주세요</h2>
          <p class="text-gray-500 leading-relaxed mb-10">
            SafeD 도입에 관심이 있으시다면 아래 양식을 작성해 주세요.<br />
            담당자가 빠르게 연락드리겠습니다.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-800 mb-1">전화 문의</p>
                <p class="text-gray-500 text-sm">02-6748-0835 / 02-6748-0836</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-800 mb-1">이메일</p>
                <a href="mailto:sales@safed.co.kr" class="text-gray-500 text-sm hover:text-primary transition-colors">sales@safed.co.kr</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="reveal delay-200">
          <div class="bg-gray-50 rounded-2xl p-8 lg:p-10">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee -->
  <section class="py-12 overflow-hidden border-t border-gray-100">
    <div class="animate-marquee whitespace-nowrap">
      <span class="eng text-4xl font-bold text-gray-100 mx-8">Contech Future Leader</span>
      <span class="eng text-4xl font-bold text-gray-100 mx-8">Contech Future Leader</span>
      <span class="eng text-4xl font-bold text-gray-100 mx-8">Contech Future Leader</span>
      <span class="eng text-4xl font-bold text-gray-100 mx-8">Contech Future Leader</span>
      <span class="eng text-4xl font-bold text-gray-100 mx-8">Contech Future Leader</span>
      <span class="eng text-4xl font-bold text-gray-100 mx-8">Contech Future Leader</span>
    </div>
  </section>
</SubPageLayout>

<style>
  .animate-marquee {
    display: flex;
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
