---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import ParallaxImage from '../components/ui/ParallaxImage.astro';

const navLinks = [
  { name: '회사개요', url: '/company-overview' },
  { name: '인사말', url: '/welcome' },
  { name: '비전 및 미션', url: '/vision-mission' },
  { name: '오시는 길', url: '/location' },
];
---

<SubPageLayout
  title="회사개요 - SafeD | 스마트안전관리시스템"
  pageTitle="회사개요"
  pageTitleEn="About Us"
  description="세이프디 주식회사는 차별화된 기술력으로 스마트안전관리시스템을 개발하여 현장의 생명을 위험요소로부터 지키는 회사입니다."
  keywords="세이프디, SafeD, 회사소개, 스마트안전관리시스템, 건설안전기업, 안전관리솔루션"
  navLinks={navLinks}
>
  <!-- Company Intro - Split Layout with accent -->
  <section class="py-24 overflow-hidden">
    <div class="w-container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 reveal">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <p class="text-primary eng font-semibold text-sm tracking-widest uppercase">About SafeD</p>
          </div>
          <h2 class="text-4xl lg:text-5xl font-extrabold mb-6 tracking-tight leading-tight">
            안전을 기술로<br />완성하는 기업,<br />
            <span class="text-gradient-blue">SafeD</span>
          </h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            세이프디 주식회사는 차별화된 기술력으로 스마트안전관리시스템을 개발하여
            현장의 생명을 위험요소로부터 지키고, 고객의 풍요로운 삶과 행복한 미래를
            함께 만드는 회사입니다.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="eng text-2xl font-extrabold text-primary mb-1">150+</p>
              <p class="text-sm text-gray-500">도입 현장</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
              <p class="eng text-2xl font-extrabold text-primary mb-1">2건</p>
              <p class="text-sm text-gray-500">기술특허 보유</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 reveal-right delay-200">
          <div class="relative">
            <div class="absolute -top-4 -right-4 w-full h-full rounded-3xl bg-primary/5 -z-10"></div>
            <img src="/images/about_svg.svg" alt="SafeD 소개" class="w-full rounded-2xl" />
            <!-- Floating badge -->
            <div class="absolute -bottom-6 -left-4 bg-white rounded-2xl px-6 py-4 shadow-xl border border-gray-100">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div>
                  <p class="font-bold text-sm">국내 유일</p>
                  <p class="text-xs text-gray-400">스마트안전관리 전문기업</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values - Icon Grid -->
  <section class="py-24 bg-gray-950 text-white overflow-hidden relative">
    <!-- Wave bars decoration -->
    <div class="absolute bottom-0 left-0 right-0 flex items-end gap-[2px] h-12 opacity-15 px-4" aria-hidden="true">
      {Array.from({length: 60}).map((_, i) => {
        const h = 20 + Math.sin(i * 0.6) * 20 + Math.sin(i * 1.0) * 10;
        const dur = (0.5 + Math.sin(i * 0.5) * 0.3).toFixed(2);
        const del = (i * 0.03).toFixed(2);
        return (
          <div class="flex-1 rounded-t-sm" style={`height: ${h}%; background: linear-gradient(to top, rgba(0,123,255,0.5), rgba(0,198,255,0.15)); animation: wave-bar ${dur}s ease-in-out infinite alternate; animation-delay: ${del}s;`}></div>
        );
      })}
    </div>
    <div class="w-container relative z-10">
      <div class="text-center mb-16">
        <p class="eng font-semibold text-sm tracking-widest uppercase mb-4 text-primary reveal">Core Values</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">SafeD가 추구하는 핵심 가치</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Safety First -->
        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-all reveal delay-100 group">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-red-500/20 to-red-600/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Safety First</h3>
          <p class="text-white/50 text-sm leading-relaxed">현장 근로자의 생명과 안전을 최우선으로 생각합니다. 기술로 위험을 사전에 차단하고, 사고를 예방합니다.</p>
          <div class="mt-6 pt-4 border-t border-white/5">
            <div class="flex items-center gap-2 text-xs text-white/30">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              안전보건관리체계 구축
            </div>
          </div>
        </div>
        <!-- Innovation -->
        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-all reveal delay-200 group">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500/20 to-blue-600/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Innovation</h3>
          <p class="text-white/50 text-sm leading-relaxed">GPS, Beacon, AI 번역, 빅데이터 분석 등 최첨단 기술을 안전관리에 접목하여 혁신적인 솔루션을 제공합니다.</p>
          <div class="mt-6 pt-4 border-t border-white/5">
            <div class="flex items-center gap-2 text-xs text-white/30">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2"/></svg>
              차별화된 기술력
            </div>
          </div>
        </div>
        <!-- Trust -->
        <div class="bg-white/5 border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-all reveal delay-300 group">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-500/20 to-amber-600/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.5"><path d="M12 15l-3 3 1-4-3-3h4L12 7l1 4h4l-3 3 1 4z"/><circle cx="12" cy="12" r="10"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Trust</h3>
          <p class="text-white/50 text-sm leading-relaxed">국내 150+ 현장에서 검증된 신뢰. 스마트건설대상 수상과 특허 보유로 기술력을 인정받았습니다.</p>
          <div class="mt-6 pt-4 border-t border-white/5">
            <div class="flex items-center gap-2 text-xs text-white/30">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15l-3 3 1-4-3-3h4L12 7l1 4h4l-3 3 1 4z"/></svg>
              스마트건설대상 수상
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do - Bento Grid -->
  <section class="py-24">
    <div class="w-container">
      <div class="text-center mb-16">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4 reveal">What We Do</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight reveal delay-100">SafeD가 하는 일</h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto reveal delay-200">건설현장의 안전관리를 디지털 기술로 혁신합니다</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Card 1: Large -->
        <div class="lg:col-span-2 bg-gradient-to-br from-blue-600 to-blue-800 rounded-3xl p-8 lg:p-10 text-white relative overflow-hidden reveal delay-100">
          <div class="absolute top-0 right-0 w-60 h-60 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center backdrop-blur">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              </div>
              <span class="eng text-xs font-semibold tracking-widest uppercase opacity-60">Platform</span>
            </div>
            <h3 class="text-2xl font-bold mb-3">스마트 안전관리 플랫폼</h3>
            <p class="text-white/70 text-sm leading-relaxed max-w-lg">
              위험성평가, 중점점검, 안전교육, TBM, 작업허가서 등 안전관리의 모든 업무를 하나의 플랫폼으로 통합합니다.
              PC와 모바일에서 실시간 연동되어 현장과 본사가 하나로 연결됩니다.
            </p>
            <div class="flex gap-3 mt-6">
              <span class="bg-white/10 backdrop-blur rounded-full px-3 py-1 text-xs">위험성평가</span>
              <span class="bg-white/10 backdrop-blur rounded-full px-3 py-1 text-xs">안전교육</span>
              <span class="bg-white/10 backdrop-blur rounded-full px-3 py-1 text-xs">TBM</span>
              <span class="bg-white/10 backdrop-blur rounded-full px-3 py-1 text-xs">보고서</span>
            </div>
          </div>
        </div>
        <!-- Card 2 -->
        <div class="bg-gray-50 rounded-3xl p-8 border border-gray-100 reveal delay-200 group hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">위험 사전 차단</h3>
          <p class="text-gray-500 text-sm leading-relaxed">50,000개 위험요인 DB를 기반으로 위험을 사전에 식별하고, 비콘 센서로 위험지역 접근 시 자동 경고합니다.</p>
        </div>
        <!-- Card 3 -->
        <div class="bg-gray-50 rounded-3xl p-8 border border-gray-100 reveal delay-100 group hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">다국어 소통</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Google AI 자동번역으로 19개 언어를 지원합니다. 다국적 근로자가 모국어로 안전교육을 받을 수 있습니다.</p>
        </div>
        <!-- Card 4 -->
        <div class="bg-gray-50 rounded-3xl p-8 border border-gray-100 reveal delay-200 group hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">GPS 모니터링</h3>
          <p class="text-gray-500 text-sm leading-relaxed">GPS로 근로자 위치와 동선을 실시간 추적합니다. 출역 관리부터 위험구역 진입 감지까지 자동화합니다.</p>
        </div>
        <!-- Card 5 -->
        <div class="bg-gray-50 rounded-3xl p-8 border border-gray-100 reveal delay-300 group hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3 class="text-lg font-bold mb-2">자동 보고서</h3>
          <p class="text-gray-500 text-sm leading-relaxed">대시보드에서 안전현황을 한눈에 파악하고, 법적 의무이행 근거자료를 자동으로 생성·보관합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Info Strip -->
  <section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="w-container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="reveal delay-100">
          <div class="flex items-center gap-3 mb-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            <p class="text-xs text-gray-400 eng font-semibold uppercase tracking-wider">Company</p>
          </div>
          <p class="font-bold text-lg">세이프디(주)</p>
          <p class="text-sm text-gray-400">SafeD Inc.</p>
        </div>
        <div class="reveal delay-200">
          <div class="flex items-center gap-3 mb-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/></svg>
            <p class="text-xs text-gray-400 eng font-semibold uppercase tracking-wider">Location</p>
          </div>
          <p class="font-bold text-lg">서울특별시</p>
          <p class="text-sm text-gray-400">구로구 디지털로31길</p>
        </div>
        <div class="reveal delay-300">
          <div class="flex items-center gap-3 mb-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.11 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <p class="text-xs text-gray-400 eng font-semibold uppercase tracking-wider">Contact</p>
          </div>
          <p class="font-bold text-lg">02-6956-5291</p>
          <p class="text-sm text-gray-400">평일 09:00~18:00</p>
        </div>
        <div class="reveal delay-400">
          <div class="flex items-center gap-3 mb-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <p class="text-xs text-gray-400 eng font-semibold uppercase tracking-wider">Email</p>
          </div>
          <p class="font-bold text-lg">safed@safed.co.kr</p>
          <p class="text-sm text-gray-400">문의 및 제안</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technology Stack - Horizontal Cards -->
  <section class="py-24 overflow-hidden">
    <div class="w-container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 reveal">
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Technology</p>
          <h2 class="text-3xl lg:text-4xl font-bold tracking-tight mb-6 leading-tight">
            차별화된 기술력으로<br />안전관리를 혁신합니다
          </h2>
          <p class="text-gray-500 leading-relaxed mb-8">
            SafeD는 최신 IT 기술을 안전관리에 접목하여 기존 서류 중심의 안전관리를
            디지털 기반의 체계적인 시스템으로 전환합니다.
          </p>
          <a href="/safed-features" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-full font-semibold text-sm hover:bg-primary-dark transition-colors">
            기능 자세히 보기
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="lg:col-span-7 space-y-4 reveal-right delay-200">
          <!-- Tech 1 -->
          <div class="flex items-center gap-5 bg-white rounded-2xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center flex-shrink-0">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="3"/><circle cx="12" cy="18" r="1"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <h4 class="font-bold mb-0.5">모바일 & 웹 플랫폼</h4>
              <p class="text-sm text-gray-400">Android, iOS 앱과 PC 웹을 실시간 연동. 현장에서 즉시 작성하고 본사에서 실시간 확인.</p>
            </div>
            <div class="flex gap-1 flex-shrink-0">
              <span class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="3"/></svg></span>
              <span class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/></svg></span>
            </div>
