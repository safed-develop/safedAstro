---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '상담문의', url: '/inquiries' },
];

const announcements = [
  {
    title: '2024 SafeD 홈페이지 리뉴얼',
    description: '2024 SafeD 홈페이지 리뉴얼 안내드립니다.',
    date: '2024.12.01',
  },
  {
    title: 'SafeD 시스템 점검 일정',
    description: '시스템 점검 일정 안내입니다.',
    date: '2024.11.15',
  },
];
---

<SubPageLayout
  title="공지사항 - SafeD | 스마트안전관리시스템"
  pageTitle="공지사항"
  pageTitleEn="Notices"
  description="SafeD 공지사항 - 스마트안전관리시스템 소식"
  navLinks={navLinks}
>
  <section class="py-20">
    <div class="w-container max-w-4xl">
      <div class="mb-12 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Notice Board</p>
        <h2 class="text-2xl font-bold tracking-tight">SafeD 소식을 알려드립니다</h2>
      </div>

      <div class="space-y-0 reveal delay-100">
        {announcements.length > 0 ? (
          announcements.map((item, i) => (
            <div class="flex items-center gap-6 py-6 border-b border-gray-100 hover:bg-gray-50 transition-colors px-4 -mx-4 rounded-lg">
              <span class="eng text-primary font-bold text-lg flex-shrink-0 w-12 text-center">{String(i + 1).padStart(2, '0')}</span>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-gray-800 mb-1 truncate">{item.title}</h3>
                <p class="text-sm text-gray-500 truncate">{item.description}</p>
              </div>
              <span class="text-sm text-gray-400 eng flex-shrink-0 hidden sm:block">{item.date}</span>
            </div>
          ))
        ) : (
          <div class="py-20 text-center text-gray-400">
            <p>등록된 공지사항이 없습니다.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</SubPageLayout>
