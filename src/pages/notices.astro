---
import SubPageLayout from '../layouts/SubPageLayout.astro';

const navLinks = [
  { name: '공지사항', url: '/notices' },
  { name: '보도자료', url: '/press-releases' },
  { name: '상담문의', url: '/inquiries' },
  { name: 'FAQ', url: '/faq' },
];

const announcements = [
  {
    title: '2024 SafeD 홈페이지 리뉴얼',
    description: '2024 SafeD 홈페이지 리뉴얼 안내드립니다. 더욱 편리하고 직관적인 UI로 개편되었습니다.',
    date: '2024.12.01',
    category: '서비스',
    isNew: true,
  },
  {
    title: 'SafeD 시스템 점검 일정',
    description: '시스템 안정성 강화를 위한 정기 점검 일정 안내입니다.',
    date: '2024.11.15',
    category: '점검',
    isNew: false,
  },
];
---

<SubPageLayout
  title="공지사항 - SafeD | 스마트안전관리시스템"
  pageTitle="공지사항"
  pageTitleEn="Notices"
  description="SafeD 공지사항 - 스마트안전관리시스템 소식"
  navLinks={navLinks}
>
  <section class="py-20">
    <div class="w-container max-w-4xl">
      <!-- Section header -->
      <div class="flex items-end justify-between mb-10 reveal">
        <div>
          <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-3">Notice Board</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight">SafeD 소식을 알려드립니다</h2>
        </div>
        <p class="eng text-sm text-gray-400 hidden sm:block">
          Total <span class="font-bold text-gray-600">{announcements.length}</span>
        </p>
      </div>

      <!-- Notice list -->
      {announcements.length > 0 ? (
        <div class="space-y-4 reveal delay-100">
          {announcements.map((item, i) => (
            <div class="group relative bg-white border border-gray-100 rounded-2xl p-6 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300">
              <div class="flex items-start gap-5">
                <!-- Number -->
                <div class="w-12 h-12 rounded-xl bg-gray-50 group-hover:bg-primary/5 flex items-center justify-center flex-shrink-0 transition-colors">
                  <span class="eng text-primary font-bold text-lg">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">{item.category}</span>
                    {item.isNew && (
                      <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-50 text-red-500 eng uppercase">New</span>
                    )}
                  </div>
                  <h3 class="font-bold text-gray-800 mb-1 group-hover:text-primary transition-colors">{item.title}</h3>
                  <p class="text-sm text-gray-500 line-clamp-1">{item.description}</p>
                </div>
                <!-- Date + Arrow -->
                <div class="flex-shrink-0 text-right hidden sm:flex flex-col items-end gap-2">
                  <span class="text-sm text-gray-400 eng">{item.date}</span>
                  <svg class="w-5 h-5 text-gray-200 group-hover:text-primary group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="py-24 text-center reveal delay-100">
          <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <p class="text-gray-400 font-medium">등록된 공지사항이 없습니다.</p>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-16 bg-gradient-to-r from-gray-50 to-blue-50/30 rounded-2xl p-8 flex items-center justify-between reveal delay-200">
        <div>
          <p class="font-bold text-gray-800 mb-1">더 궁금한 점이 있으신가요?</p>
          <p class="text-sm text-gray-500">SafeD 도입 상담을 신청해 보세요.</p>
        </div>
        <a href="/inquiries" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-full text-sm font-semibold hover:bg-primary/90 transition-colors flex-shrink-0">
          상담문의
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</SubPageLayout>
