---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import FeatureCarousel from '../components/ui/FeatureCarousel.tsx';
import FeaturesSection from '../components/safed/FeaturesSection.astro';

const navLinks = [
  { name: '사업배경', url: '/business-background' },
  { name: 'SafeD Development', url: '/safed-features' },
];

const features = [
  { icon: '/images/icon01.png', title: '스마트 위험성평가', desc: '300여개 공종, 50,000개 위험요인·안전대책 DB 자동 매칭. 모바일에서 원클릭으로 위험성평가를 작성하고 관리합니다.' },
  { icon: '/images/icon02.png', title: '위험요소 제거', desc: '추가위험을 발굴하고 위험요소들을 사전에 제거합니다. 사진 촬영·전송만으로 즉시 위험요소 신고 가능.' },
  { icon: '/images/icon03.png', title: '다국어 지원 (19개국)', desc: 'Google AI 자동번역으로 19개국어 지원. 외국인 근로자도 모국어로 위험성평가·TBM 내용을 확인하고 음성 안내까지.' },
  { icon: '/images/icon04.png', title: 'GPS 안전 모니터링', desc: '토목 현장 등 넓은 작업 반경도 GPS로 출역·작업위치·동선을 실시간 추적하고 모니터링합니다.' },
  { icon: '/images/icon05.png', title: '스마트 비콘 (BEACON)', desc: '명함 80% 크기, 6만원. 기존 대비 90% 비용 절감. 위험지역 접근 시 1차·2차 경고를 자동 발송합니다.' },
  { icon: '/images/icon06.png', title: '커뮤니케이션', desc: 'SMS, Mobile Push 알람으로 오늘할일, 잔여과제, 지연처리, 폭염주의까지 Message 자동 발송합니다.' },
  { icon: '/images/icon07.png', title: 'QR코드', desc: '통합QR코드 하나로 위험성평가 확인, 안전건의함 작성, 작업중지권 신청까지. 근로자 참여를 극대화합니다.' },
  { icon: '/images/icon08.png', title: '안전교육·TBM·협의체', desc: 'PC+모바일 동시 작성. TBM 참석자 서명, 문자 인증, 보고서 자동 생성. 노사협의체 회의록 관리까지.' },
  { icon: '/images/icon09.png', title: '점검일지·작업계획서·허가서(PTW)', desc: '사전 입력 양식으로 빠른 작성. 결재선 설정, 승인/반려 프로세스, 보고서 자동 출력까지 원스톱.' },
];
---

<SubPageLayout
  title="SafeD Development - SafeD | 스마트안전관리시스템"
  pageTitle="SafeD Development"
  pageTitleEn="SafeD Features"
  description="SafeD 스마트 위험성평가, GPS 안전 모니터링, 비콘 기술, 다국어 자동번역 등 건설현장 안전관리 핵심 기능을 제공합니다."
  keywords="위험성평가, GPS모니터링, 비콘안전, QR코드안전관리, TBM, 안전교육, 작업허가서, SafeD기능"
  navLinks={navLinks}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SafeD",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web, Android, iOS",
    "description": "건설현장 스마트 안전관리 시스템",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "KRW",
      "description": "맞춤 견적 제공"
    }
  }}
>
  <!-- ═══ HERO (unchanged) ═══ -->
  <section class="py-14 lg:py-20 bg-white">
    <div class="w-container max-w-4xl text-center">
      <h2 class="hero-headline tracking-tight reveal">
        안전관리,<br /><span class="text-gradient-blue">더 스마트하게.</span>
      </h2>
      <p class="text-gray-500 text-lg lg:text-xl mt-8 leading-relaxed max-w-2xl mx-auto reveal delay-100">
        SafeD는 위험성평가, 실시간 모니터링, AI 번역, 자동 알림을 하나의 플랫폼에 담았습니다.
        현장의 복잡함은 줄이고, 안전의 확실함은 높입니다.
      </p>
    </div>
  </section>

  <!-- ═══ Efficiency / ROI ═══ -->
  <section class="bg-[#1C1C1E] text-white">
    <div class="w-container max-w-5xl py-14 lg:py-16">
      <div class="text-center mb-8">
        <p class="eng font-medium text-xs tracking-[0.15em] uppercase mb-2 text-[#6B6B6B] reveal">Efficiency</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight reveal delay-100">단순·반복 업무 <span class="text-[#2563EB]">80% 제거</span></h2>
        <p class="text-white/40 mt-4 max-w-xl mx-auto text-sm reveal delay-200">현장 내 다양한 단순/반복 업무를 시스템화하여, 작업자 개개인의 핵심업무에 집중할 수 있도록 도와줍니다.</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-[1px] bg-white/10 border border-white/10 mb-8 reveal delay-200">
        {[
          { num: '80%', label: '단순반복 업무', sub: '제거' },
          { num: '60h', label: '월간 절감 시간', sub: '1개 현장 기준' },
          { num: '120만원', label: '월간 비용 절감', sub: '1개 현장 기준' },
          { num: '70%', label: '위험성평가', sub: '작성시간 단축' },
        ].map((item) => (
          <div class="bg-[#1C1C1E] p-6 text-center">
            <p class="eng text-2xl lg:text-3xl font-bold text-[#2563EB] mb-2">{item.num}</p>
            <p class="font-semibold text-white/80 text-sm mb-1">{item.label}</p>
            <p class="text-xs text-white/40">{item.sub}</p>
          </div>
        ))}
      </div>

      <div class="border border-white/10 p-6 lg:p-8 reveal delay-300">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
          <div>
            <p class="text-[#6B6B6B] text-xs font-semibold mb-2 uppercase eng">AS-IS</p>
            <p class="text-white/50 text-sm">260종 문서를 눈으로 확인<br/>사진 출력·작성·점검에 240분 소요<br/>정보(문서) 파편화로 탐색·학습 어려움</p>
          </div>
          <div class="flex items-center justify-center">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
          <div>
            <p class="text-[#2563EB] text-xs font-semibold mb-2 uppercase eng">TO-BE (SafeD)</p>
            <p class="text-white/70 text-sm">1-click 조회 및 참조<br/>All-in-One 디지털 온라인 처리 40분<br/>실시간 저장·열람·탐색·학습</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Video Section ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-5xl py-14 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5 reveal">
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-4">Watch Demo</p>
          <h2 class="text-2xl lg:text-3xl font-bold mb-4 tracking-tight leading-snug text-[#111]">
            스마트 위험성평가 ·<br/>다국적 근로자를 고려한
            <span class="text-[#2563EB]">자동번역 기능</span>
          </h2>
          <p class="text-[#6B6B6B] text-sm leading-relaxed mb-6">SafeD의 핵심 기능을 영상으로 확인하세요. 위험성평가 작성부터 다국어 자동번역, 음성 안내까지 한눈에 볼 수 있습니다.</p>
          <div class="divide-y divide-[#E0E0E0] border border-[#E0E0E0]">
            {[
              { label: '원클릭 위험성평가', desc: '50,000 DB 자동 매칭' },
              { label: '19개국어 자동번역', desc: 'Google AI 기반 실시간' },
              { label: '음성 안내 TTS', desc: '모국어 음성 출력 지원' },
            ].map((item) => (
              <div class="flex items-center gap-3 p-3">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" class="flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-sm font-semibold text-[#111]">{item.label}</span>
                <span class="text-xs text-[#6B6B6B] ml-auto">{item.desc}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="lg:col-span-7 reveal delay-200">
          <div class="relative w-full aspect-video overflow-hidden border border-[#E0E0E0]">
            <iframe
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/tu9mHC7H_Kw"
              title="SafeD 소개 영상"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Core Features Carousel ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="py-14 lg:py-16">
      <div class="text-center mb-8 reveal w-container">
        <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-2">Core Features</p>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight text-[#111]">주요 기능</h2>
        <p class="text-[#6B6B6B] mt-3 text-sm">PC + 모바일 동시 지원, 실시간 연동</p>
      </div>
      <FeatureCarousel client:visible features={features} interval={4000} />
    </div>
  </section>

  <!-- ═══ Phone Infographic: 8 Features ═══ -->
  <FeaturesSection />

  <!-- ═══ Beacon Deep Dive ═══ -->
  <section class="bg-[#1C1C1E] text-white">
    <div class="w-container max-w-5xl py-14 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="reveal">
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-4">Smart Beacon</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-6">스마트 안전 비콘<br/><span class="text-[#2563EB]">비용 90% 절감</span></h2>
          <p class="text-white/50 leading-relaxed mb-6 text-sm">
            기존 고비용 송신기(1세트 60만원)를 스마트폰으로 대체하여 비콘 1개당 6만원으로 동일한 기능을 구현합니다.
            명함 80% 크기로 어디든 탈·부착 가능하며, 3~5년 배터리 수명을 보장합니다.
          </p>
          <div class="grid grid-cols-3 gap-[1px] bg-white/10 border border-white/10 mb-6">
            {[
              { label: '크기', value: '명함 80%' },
              { label: '수명', value: '3~5년' },
              { label: '단가', value: '6만원' },
            ].map((item) => (
              <div class="bg-[#1C1C1E] p-3 text-center">
                <p class="eng font-bold text-lg text-[#2563EB]">{item.value}</p>
                <p class="text-xs text-white/40 mt-1">{item.label}</p>
              </div>
            ))}
          </div>
          <div class="divide-y divide-white/10">
            {[
              '위험지역 접근 시 1차 경고 (스마트폰 알림)',
              '접근 지속 시 안전관리자 2차 경고 발송',
              '이동식 장비(덤프트럭, 크레인)에도 부착 가능',
              '반경 1~50m 유효 작동 범위 설정',
            ].map((text) => (
              <div class="flex items-center gap-3 py-3">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5" class="flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-white/70 text-sm">{text}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal-right delay-200">
          <div class="border border-white/10 p-8 lg:p-10">
            <div class="text-center mb-6">
              <p class="eng text-xs text-white/40 tracking-widest uppercase mb-2">Cost Comparison</p>
              <h3 class="text-xl font-bold">SafeD vs 타사</h3>
            </div>
            <div class="grid grid-cols-2 gap-[1px] bg-white/10">
              <div class="bg-[#2563EB]/10 border border-[#2563EB]/30 p-6 text-center">
                <p class="eng text-3xl font-bold text-[#2563EB]">6만원</p>
                <p class="text-sm text-white/70 mt-2">SafeD 비콘</p>
                <p class="text-xs text-white/40 mt-1">비콘 + 스마트폰</p>
              </div>
              <div class="bg-white/5 p-6 text-center">
                <p class="eng text-3xl font-bold text-white/60">60만원</p>
                <p class="text-sm text-white/70 mt-2">타사 솔루션</p>
                <p class="text-xs text-white/40 mt-1">비콘 + AP + 송신기</p>
              </div>
            </div>
            <div class="mt-4 border border-[#2563EB]/20 bg-[#2563EB]/[0.05] p-3 text-center">
              <p class="text-[#2563EB] font-bold eng text-sm">90% 비용 절감</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Multilingual Support ═══ -->
  <section class="border-b border-[#E0E0E0]">
    <div class="w-container max-w-6xl py-14 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-5 reveal lg:sticky lg:top-24">
          <p class="eng font-medium text-xs tracking-[0.15em] uppercase text-[#6B6B6B] mb-4">Multilingual</p>
          <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-4 leading-tight text-[#111]">
            Google AI<br/><span class="text-[#2563EB]">다국어 자동번역</span>
          </h2>
          <p class="text-[#6B6B6B] leading-relaxed mb-8 text-sm">현장별 다국적 근로자 현황을 고려하여 19개국어 자동번역과 음성 안내를 지원합니다.</p>

          <div class="bg-[#1C1C1E] p-6 mb-6">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-10 h-10 border border-[#2563EB]/30 flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
              </div>
              <div>
                <p class="text-white text-sm font-semibold">음성 안내 지원</p>
                <p class="text-white/40 text-xs">TTS 기반 모국어 음성 출력</p>
              </div>
            </div>
            <div class="flex items-end gap-[3px] h-12 mb-5">
              {Array.from({length: 32}).map((_, i) => {
                const h = 25 + Math.sin(i * 0.7) * 20 + Math.sin(i * 1.3) * 10;
                const dur = (0.4 + Math.sin(i * 0.5) * 0.3).toFixed(2);
                const del = (i * 0.04).toFixed(2);
                return (
                  <div class="flex-1" style={`height: ${h}%; background: #2563EB; opacity: 0.6; animation: soundBar ${dur}s ease-in-out infinite alternate; animation-delay: ${del}s;`}></div>
                );
              })}
            </div>
            <div class="grid grid-cols-3 gap-[1px] bg-white/10">
              <div class="bg-[#1C1C1E] p-2.5 text-center">
                <p class="text-xs text-white/40 mb-1">원문</p>
                <p class="text-white/90 text-xs font-medium">안전모 착용</p>
              </div>
              <div class="bg-[#2563EB]/10 p-2.5 text-center">
                <p class="text-xs text-[#2563EB]/60 mb-1">번역</p>
                <p class="text-[#2563EB] text-xs font-medium">Wear a helmet</p>
              </div>
              <div class="bg-[#1C1C1E] p-2.5 text-center">
                <p class="text-xs text-white/40 mb-1">음성</p>
                <p class="text-white/90 text-xs font-medium flex items-center justify-center gap-1">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                  TTS
                </p>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0]">
            {[
              { iconPath: 'M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11', label: '위험성평가', desc: 'QR 스캔 시 모국어 번역' },
              { iconPath: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75', label: 'TBM', desc: '다국어 작업내용 전달' },
              { iconPath: 'M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z', label: '안전교육', desc: '번역 + 음성 안내' },
            ].map((item) => (
              <div class="bg-white p-3 flex flex-col items-center text-center gap-1.5">
                <div class="w-8 h-8 border border-[#E0E0E0] flex items-center justify-center flex-shrink-0">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d={item.iconPath}/></svg>
                </div>
                <div>
                  <p class="font-bold text-sm text-[#111]">{item.label}</p>
                  <p class="text-[#6B6B6B] text-xs">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="lg:col-span-7 reveal-right delay-200">
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-[1px] bg-[#E0E0E0] border border-[#E0E0E0]">
            {[
              { code: 'gb', name: 'English', ko: '영어' },
              { code: 'cn', name: '简体中文', ko: '중국어(간체)' },
              { code: 'tw', name: '繁體中文', ko: '중국어(번체)' },
              { code: 'vn', name: 'Tiếng Việt', ko: '베트남어' },
