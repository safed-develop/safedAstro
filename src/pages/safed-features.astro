---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import VerticalTab from '../components/ui/VerticalTab.astro';

const navLinks = [
  { name: '사업배경', url: '/business-background' },
  { name: 'SafeD Development', url: '/safed-features' },
];

const features = [
  { icon: '/images/safed_feature_01.png', title: '스마트 위험성평가', desc: '위험요인을 찾아 위험성의 크기를 평가하고 조치·검토 할 수 있는 시스템입니다.' },
  { icon: '/images/safed_feature_02.png', title: '위험요소 제거', desc: '추가위험을 발굴하고 위험요소들을 사전에 제거합니다.' },
  { icon: '/images/safed_feature_03.png', title: '다국어 지원', desc: '현장 별 다국적 근로자를 고려하여, Google A.I 자동번역 기능을 제공합니다.' },
  { icon: '/images/safed_feature_04.png', title: '안전 모니터링', desc: '작업 반경이 넓은 현장도 GPS를 통해, 출역·작업위치·동선 등을 알 수 있습니다.' },
  { icon: '/images/safed_feature_05.png', title: '비콘', desc: '이동식 장비에도 쉽게 탈·부착 가능하며, 스마트폰 접근경고를 통해 현장 작업자 안전을 확보합니다.' },
  { icon: '/images/safed_feature_06.png', title: '커뮤니케이션', desc: 'SMS, Mobile Push 알람 기능으로 오늘할일, 잔여과제, 지연처리 Message 자동 발송합니다.' },
  { icon: '/images/safed_feature_07.png', title: 'QR코드', desc: '위험성평가, 안전건의함, 작업중지권을 QR코드로 쉽게 조회, 작성합니다.' },
  { icon: '/images/safed_feature_08.png', title: '안전교육·TBM·협의체', desc: '현장에 안전에 필요한 회의, 교육, TBM을 쉽게 작성하고 참석할 수 있습니다.' },
  { icon: '/images/safed_feature_09.png', title: '점검일지·작업계획서·작업허가서(PTW)', desc: '모바일에서 쉽게 작성하고 점검, 결재까지 한번에 가능합니다.' },
];

const tabs = [
  { name: '중간점검활동', content: '<div class="p-8 text-center text-gray-400">중간점검활동 상세 내용</div>' },
  { name: '일상점검활동', content: '<div class="p-8 text-center text-gray-400">일상점검활동 상세 내용</div>' },
  { name: '점검일지', content: '<div class="p-8 text-center text-gray-400">점검일지 상세 내용</div>' },
  { name: '교육', content: '<div class="p-8 text-center text-gray-400">교육 상세 내용</div>' },
  { name: '추가위험발굴', content: '<div class="p-8 text-center text-gray-400">추가위험발굴 상세 내용</div>' },
  { name: '부적합보고서', content: '<div class="p-8 text-center text-gray-400">부적합보고서 상세 내용</div>' },
  { name: '작업계획서·허가서', content: '<div class="p-8 text-center text-gray-400">작업계획서·허가서 상세 내용</div>' },
  { name: 'TBM', content: '<div class="p-8 text-center text-gray-400">TBM 상세 내용</div>' },
];
---

<SubPageLayout
  title="SafeD Development - SafeD | 스마트안전관리시스템"
  pageTitle="SafeD Development"
  pageTitleEn="SafeD Features"
  description="SafeD 스마트 위험성평가, GPS 안전 모니터링, 비콘 기술, 다국어 자동번역 등 건설현장 안전관리 핵심 기능을 제공합니다."
  keywords="위험성평가, GPS모니터링, 비콘안전, QR코드안전관리, TBM, 안전교육, 작업허가서, SafeD기능"
  navLinks={navLinks}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SafeD",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web, Android, iOS",
    "description": "건설현장 스마트 안전관리 시스템",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "KRW",
      "description": "맞춤 견적 제공"
    }
  }}
>
  <!-- Video Section -->
  <section class="py-20 bg-gray-50">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl lg:text-4xl font-bold mb-4 tracking-tight">
          스마트 위험성평가 · 다국적 근로자를 고려한
          <span class="text-primary">자동번역 기능</span>
        </h2>
      </div>
      <div class="relative w-full aspect-video rounded-2xl overflow-hidden shadow-lg reveal delay-200">
        <iframe
          class="absolute inset-0 w-full h-full"
          src="https://www.youtube.com/embed/tu9mHC7H_Kw"
          title="SafeD 소개 영상"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="py-20">
    <div class="w-container">
      <div class="text-center mb-16 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Core Features</p>
        <h2 class="text-3xl font-bold tracking-tight">주요 기능</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((item, i) => (
          <div class={`bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-lg transition-shadow reveal delay-${((i % 3) + 1) * 100}`}>
            <img src={item.icon} alt={item.title} class="w-16 h-16 object-contain mb-4" loading="lazy" />
            <h3 class="font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Vertical Tab Section -->
  <section class="py-20 bg-gray-50">
    <div class="w-container max-w-5xl">
      <div class="text-center mb-12 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Detailed Features</p>
        <h2 class="text-3xl font-bold tracking-tight">기능 상세</h2>
      </div>
      <div class="bg-white rounded-2xl p-8 lg:p-12 shadow-sm reveal delay-200">
        <VerticalTab tabs={tabs} />
      </div>
    </div>
  </section>

  <!-- Dashboard -->
  <section class="py-20 hidden md:block">
    <div class="w-container">
      <div class="text-center mb-12 reveal">
        <p class="text-primary eng font-semibold text-sm tracking-widest uppercase mb-4">Dashboard</p>
        <h2 class="text-3xl font-bold tracking-tight">통합 대시보드</h2>
      </div>
      <div class="reveal delay-200">
        <img src="/images/dboard.png" alt="SafeD 대시보드" class="w-full rounded-2xl shadow-lg" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary text-white text-center">
    <div class="w-container reveal">
      <h2 class="text-3xl font-bold mb-4 tracking-tight">SafeD로 스마트한 안전관리를 시작하세요</h2>
      <p class="opacity-80 mb-8">위험성평가부터 모니터링까지 올인원 솔루션</p>
      <a href="/inquiries" class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-primary rounded-full font-semibold hover:bg-gray-100 transition-colors">
        도입문의
      </a>
    </div>
  </section>
</SubPageLayout>
