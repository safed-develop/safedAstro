    font-size: 0.95rem;
    font-weight: 700;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.3px;
    color: #111;
  }

  .sf-card-desc {
    font-size: 0.8rem;
    color: #6B6B6B;
    line-height: 1.6;
    word-break: keep-all;
  }

  /* ── Workflow Carousel ── */
  .wf-carousel {
    overflow: hidden;
    position: relative;
  }

  .wf-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .wf-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    width: 100%;
    flex-shrink: 0;
    background: #E0E0E0;
    border: 1px solid #E0E0E0;
  }

  .wf-card {
    background: #fff;
    padding: 1.25rem 1.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .wf-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .wf-card-stat {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .wf-card-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: auto;
  }

  .wf-card-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .wf-page[data-page].wf-active .wf-card-bar {
    width: 100%;
  }

  .wf-nav-btn {
    width: 32px;
    height: 32px;
    border: 1px solid #E0E0E0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #6B6B6B;
    transition: all 0.2s;
  }

  .wf-nav-btn:hover {
    border-color: #111;
    color: #111;
  }

  .wf-dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    border: none;
    padding: 0;
    cursor: pointer;
    background: #d1d5db;
    transition: all 0.3s;
  }

  .wf-dot-active {
    width: 20px;
    background: #2563EB;
  }

  @media (max-width: 639px) {
    .wf-page {
      grid-template-columns: 1fr;
    }
    .wf-card {
      padding: 1rem;
    }
    .wf-card h3 {
      font-size: 14px !important;
    }
  }
</style>

<script>
  function initWorkflowCarousel() {
    const track = document.getElementById('wf-track');
    const counter = document.getElementById('wf-counter');
    const dots = document.querySelectorAll('.wf-dot');
    const prevBtn = document.getElementById('wf-prev');
    const nextBtn = document.getElementById('wf-next');
    if (!track || !counter) return;

    let current = 0;
    const total = 4;
    let timer: ReturnType<typeof setInterval> | null = null;

    function goTo(idx: number) {
      current = ((idx % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      counter.textContent = `${current + 1} / ${total}`;

      // Update dots
      dots.forEach((d, i) => {
        d.classList.toggle('wf-dot-active', i === current);
      });

      // Update active page for bar animation
      document.querySelectorAll('.wf-page').forEach((p, i) => {
        p.classList.toggle('wf-active', i === current);
      });
    }

    function startAuto() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    prevBtn?.addEventListener('click', () => { goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); startAuto(); });
    dots.forEach((d) => {
      d.addEventListener('click', () => {
        const idx = parseInt(d.getAttribute('data-dot') || '0');
        goTo(idx);
        startAuto();
      });
    });

    // Touch swipe
    let touchX = 0;
    track.addEventListener('touchstart', (e: TouchEvent) => { touchX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e: TouchEvent) => {
      const diff = touchX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) {
        goTo(diff > 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    goTo(0);
    startAuto();
  }

  document.addEventListener('DOMContentLoaded', initWorkflowCarousel);
  document.addEventListener('astro:page-load', initWorkflowCarousel);
</script>
