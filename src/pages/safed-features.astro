---
import SubPageLayout from '../layouts/SubPageLayout.astro';
import VerticalTab from '../components/ui/VerticalTab.astro';

const navLinks = [
  { name: '사업배경', url: '/business-background' },
  { name: 'SafeD Development', url: '/safed-features' },
];

const features = [
  { icon: '/images/safed_feature_01.png', title: '스마트 위험성평가', desc: '300여개 공종, 50,000개 위험요인·안전대책 DB 자동 매칭. 모바일에서 원클릭으로 위험성평가를 작성하고 관리합니다.' },
  { icon: '/images/safed_feature_02.png', title: '위험요소 제거', desc: '추가위험을 발굴하고 위험요소들을 사전에 제거합니다. 사진 촬영·전송만으로 즉시 위험요소 신고 가능.' },
  { icon: '/images/safed_feature_03.png', title: '다국어 지원 (19개국)', desc: 'Google AI 자동번역으로 19개국어 지원. 외국인 근로자도 모국어로 위험성평가·TBM 내용을 확인하고 음성 안내까지.' },
  { icon: '/images/safed_feature_04.png', title: 'GPS 안전 모니터링', desc: '토목 현장 등 넓은 작업 반경도 GPS로 출역·작업위치·동선을 실시간 추적하고 모니터링합니다.' },
  { icon: '/images/safed_feature_05.png', title: '스마트 비콘 (BEACON)', desc: '명함 80% 크기, 6만원. 기존 대비 90% 비용 절감. 위험지역 접근 시 1차·2차 경고를 자동 발송합니다.' },
  { icon: '/images/safed_feature_06.png', title: '커뮤니케이션', desc: 'SMS, Mobile Push 알람으로 오늘할일, 잔여과제, 지연처리, 폭염주의까지 Message 자동 발송합니다.' },
  { icon: '/images/safed_feature_07.png', title: 'QR코드', desc: '통합QR코드 하나로 위험성평가 확인, 안전건의함 작성, 작업중지권 신청까지. 근로자 참여를 극대화합니다.' },
  { icon: '/images/safed_feature_08.png', title: '안전교육·TBM·협의체', desc: 'PC+모바일 동시 작성. TBM 참석자 서명, 문자 인증, 보고서 자동 생성. 노사협의체 회의록 관리까지.' },
  { icon: '/images/safed_feature_09.png', title: '점검일지·작업계획서·허가서(PTW)', desc: '사전 입력 양식으로 빠른 작성. 결재선 설정, 승인/반려 프로세스, 보고서 자동 출력까지 원스톱.' },
];

const tabs = [
  {
    name: '위험성평가',
    content: `
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 p-6 lg:p-8">
        <div>
          <h3 class="text-xl font-bold mb-4 tracking-tight">시스템 기반 스마트 위험성평가</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">300여개 공종과 50,000개의 위험요인·안전대책 데이터베이스를 보유하고 있어, 원클릭으로 공종을 조회하고 위험성평가를 작성할 수 있습니다.</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 최초/정기/수시/일일 위험성평가 지원</li>
            <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 가능성(빈도)·중대성(강도) 자동 점수 산출</li>
            <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 상(중점)·중(일상)·하(일반) 점검 자동 분류</li>
            <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 총괄책임자 승인 후 회의록 자동 생성·출력</li>
            <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 근로자 QR코드로 위험성평가 열람·의견 작성</li>
          </ul>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 flex flex-col justify-center">
          <div class="grid grid-cols-2 gap-4 text-center">
            <div class="bg-white rounded-lg p-4 shadow-sm">
              <p class="text-2xl font-extrabold text-primary eng">300+</p>
              <p class="text-xs text-gray-500 mt-1">표준위험공종</p>
            </div>
            <div class="bg-white rounded-lg p-4 shadow-sm">
              <p class="text-2xl font-extrabold text-primary eng">50,000+</p>
              <p class="text-xs text-gray-500 mt-1">위험요인·안전대책</p>
            </div>
            <div class="bg-white rounded-lg p-4 shadow-sm">
              <p class="text-2xl font-extrabold text-primary eng">4종</p>
              <p class="text-xs text-gray-500 mt-1">평가 유형</p>
            </div>
            <div class="bg-white rounded-lg p-4 shadow-sm">
              <p class="text-2xl font-extrabold text-primary eng">자동</p>
              <p class="text-xs text-gray-500 mt-1">회의록 생성</p>
            </div>
          </div>
        </div>
      </div>
    `,
  },
  {
    name: '중점점검활동',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">중점점검활동 PROCESS</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-6">위험성평가 회의에서 '상(중점점검)' 등급으로 분류된 항목을 집중 관리합니다.</p>
        <div class="grid grid-cols-5 gap-3">
          <div class="bg-primary/5 rounded-xl p-4 text-center">
            <p class="text-2xl mb-2">📋</p>
            <p class="text-xs font-semibold text-gray-700">목록 확인</p>
          </div>
          <div class="bg-primary/5 rounded-xl p-4 text-center">
            <p class="text-2xl mb-2">🔍</p>
            <p class="text-xs font-semibold text-gray-700">현장 확인</p>
          </div>
          <div class="bg-primary/5 rounded-xl p-4 text-center">
            <p class="text-2xl mb-2">✏️</p>
            <p class="text-xs font-semibold text-gray-700">결과 작성</p>
          </div>
          <div class="bg-primary/5 rounded-xl p-4 text-center">
            <p class="text-2xl mb-2">📸</p>
            <p class="text-xs font-semibold text-gray-700">사진 촬영</p>
          </div>
          <div class="bg-primary/5 rounded-xl p-4 text-center">
            <p class="text-2xl mb-2">✅</p>
            <p class="text-xs font-semibold text-gray-700">등록 완료</p>
          </div>
        </div>
        <p class="text-sm text-gray-500 mt-4">위험성평가 회의 내용을 기반으로 점검 목록이 자동 생성되며, 모바일에서 현장 사진과 함께 점검 결과를 즉시 등록할 수 있습니다.</p>
      </div>
    `,
  },
  {
    name: '일상점검활동',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">일상점검활동</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">위험성평가에서 '중(일상점검)' 등급으로 분류된 항목을 매일 점검하고 기록합니다.</p>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 일일 안전책임자 지정 및 스마트폰 알람 예약</li>
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 모바일 앱에서 점검 목록 확인 및 결과 입력</li>
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 현장 사진 촬영·첨부로 실질적 점검 증빙</li>
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 관리자·협력사 맞춤형 화면 제공</li>
        </ul>
      </div>
    `,
  },
  {
    name: '점검일지',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">순회점검일지 & 점검일지 관리</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">산업안전보건법 제64조에 따른 작업장 순회점검을 체계적으로 이행합니다. 건설업·제조업은 2일에 1회 이상 실시해야 합니다.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-gray-50 rounded-lg p-4">
            <p class="font-semibold text-sm mb-2">순회점검일지</p>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>• 점검항목·점검자 사전 지정</li>
              <li>• 모바일 앱에서 즉시 촬영·전송</li>
              <li>• 승인자 검토 후 승인/반려</li>
              <li>• 보고서 형태 자동 출력</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <p class="font-semibold text-sm mb-2">점검일지 관리</p>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>• 점검주기(매주/매월) 설정</li>
              <li>• PC·모바일 동시 등록</li>
              <li>• 조치 완료 상태 추적</li>
              <li>• 이력 관리 및 통계</li>
            </ul>
          </div>
        </div>
      </div>
    `,
  },
  {
    name: '교육·TBM',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">안전교육 & TBM (Tool Box Meeting)</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">PC+모바일에서 동시에 쉽고 빠르게 교육과 TBM을 기록·관리합니다.</p>
        <div class="space-y-4">
          <div class="bg-blue-50/50 border border-blue-100 rounded-lg p-4">
            <p class="font-semibold text-sm text-blue-900 mb-2">TBM 주요 기능</p>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>• TBM명, 일시, 공종, 작업내용, 위험요인 및 안전대책 입력</li>
              <li>• 모바일 앱 또는 SMS를 통한 참석자 서명 확인</li>
              <li>• 일용근로자도 이름+전화번호 입력 → 문자 인증 참석 확인</li>
              <li>• TBM 점검/교육일지 자동 생성 및 인쇄</li>
            </ul>
          </div>
          <div class="bg-green-50/50 border border-green-100 rounded-lg p-4">
            <p class="font-semibold text-sm text-green-900 mb-2">안전교육</p>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>• 계절별 특성에 맞는 안전교육 자료 사전 입력</li>
              <li>• PC 등록, 모바일 열람 동시 지원</li>
              <li>• 교육 이수 여부 자동 체크</li>
            </ul>
          </div>
        </div>
      </div>
    `,
  },
  {
    name: '추가위험발굴',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">추가위험발굴 & 안전건의함</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">현장 근로자가 직접 위험요소를 발굴하고, 안전건의함을 통해 소통합니다.</p>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 근로자가 스마트폰으로 사진 촬영·전송만으로 위험 신고</li>
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 안전건의함: 건의 내용+사진 첨부 → 즉시 관리자에게 전달</li>
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 작업중지권: QR코드로 간편 신청, 관리자 PC·모바일 실시간 조회</li>
          <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-primary font-bold">•</span> 외국인 근로자도 모국어 자동번역으로 참여 가능</li>
        </ul>
      </div>
    `,
  },
  {
    name: '작업계획서·허가서',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">작업계획서 & 작업허가서(PTW)</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <div class="bg-gray-50 rounded-lg p-4">
            <p class="font-semibold text-sm mb-2">작업계획서</p>
            <p class="text-xs text-gray-600 leading-relaxed">산업안전보건기준에 관한 규칙 제38조에 따른 작업계획서를 사전 입력 양식으로 빠르게 작성. 도구·절차·순서를 고려한 안전작업계획을 수립합니다.</p>
            <ul class="text-xs text-gray-600 space-y-1 mt-2">
              <li>• 사전 입력 양식 + 추가 양식 작성 가능</li>
              <li>• 결재선 설정 및 의견 작성</li>
            </ul>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <p class="font-semibold text-sm mb-2">작업허가서 (PTW)</p>
            <p class="text-xs text-gray-600 leading-relaxed">고위험작업 진행 시 안전성을 검토·확인하여 작업을 진행합니다.</p>
            <ul class="text-xs text-gray-600 space-y-1 mt-2">
              <li>• 위험요인·개선대책·점검사항 사전 데이터 활용</li>
              <li>• 협력업체 작성 → 시공담당 → 안전담당 → 총괄 순 결재</li>
              <li>• 작업허가 → 작업진행 → 작업완료 결재 프로세스</li>
            </ul>
          </div>
        </div>
      </div>
    `,
  },
  {
    name: '보고서·대시보드',
    content: `
      <div class="p-6 lg:p-8">
        <h3 class="text-xl font-bold mb-4 tracking-tight">성과측정 & 보고서</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">본사 관리자는 전국 각 현장별 안전활동 이행률을 실시간으로 모니터링하고 비교할 수 있습니다.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div class="bg-primary/5 rounded-lg p-4 text-center">
            <p class="text-xl mb-1">📊</p>
            <p class="text-xs font-semibold">현장별 이행률</p>
          </div>
          <div class="bg-primary/5 rounded-lg p-4 text-center">
            <p class="text-xl mb-1">📈</p>
            <p class="text-xs font-semibold">항목별 비교</p>
          </div>
          <div class="bg-primary/5 rounded-lg p-4 text-center">
            <p class="text-xl mb-1">📄</p>
            <p class="text-xs font-semibold">자동 보고서</p>
          </div>
          <div class="bg-primary/5 rounded-lg p-4 text-center">
            <p class="text-xl mb-1">🖨️</p>
            <p class="text-xs font-semibold">인쇄·출력</p>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-4">위험성평가 회의록, TBM 교육일지, 순회점검일지, 작업계획서, 작업허가서 등 모든 문서가 보고서 형태로 자동 정리되어 출력 가능합니다.</p>
      </div>
    `,
