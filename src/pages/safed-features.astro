        <div class="wf-track" id="wf-track">
          {(() => {
            const allSteps = [
              { step: '01', title: '위험성평가 작성', desc: '50,000개 위험요인·안전대책 DB 원클릭 조회. 최초/정기/수시/일일 평가를 모바일에서 즉시 작성.', details: ['위험요인·안전대책 자동 매칭', '가능성·중대성 점수 자동 산출', '승인 후 회의록 자동 생성'], stat: '50,000+', statLabel: '위험요인 DB', color: '#3B82F6' },
              { step: '02', title: '중점·일상 점검활동', desc: '위험성평가에서 분류된 상·중 등급 항목을 매일 현장에서 점검, 결과 즉시 등록.', details: ['점검 목록 자동 생성', '모바일 사진 촬영·등록', '안전책임자 지정 및 알람'], stat: '매일', statLabel: '현장 점검', color: '#8B5CF6' },
              { step: '03', title: '순회점검일지 작성', desc: '산업안전보건법 제64조에 따른 순회점검 체계적 이행. 건설업 2일 1회 이상 실시.', details: ['점검항목·점검자 사전 지정', '승인/반려 프로세스', '보고서 자동 출력'], stat: '자동', statLabel: '보고서 생성', color: '#10B981' },
              { step: '04', title: '안전교육 · TBM', desc: 'PC+모바일 동시 교육·TBM 기록. 참석자 서명, 문자 인증, 교육일지 자동 생성.', details: ['TBM 참석자 모바일 서명', '일용근로자 문자 인증', '계절별 안전교육 자료 관리'], stat: 'PC+모바일', statLabel: '동시 지원', color: '#F59E0B' },
              { step: '05', title: '추가위험 발굴', desc: '근로자 스마트폰 직접 위험요소 신고. 안전건의함·작업중지권 QR코드로 간편 참여.', details: ['사진 촬영·전송 위험 신고', 'QR코드 작업중지권', '외국인 근로자 모국어 참여'], stat: 'QR코드', statLabel: '즉시 참여', color: '#EF4444' },
              { step: '06', title: '다국어 자동번역', desc: 'Google AI 19개국어 실시간 번역. 위험성평가·TBM 모국어 확인 + 음성 안내.', details: ['19개국어 자동번역', '음성 안내 지원', '외국인 근로자 완전 참여'], stat: '19개국어', statLabel: 'AI 번역', color: '#06B6D4' },
              { step: '07', title: '작업계획서 · 허가서', desc: '고위험작업 작업계획서와 PTW를 체계적으로 작성하고 결재.', details: ['사전 양식 빠른 작성', '결재선 설정 · 의견 작성', '작업허가→진행→완료'], stat: '원스톱', statLabel: '결재', color: '#8B5CF6' },
              { step: '08', title: '대시보드 · 보고서', desc: '본사에서 전국 현장별 안전활동 이행률 실시간 모니터링. 보고서 자동 정리·출력.', details: ['현장별 이행률 비교', '항목별 통계 분석', '보고서 자동 생성·인쇄'], stat: '실시간', statLabel: '모니터링', color: '#3B82F6' },
            ];
            const pages = [];
            for (let p = 0; p < 4; p++) {
