---
import { formatDateShort } from '../../utils/blog';
import TagBadge from './TagBadge.astro';

interface Post {
  slug: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    tags: string[];
    heroImage?: string;
  };
}
interface Props {
  posts: Post[];
}
const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="rp-wrap">
    <h3 class="rp-title">관련 글</h3>
    <div class="rp-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="rp-card">
          <div class="rp-img">
            {post.data.heroImage ? (
              <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
            ) : (
              <div class="rp-placeholder">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B0B8C1" stroke-width="1.2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
            )}
          </div>
          <div class="rp-body">
            <h4 class="rp-name">{post.data.title}</h4>
            <time class="rp-date eng" datetime={post.data.pubDate.toISOString()}>
              {formatDateShort(post.data.pubDate)}
            </time>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .rp-wrap {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid #E5E8EB;
  }
  .rp-title {
    font-size: 18px;
    font-weight: 700;
    color: #191F28;
    margin-bottom: 20px;
  }
  .rp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .rp-card {
    background: #F2F4F6;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    color: inherit;
  }
  .rp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.06);
  }
  .rp-img {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #E5E8EB;
  }
  .rp-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rp-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #E5E8EB 0%, #F2F4F6 100%);
  }
  .rp-body {
    padding: 14px 16px;
  }
  .rp-name {
    font-size: 14px;
    font-weight: 600;
    color: #191F28;
    line-height: 1.4;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rp-date {
    font-size: 12px;
    color: #8B95A1;
  }
  @media (max-width: 768px) {
    .rp-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
