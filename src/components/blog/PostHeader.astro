---
import TagBadge from './TagBadge.astro';
import { formatDate, getReadingTime } from '../../utils/blog';

interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  heroImage?: string;
  body: string;
}
const { title, pubDate, updatedDate, author, tags, heroImage, body } = Astro.props;
const readTime = getReadingTime(body);
---

<header class="ph-wrap">
  <div class="ph-tags">
    {tags.map(tag => <TagBadge tag={tag} size="md" />)}
  </div>
  <h1 class="ph-title">{title}</h1>
  <div class="ph-meta">
    <span class="ph-author">{author}</span>
    <span class="ph-sep"></span>
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    {updatedDate && (
      <>
        <span class="ph-sep"></span>
        <span class="ph-updated">수정: {formatDate(updatedDate)}</span>
      </>
    )}
    <span class="ph-sep"></span>
    <span>{readTime}분 읽기</span>
  </div>
  {heroImage && (
    <div class="ph-hero">
      <img src={heroImage} alt={title} />
    </div>
  )}
</header>

<style>
  .ph-wrap {
    margin-bottom: 48px;
  }
  .ph-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }
  .ph-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: #191F28;
    line-height: 1.3;
    letter-spacing: -1px;
    margin-bottom: 16px;
    word-break: keep-all;
  }
  .ph-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 14px;
    color: #8B95A1;
  }
  .ph-author {
    font-weight: 600;
    color: #4E5968;
  }
  .ph-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #D1D6DB;
  }
  .ph-updated {
    color: #B0B8C1;
  }
  .ph-hero {
    margin-top: 32px;
    border-radius: 12px;
    overflow: hidden;
  }
  .ph-hero img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
</style>
