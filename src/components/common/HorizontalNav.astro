---
interface Props {
  links: { name: string; url: string }[];
}

const { links } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav class="h-nav" aria-label="섹션 네비게이션">
  <div class="h-nav-inner">
    {links.map((link) => (
      <a
        href={link.url}
        class:list={['h-nav-link', { active: currentPath === link.url }]}
      >
        <span>{link.name}</span>
      </a>
    ))}
  </div>
</nav>

<style>
  .h-nav {
    background: #fff;
    border-bottom: 1px solid var(--color-gray-200);
    position: sticky;
    top: 56px;
    z-index: 100;
  }

  .h-nav-inner {
    display: flex;
    justify-content: center;
    gap: 0.25rem;
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .h-nav-link {
    padding: 0.5rem 1rem;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-gray-500);
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
    letter-spacing: -0.3px;
  }

  .h-nav-link:hover {
    color: var(--color-gray-800);
  }

  .h-nav-link.active {
    color: var(--color-gray-900);
    border-bottom-color: var(--color-primary);
  }

  /* Dark mode — toggled by scroll JS on welcome page */
  .h-nav.h-nav-dark {
    background: rgba(5, 10, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .h-nav.h-nav-dark .h-nav-link {
    color: rgba(255, 255, 255, 0.7);
  }

  .h-nav.h-nav-dark .h-nav-link:hover {
    color: rgba(255, 255, 255, 0.95);
  }

  .h-nav.h-nav-dark .h-nav-link.active {
    color: #fff;
    border-bottom-color: var(--color-primary-light);
  }

  @media (max-width: 999px) {
    .h-nav-inner {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .h-nav-inner::-webkit-scrollbar {
      display: none;
    }

    .h-nav-link {
      font-size: 12px;
      padding: 0.4rem 0.625rem;
    }
  }
</style>
