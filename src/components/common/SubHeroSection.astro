---
interface Props {
  title: string;
  titleEn?: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, titleEn, breadcrumbs = [] } = Astro.props;
const currentPath = Astro.url.pathname;

const autoBreadcrumbs = breadcrumbs.length > 0 ? breadcrumbs : (() => {
  const segments = currentPath.split('/').filter(Boolean);
  const pathMap: Record<string, string> = {
    'company-overview': '회사개요',
    'welcome': '인사말',
    'vision-mission': '비전 및 미션',
    'location': '오시는 길',
    'business-background': '사업배경',
    'business-overview': '사업개요',
    'safed-features': 'SafeD Development',
    'services': '서비스',
    'recruitment': '채용',
    'recruitment-guide': '채용안내',
    'recruitment-info': '채용정보',
    'notices': '공지사항',
    'press-releases': '보도자료',
    'inquiries': '상담문의',
    'faq': 'FAQ',
    'contact': '연락처',
    'privacy-policy': '개인정보처리방침',
    'terms-of-service': '이용약관',
    'about': '회사소개',
  };

  return segments.map((seg, i) => ({
    label: pathMap[seg] || seg,
    href: i < segments.length - 1 ? '/' + segments.slice(0, i + 1).join('/') : undefined,
  }));
})();
---

<section class="sub-hero">
  <div class="sub-hero-bg"></div>

  <!-- Minimal geometric accents -->
  <div class="sub-hero-shapes" aria-hidden="true">
    <div class="glow-orb"></div>
    <div class="line-h"></div>
    <div class="line-v"></div>
  </div>

  <div class="sub-hero-accent"></div>

  <div class="sub-hero-inner w-container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Home
      </a>
      {autoBreadcrumbs.map((crumb, i) => (
        <>
          <span class="separator" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </span>
          {crumb.href ? (
            <a href={crumb.href}>{crumb.label}</a>
          ) : (
            <span class="current">{crumb.label}</span>
          )}
        </>
      ))}
    </nav>

    <div class="sub-hero-content">
      {titleEn && <p class="sub-hero-title-en eng">{titleEn}</p>}
      <h1 class="sub-hero-title">{title}</h1>
      <div class="sub-hero-bar"></div>
    </div>
  </div>
</section>

<style>
  .sub-hero {
    position: relative;
    padding: 8rem 0 3.5rem;
    overflow: hidden;
    min-height: 240px;
  }

  .sub-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #0a1628 0%, #0f2042 40%, #132b55 70%, #0a1628 100%);
    z-index: 0;
  }

  /* Minimal accents - Apple/Toss style */
  .sub-hero-shapes {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .glow-orb {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 123, 255, 0.08) 0%, transparent 65%);
    top: -100px;
    right: -50px;
    animation: orbBreathe 6s ease-in-out infinite;
  }

  .line-h {
    position: absolute;
    bottom: 35%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.04) 30%, rgba(255,255,255,0.04) 70%, transparent 100%);
  }

  .line-v {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 20%;
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.03) 40%, rgba(255,255,255,0.03) 60%, transparent 100%);
  }

  @keyframes orbBreathe {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  .sub-hero-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40%;
    height: 2px;
    background: linear-gradient(90deg, #007BFF, transparent);
    z-index: 4;
  }

  .sub-hero-inner {
    position: relative;
    z-index: 3;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .breadcrumb a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .breadcrumb svg {
    opacity: 0.4;
  }

  .separator {
    display: flex;
    align-items: center;
    opacity: 0.2;
  }

  .breadcrumb .current {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 600;
  }

  .sub-hero-content {
    display: flex;
    flex-direction: column;
  }

  .sub-hero-title-en {
    font-size: 12px;
    color: rgba(96, 165, 250, 0.7);
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .sub-hero-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -1.5px;
    line-height: 1.15;
  }

  .sub-hero-bar {
    width: 40px;
    height: 2px;
    background: #007BFF;
    border-radius: 1px;
    margin-top: 1.25rem;
  }

  @media (max-width: 999px) {
    .sub-hero {
      padding: 6rem 0 2rem;
      min-height: 180px;
    }

    .sub-hero-title {
      font-size: 1.8rem;
    }

    .sub-hero-title-en {
      font-size: 11px;
      letter-spacing: 2px;
    }

    .breadcrumb {
      font-size: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glow-orb {
      animation: none;
    }
  }
</style>
