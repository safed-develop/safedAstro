---
const currentYear = new Date().getFullYear();
---

<!-- Map Section -->
<section class="ft-map">
  <iframe
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3165.1!2d127.0622!3d37.5085!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x357ca40000000000%3A0x0!2z7ISc7Jq47Yq567OE7IucIOqwleuCqOq1rCDthYztl6TrnoDroZwgNTM0!5e0!3m2!1sko!2skr!4v1"
    width="100%"
    height="100%"
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
  <div class="ft-map-pin">
    <div class="ft-pin-pulse"></div>
    <svg width="28" height="36" viewBox="0 0 28 36" fill="none">
      <path d="M14 0C6.268 0 0 6.268 0 14c0 10.5 14 22 14 22s14-11.5 14-22C28 6.268 21.732 0 14 0z" fill="#E53E3E"/>
      <circle cx="14" cy="14" r="6" fill="white"/>
    </svg>
  </div>
</section>

<!-- CTA + Inquiry Form -->
<section class="ft-cta">
  <div class="ft-cta-inner w-container">
    <div class="ft-cta-left">
      <h2 class="ft-cta-heading">안전한 현장을 위한<br/><span class="ft-outline-text">첫걸음</span>을 시작하세요</h2>
      <p class="ft-cta-sub">서비스 도입 문의를 남겨주시면, 담당자가 맞춤 솔루션을 안내드리겠습니다.</p>
    </div>
    <div class="ft-cta-right">
      <form class="ft-form" id="ft-inquiry-form">
        <div class="ft-form-row ft-form-row-3">
          <div class="ft-field">
            <label for="ft-name">회사명 / 담당자명*</label>
            <input type="text" id="ft-name" name="name" required autocomplete="organization" />
          </div>
          <div class="ft-field">
            <label for="ft-email">이메일*</label>
            <input type="email" id="ft-email" name="email" required autocomplete="email" />
          </div>
          <div class="ft-field">
            <label for="ft-tel">연락처*</label>
            <input type="tel" id="ft-tel" name="tel" required autocomplete="tel" />
          </div>
        </div>
        <div class="ft-form-bottom-row">
          <div class="ft-field ft-field-msg">
            <label for="ft-message">문의 내용</label>
            <textarea id="ft-message" name="message" rows="1"></textarea>
          </div>
          <button type="submit" class="ft-submit-btn">
            <span>도입 문의</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="ft-footer">
  <div class="w-container">
    <!-- SAFED Letter Grid: each letter in a cell with border lines -->
    <div class="ft-letter-grid" aria-hidden="true">
      <div class="ft-letter-cell"><span class="eng">S</span></div>
      <div class="ft-letter-cell"><span class="eng">A</span></div>
      <div class="ft-letter-cell"><span class="eng">F</span></div>
      <div class="ft-letter-cell"><span class="eng">E</span></div>
      <div class="ft-letter-cell ft-letter-d"><span class="eng">D</span></div>
    </div>

    <!-- Info Columns -->
    <div class="ft-info">
      <div class="ft-info-col">
        <p class="ft-company">세이프디</p>
        <p class="ft-detail">사업자등록번호 724-81-03168</p>
        <p class="ft-detail">서울특별시 강남구 테헤란로 534, 21층<br/>(대치동, 글라스타워)</p>
      </div>
      <div class="ft-info-col">
        <span class="ft-label">대표전화</span>
        <a href="tel:02-6748-0835" class="ft-val">02-6748-0835</a>
        <span class="ft-label">이메일</span>
        <a href="mailto:sales@safed.co.kr" class="ft-val">sales@safed.co.kr</a>
      </div>
      <div class="ft-info-col">
        <span class="ft-label">영업시간</span>
        <p class="ft-val">월–금: 09:00–18:00</p>
        <span class="ft-label">팩스</span>
        <p class="ft-val">02-6956-5291</p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="ft-bottom">
      <div class="ft-bottom-left">
        <p class="ft-copy eng">&copy; {currentYear} SafeD. All rights reserved.</p>
        <span class="ft-dot">·</span>
        <a href="/privacy-policy">개인정보처리방침</a>
        <span class="ft-dot">·</span>
        <a href="/terms-of-service">이용약관</a>
      </div>
      <div class="ft-bottom-right">
        <a href="/files/safed_company_profile.pdf" target="_blank" rel="noopener noreferrer" class="ft-link-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
          회사소개서
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.safed" target="_blank" rel="noopener noreferrer" class="ft-link-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3l18 9-18 9V3z"/></svg>
          Android
        </a>
        <a href="https://apps.apple.com/app/safed" target="_blank" rel="noopener noreferrer" class="ft-link-btn">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M15.5 8.5c-.7-1.2-2-2-3.5-2s-2.8.8-3.5 2"/><path d="M12 6v2"/></svg>
          iOS
        </a>
        <a href="https://safed.co.kr/login" target="_blank" rel="noopener noreferrer" class="ft-link-btn ft-link-btn-primary">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          SafeD 바로가기
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ============ MAP ============ */
  .ft-map {
    position: relative;
    width: 100%;
    height: 420px;
    overflow: hidden;
    background: #e8e8e8;
  }

  .ft-map iframe {
    width: 100%;
    height: 100%;
    filter: grayscale(1) contrast(1.05);
  }

  .ft-map-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -100%);
    z-index: 2;
    pointer-events: none;
  }

  .ft-pin-pulse {
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: rgba(229, 62, 62, 0.3);
    animation: pin-pulse 2s ease-out infinite;
  }

  @keyframes pin-pulse {
    0% { transform: translateX(-50%) scale(1); opacity: 0.6; }
    100% { transform: translateX(-50%) scale(3.5); opacity: 0; }
  }

  /* ============ CTA + FORM ============ */
  .ft-cta {
    background: #111111;
    color: #fff;
    padding: 2.5rem 0;
    position: relative;
  }

  .ft-cta-inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2rem;
    align-items: start;
  }

  .ft-cta-heading {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -0.5px;
    color: #fff;
  }

  .ft-cta-sub {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  /* 첫걸음 — thin outline + metallic shine sweep */
  .ft-outline-text {
    color: transparent !important;
    -webkit-text-fill-color: transparent;
    font-weight: 300;
    position: relative;
    -webkit-text-stroke: 1px rgba(255,255,255,0.25);
  }

  .ft-outline-text::before {
    content: '첫걸음';
    position: absolute;
    inset: 0;
    font-weight: inherit;
    background: linear-gradient(
      90deg,
      transparent 0%,
      transparent 30%,
      rgba(255,255,255,0.6) 44%,
      rgba(255,255,255,1) 50%,
      rgba(255,255,255,0.6) 56%,
      transparent 70%,
      transparent 100%
    );
    background-size: 250% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 1px transparent;
    animation: ft-metallic-sweep 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes ft-metallic-sweep {
    0% { background-position: 200% 0; }
    100% { background-position: -50% 0; }
  }

  .ft-cta-contact {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ft-cc-row {
    display: flex;
    gap: 0.75rem;
    font-size: 12.5px;
    color: rgba(255,255,255,0.5);
  }

  .ft-cc-label {
    color: rgba(255,255,255,0.3);
    min-width: 36px;
    font-weight: 500;
  }

  .ft-cc-row a:hover {
    color: #fff;
  }

  /* Form */
  .ft-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ft-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .ft-form-row-3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .ft-field {
    display: flex;
    flex-direction: column;
  }

  .ft-field label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.35rem;
    font-weight: 500;
  }

  .ft-field input,
  .ft-field textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    font-size: 0.85rem;
    font-family: inherit;
    padding: 0.375rem 0;
    outline: none;
    transition: border-color 0.3s ease;
    resize: none;
  }

  .ft-field input:focus,
  .ft-field textarea:focus {
    border-bottom-color: #fff;
  }

  .ft-form-bottom-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .ft-field-msg {
    flex: 1;
  }

  .ft-submit-btn {
    margin-top: 0;
    flex-shrink: 0;
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 2.25rem;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 0;
    background: transparent;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .ft-submit-btn:hover {
    background: #fff;
    color: #111;
  }

  /* ============ FOOTER ============ */
  .ft-footer {
    position: relative;
    color: rgba(255,255,255,0.6);
    font-size: 13px;
    background: transparent;
  }

  /* Shared animated gradient background for CTA + Footer */
  .ft-cta,
  .ft-footer {
    --ft-bg: #111111;
  }

  .ft-cta::before,
  .ft-footer::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--ft-bg);
  }

  .ft-cta::after,
  .ft-footer::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(180,180,190,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 60% 60% at 80% 60%, rgba(200,200,210,0.05) 0%, transparent 70%),
      radial-gradient(ellipse 90% 40% at 50% 80%, rgba(160,165,175,0.04) 0%, transparent 60%);
    background-size: 200% 200%, 200% 200%, 200% 200%;
    animation: ft-silver-shift 12s ease-in-out infinite alternate;
  }

  .ft-cta > *,
  .ft-footer > * {
    position: relative;
    z-index: 1;
  }

  @keyframes ft-silver-shift {
    0% {
      background-position: 0% 0%, 100% 100%, 50% 0%;
    }
    33% {
      background-position: 100% 50%, 0% 0%, 80% 100%;
    }
    66% {
      background-position: 50% 100%, 50% 50%, 0% 50%;
    }
    100% {
      background-position: 100% 0%, 0% 100%, 50% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ft-cta::after,
    .ft-footer::after {
      animation: none;
    }
  }

  /* SAFED Letter Grid */
  .ft-letter-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ft-letter-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 0;
    border-left: 1px solid rgba(255,255,255,0.08);
  }

  .ft-letter-cell:first-child {
    border-left: none;
  }

  .ft-letter-cell span {
    font-family: var(--font-english, 'DM Sans', sans-serif);
    font-size: clamp(3.5rem, 8vw, 7.5rem);
    font-weight: 800;
    color: rgba(255,255,255,0.06);
    line-height: 1;
    user-select: none;
    transition: color 0.5s ease;
  }

  .ft-letter-grid:hover .ft-letter-cell span {
    color: rgba(255,255,255,0.12);
  }

  /* D letter blue glow */
  .ft-letter-d span {
    color: transparent !important;
    -webkit-text-stroke: 1px rgba(59, 130, 246, 0.25);
    text-shadow: 0 0 40px rgba(59, 130, 246, 0.1);
    animation: ft-d-glow 4s ease-in-out infinite;
  }

  .ft-letter-grid:hover .ft-letter-d span {
    -webkit-text-stroke-color: rgba(59, 130, 246, 0.5);
    color: transparent !important;
  }

  @keyframes ft-d-glow {
    0%, 100% {
      -webkit-text-stroke-color: rgba(59, 130, 246, 0.2);
      text-shadow: 0 0 30px rgba(59, 130, 246, 0.05);
    }
    50% {
      -webkit-text-stroke-color: rgba(59, 130, 246, 0.45);
      text-shadow: 0 0 60px rgba(59, 130, 246, 0.15), 0 0 120px rgba(59, 130, 246, 0.05);
    }
  }

  /* Info Grid — aligned to 5-col letter grid */
  .ft-info {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1.5fr;
    gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .ft-info-col {
    padding: 1.75rem 1.5rem;
    border-left: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ft-info-col:first-child {
    border-left: none;
    padding-left: 0;
  }

  .ft-company {
    color: rgba(255,255,255,0.85);
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 0.2rem;
  }

  .ft-detail {
    color: rgba(255,255,255,0.35);
    font-size: 12px;
    line-height: 1.6;
  }

  .ft-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: rgba(255,255,255,0.25);
    margin-top: 0.6rem;
    font-weight: 500;
  }

  .ft-info-col .ft-label:first-child {
    margin-top: 0;
  }

  .ft-val {
    color: rgba(255,255,255,0.55);
    font-size: 12.5px;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a.ft-val:hover {
    color: #fff;
  }

  /* Bottom Bar */
  .ft-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .ft-bottom-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ft-bottom-left a {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .ft-bottom-left a:hover {
    color: #fff;
  }

  .ft-dot {
    color: rgba(255,255,255,0.12);
    font-size: 11px;
  }

  .ft-copy {
    font-size: 11px;
    color: rgba(255,255,255,0.2);
  }

  .ft-bottom-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .ft-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px;
    color: rgba(255,255,255,0.4);
    font-size: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    letter-spacing: 0.3px;
  }

  .ft-link-btn:hover {
    border-color: rgba(255,255,255,0.3);
    color: #fff;
  }

  .ft-link-btn-primary {
    border-color: rgba(0,123,255,0.3);
    color: rgba(0,123,255,0.7);
    background: rgba(0,123,255,0.05);
  }

  .ft-link-btn-primary:hover {
    border-color: rgba(0,123,255,0.6);
    color: #fff;
    background: rgba(0,123,255,0.15);
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 999px) {
    .ft-map { height: 300px; }

    .ft-cta-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .ft-info {
      grid-template-columns: 1fr 1fr;
    }

    .ft-info-col:nth-child(3) {
      grid-column: 1 / -1;
      border-left: none;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-left: 0;
    }
  }

  @media (max-width: 639px) {
    .ft-map { height: 220px; }
    .ft-cta { padding: 2.5rem 0; }

    .ft-form-row {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .ft-form-row-3 {
      grid-template-columns: 1fr;
    }

    .ft-letter-cell span {
      font-size: clamp(2.5rem, 14vw, 4rem);
    }

    .ft-letter-cell {
      padding: 1rem 0;
    }

    .ft-info {
      grid-template-columns: 1fr;
    }

    .ft-info-col {
      border-left: none !important;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1.25rem 0;
    }

    .ft-info-col:first-child {
      border-top: none;
    }

    .ft-bottom {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }

    .ft-bottom-left {
      flex-wrap: wrap;
      justify-content: center;
    }

    .ft-bottom-right {
      flex-wrap: wrap;
      justify-content: center;
    }

    .ft-submit-btn {
      width: 100%;
      justify-content: center;
    }

    .ft-form-bottom-row {
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ft-pin-pulse {
      animation: none;
      opacity: 0.3;
    }
    .ft-outline-text {
      -webkit-text-stroke-color: rgba(255, 255, 255, 0.4);
    }
    .ft-outline-text::before {
      animation: none;
      background: none;
      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.4);
    }
    .ft-letter-d span {
      animation: none;
    }
  }
</style>

<script>
  const form = document.getElementById('ft-inquiry-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const toast = document.createElement('div');
      toast.textContent = '문의가 접수되었습니다. 담당자가 빠르게 연락드리겠습니다.';
      Object.assign(toast.style, {
        position: 'fixed', bottom: '2rem', left: '50%', transform: 'translateX(-50%)',
        background: '#10B981', color: '#fff', padding: '1rem 2rem', borderRadius: '8px',
        fontSize: '0.9rem', fontWeight: '600', zIndex: '9999', opacity: '0',
        transition: 'opacity 0.3s ease', boxShadow: '0 4px 20px rgba(0,0,0,0.3)'
      });
      document.body.appendChild(toast);
      requestAnimationFrame(() => { toast.style.opacity = '1'; });
      setTimeout(() => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
      form.reset();
    });
  }
</script>
