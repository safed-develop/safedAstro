---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-main w-container">
    <div class="footer-left">
      <a href="/" class="footer-logo">
        <img src="/images/sign_logo_new.gif" alt="SafeD" style="height: 24px; filter: brightness(0) invert(1);" />
      </a>
      <p class="footer-tagline eng">Contech Future Leader</p>
    </div>

    <div class="footer-middle">
      <div class="footer-contact">
        <div class="contact-item">
          <span class="contact-label">주소</span>
          <span>서울특별시 강남구 테헤란로 534, 21층 (대치동, 글라스타워)</span>
        </div>
        <div class="contact-item">
          <span class="contact-label">이메일</span>
          <a href="mailto:sales@safed.co.kr">sales@safed.co.kr</a>
        </div>
        <div class="contact-item">
          <span class="contact-label">전화</span>
          <a href="tel:02-6748-0835">02-6748-0835</a>
        </div>
      </div>
    </div>

    <div class="footer-right">
      <a href="/company-profile.pdf" target="_blank" rel="noopener noreferrer" class="footer-download">
        회사소개서 다운로드
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner w-container">
      <p class="copyright eng">&copy; {currentYear} SafeD. All rights reserved.</p>
      <div class="footer-links">
        <a href="/privacy-policy">개인정보처리방침</a>
        <a href="/terms-of-service">이용약관</a>
        <a href="/inquiries">문의하기</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #1a1a1a;
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
  }

  .footer-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 3.5rem 1.5rem;
    gap: 2rem;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo img {
    height: 24px;
    width: auto;
  }

  .footer-tagline {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 1px;
  }

  .footer-middle {
    flex: 1;
    max-width: 500px;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    font-size: 13px;
    line-height: 1.6;
  }

  .contact-label {
    color: rgba(255, 255, 255, 0.4);
    min-width: 40px;
    font-weight: 500;
  }

  .contact-item a:hover {
    color: #fff;
  }

  .footer-right {
    display: flex;
    align-items: flex-start;
  }

  .footer-download {
    font-size: 13px;
    font-weight: 500;
    padding: 0.6rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .footer-download:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
  }

  .copyright {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  @media (max-width: 999px) {
    .footer-main {
      flex-direction: column;
      gap: 2rem;
      padding: 2.5rem 1.5rem;
    }

    .footer-middle {
      max-width: 100%;
    }

    .footer-bottom-inner {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
