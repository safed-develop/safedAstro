<div class="pm-phone" id="phone-mockup">

  <div class="pm-frame">

    <div class="pm-screen">

      <div class="pm-island"></div>

      <div class="pm-status-bar">

        <span class="pm-time eng">9:41</span>

        <div class="pm-status-right">

          <svg width="15" height="11" viewBox="0 0 15 11" fill="#191F28">

            <rect x="0" y="4" width="2.5" height="7" rx="0.5" opacity="0.25"/>

            <rect x="3.5" y="3" width="2.5" height="8" rx="0.5" opacity="0.45"/>

            <rect x="7" y="1.5" width="2.5" height="9.5" rx="0.5" opacity="0.65"/>

            <rect x="10.5" y="0" width="2.5" height="11" rx="0.5"/>

          </svg>

          <svg width="22" height="11" viewBox="0 0 22 11" fill="none">

            <rect x="0.5" y="0.5" width="19" height="10" rx="2" stroke="#191F28" stroke-width="1" opacity="0.3"/>

            <rect x="2" y="2" width="15" height="7" rx="1" fill="#191F28"/>

            <rect x="20" y="3.5" width="2" height="4" rx="1" fill="#191F28" opacity="0.3"/>

          </svg>

        </div>

      </div>

      <img src="/images/phone-screen.png" alt="SafeD" class="pm-img" />

      <div class="pm-content">

        <div class="pm-placeholder">

          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#B0B8C1" stroke-width="1.2">

            <rect x="5" y="2" width="14" height="20" rx="3"/>

            <circle cx="12" cy="18" r="1"/>

            <path d="M9 8h6M9 11h4"/>

          </svg>



        </div>

      </div>

      <div class="pm-home"></div>

    </div>

  </div>

  <div class="pm-btn-power"></div>

  <div class="pm-btn-vol-up"></div>

  <div class="pm-btn-vol-down"></div>

</div>



<style>

  .pm-phone {

    width: 268px;

    height: 580px;

    position: relative;

    flex-shrink: 0;

  }

  .pm-frame {

    width: 100%;

    height: 100%;

    background: #191F28;

    border-radius: 48px;

    padding: 10px;

    position: relative;

    box-shadow:

      inset 0 0 0 1px rgba(255,255,255,0.08),

      0 25px 80px rgba(0,0,0,0.12),

      0 4px 20px rgba(0,0,0,0.08),

      0 0 0 1px rgba(0,0,0,0.04);

  }

  .pm-screen {

    width: 100%;

    height: 100%;

    background: #F7F8FA;

    border-radius: 38px;

    overflow: hidden;

    position: relative;

    display: flex;

    flex-direction: column;

  }

  .pm-island {

    position: absolute;

    top: 12px;

    left: 50%;

    transform: translateX(-50%);

    width: 84px;

    height: 24px;

    background: #191F28;

    border-radius: 12px;

    z-index: 3;

  }

  .pm-status-bar {

    display: flex;

    align-items: center;

    justify-content: space-between;

    padding: 14px 24px 0;

    height: 48px;

    flex-shrink: 0;

    position: relative;

    z-index: 2;

  }

  .pm-time {

    font-size: 13px;

    font-weight: 600;

    color: #191F28;

    letter-spacing: -0.2px;

  }

  .pm-status-right {

    display: flex;

    align-items: center;

    gap: 5px;

  }

  .pm-content {

    flex: 1;

    display: flex;

    align-items: center;

    justify-content: center;

    padding: 16px;

  }

  .pm-img {

    width: 100%;

    height: 100%;

    object-fit: cover;

  }

  .pm-placeholder {

    display: flex;

    flex-direction: column;

    align-items: center;

    gap: 12px;

    opacity: 0.5;

  }

  .pm-ph-text {

    font-size: 11px;

    font-weight: 500;

    color: #B0B8C1;

    letter-spacing: 0.5px;

  }

  .pm-home {

    width: 100px;

    height: 4px;

    background: #191F28;

    border-radius: 2px;

    margin: 0 auto 8px;

    opacity: 0.2;

  }

  .pm-btn-power {

    position: absolute;

    right: -2px;

    top: 160px;

    width: 3px;

    height: 64px;

    background: #2A2F3A;

    border-radius: 0 2px 2px 0;

  }

  .pm-btn-vol-up {

    position: absolute;

    left: -2px;

    top: 140px;

    width: 3px;

    height: 32px;

    background: #2A2F3A;

    border-radius: 2px 0 0 2px;

  }

  .pm-btn-vol-down {

    position: absolute;

    left: -2px;

    top: 182px;

    width: 3px;

    height: 32px;

    background: #2A2F3A;

    border-radius: 2px 0 0 2px;

  }

</style>

